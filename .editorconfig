# EditorConfig — 소유: 린트·포맷
# 에디터가 파일을 **저장하는 순간**의 규칙이다. 내용의 서식은 Prettier(.prettierrc.json)가 소유하고,
# 여기서는 Prettier 가 관여하지 않는 것(문자 인코딩·개행·최종 개행·후행 공백)만 정한다.
# 두 파일의 값(indent 2 · LF)은 서로 어긋나면 안 된다 — 어긋나면 저장할 때마다 diff 가 튄다.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown 은 줄 끝 공백 2칸이 <br> 로 의미를 갖는다 — 지우지 않는다.
[*.md]
trim_trailing_whitespace = false

# 생성물·lockfile 은 도구가 쓰는 파일이다.
[pnpm-lock.yaml]
insert_final_newline = unset
trim_trailing_whitespace = unset
