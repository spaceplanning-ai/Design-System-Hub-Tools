{
  "$schema": "https://tds.internal/schemas/component.v1.json",
  "name": "FileChip",
  "version": "1.0.0",
  "level": "molecule",
  "category": "File",
  "taxonomyItem": "file-preview",
  "status": "beta",
  "description": "지금 걸려 있는 파일 한 건 — 썸네일 + 파일명 + 용량, 그리고 선택적 제거(×). 출처: apps/admin/src/shared/ui/FilePicker.tsx (사이트 설정의 파비콘·대표 이미지·비공개 이미지가 공유).\n\n[FileDropzone 과 짝이다] 둘은 가로로 나란히 서고, 미리보기는 드롭존이 아니라 브라우저 탭 목업·OG 카드라는 **다른 자리**에 그려진다. 그래서 미리보기를 자기가 소유하는 ImageUploadField 로 대체할 수 없다 — 미리보기의 주인이 다르다.\n\n[제거 버튼은 onRemove 를 준 만큼만 생긴다] 지울 수 없는 자리(필수 자산)에 죽은 버튼을 두지 않는다 — Alert.onClose 와 같은 판단이다.\n\n[용량 표기] formatFileSize 순수 함수가 소유한다. 소수점은 MB 부터만 붙인다 — KB 단위의 '12.7KB' 는 정보가 아니라 소음이고, 칩이 보여줄 것은 '작다/크다' 이지 정확한 바이트가 아니다.",
  "owner": {
    "code": "component-eng",
    "design": "ui-design",
    "figma": "figma-eng"
  },
  "props": {
    "src": {
      "type": "string",
      "default": "",
      "description": "썸네일 URL. 비거나 로드 실패면 ImageThumb 가 placeholder 를 그린다"
    },
    "name": {
      "type": "string",
      "required": true,
      "description": "파일명 — 한 줄로 자르고 넘치면 말줄임한다. 제거 버튼의 접근 가능한 이름('<name> 제거')도 여기서 온다"
    },
    "size": {
      "type": "number",
      "required": true,
      "description": "바이트 수 — 표기는 formatFileSize 가 한다(1KB 미만 B · 1MB 미만 KB · 그 위 MB 소수 1자리). 음수/NaN 은 '-'"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "figmaProperty": "Disabled",
      "description": "비활성 — 제거 버튼을 잠근다(칩 자체는 계속 읽힌다). onRemove 발화 없음"
    }
  },
  "events": {
    "onRemove": {
      "payload": "void",
      "blockedWhen": ["disabled"],
      "description": "제거(×) 클릭. **주지 않으면 버튼이 렌더되지 않는다** — 지울 수 없는 자리에 죽은 버튼을 만들지 않는다. disabled 에서는 발화 금지 — <button disabled> 가 네이티브로 막는다"
    }
  },
  "states": ["default", "hover", "focus-visible", "disabled"],
  "tokens": {
    "gap": "space.3",
    "paddingX": "space.3",
    "paddingY": "space.2",
    "border": "color.border.default",
    "borderWidth": "border-width.thin",
    "radius": "radius.md",
    "surface": "color.surface.default",
    "nameText": "color.text.default",
    "nameTypography": "typography.label.md",
    "sizeText": "color.text.muted",
    "sizeTypography": "typography.caption.md",
    "removeSize": "space.6",
    "removeRadius": "radius.full",
    "removeText": "color.text.muted",
    "focusRing": "color.border.focus",
    "focusRingWidth": "border-width.medium"
  },
  "a11y": {
    "role": "group",
    "keyboard": ["Tab", "Enter", "Space"],
    "focusVisible": true,
    "aria": {
      "label": "제거 버튼은 '<name> 제거' 를 aria-label 로 갖는다 — 칩이 여럿 서 있어도 어느 파일을 지우는지 알 수 있다",
      "thumbnail": "썸네일 alt 는 '<name> 썸네일' — ImageThumb 가 로드 실패 시 role=img placeholder 로 대체한다",
      "locking": "disabled 이면 제거 <button disabled> 로 잠근다 — onRemove 발화가 네이티브로 차단된다"
    },
    "contrastMin": 4.5
  },
  "responsive": {
    "breakpoints": ["sm", "md", "lg"],
    "behavior": "size-fixed"
  },
  "compat": {
    "breakingSince": null,
    "deprecatedProps": []
  },
  "dependencies": ["ImageThumb"],
  "anatomy": {
    "kind": "frame",
    "name": "FileChip",
    "layout": "HORIZONTAL",
    "align": "CENTER",
    "styles": {
      "fill": "surface",
      "stroke": "border",
      "strokeWidth": "borderWidth",
      "radius": "radius",
      "padX": "paddingX",
      "padY": "paddingY",
      "gap": "gap"
    },
    "children": [
      {
        "kind": "instance",
        "name": "Thumbnail",
        "fixedWidth": 32,
        "fixedHeight": 32
      },
      {
        "kind": "frame",
        "name": "Text",
        "layout": "VERTICAL",
        "grow": true,
        "children": [
          {
            "kind": "text",
            "name": "Name",
            "text": "brand-og-image.png",
            "textProp": "name",
            "styles": {
              "color": "nameText",
              "typography": "nameTypography"
            }
          },
          {
            "kind": "text",
            "name": "Size",
            "text": "1.2MB",
            "styles": {
              "color": "sizeText",
              "typography": "sizeTypography"
            },
            "figmaText": true,
            "figmaToggle": true
          }
        ]
      },
      {
        "kind": "frame",
        "name": "Remove",
        "layout": "HORIZONTAL",
        "align": "CENTER",
        "justify": "CENTER",
        "styles": {
          "size": "removeSize",
          "radius": "removeRadius"
        },
        "children": [
          {
            "kind": "vector",
            "name": "Remove Glyph",
            "styles": {
              "color": "removeText",
              "typography": "sizeTypography"
            },
            "svgIcon": "close",
            "fixedWidth": 16,
            "fixedHeight": 16
          }
        ]
      }
    ]
  }
}
