{
  "$schema": "https://tds.internal/schemas/component.v1.json",
  "name": "LineAreaChart",
  "version": "1.1.0",
  "level": "molecule",
  "status": "beta",
  "description": "범용 선 + 면적 차트 — 계열마다 kind 로 선/면적을 고른다. 외부 차트 라이브러리 의존 0 (SVG 좌표 직접 계산, Catmull-Rom → 3차 베지어 스무딩). 도메인 중립: '방문자/페이지뷰' 같은 계열 의미는 데이터를 주입하는 organism 이 소유한다 (ADR-0003). 출처 구현: apps/admin/src/pages/dashboard/components/VisitorChart.tsx 를 일반화",
  "owner": {
    "code": "A30",
    "design": "A14",
    "figma": "A51"
  },
  "props": {
    "series": {
      "type": "array",
      "itemShape": "{ id: string; label: string; kind: 'line' | 'area'; values: readonly number[] }",
      "required": true,
      "description": "계열 목록. values 길이는 labels 길이와 같아야 한다. 데이터 prop — Figma 대응 없음 (ADR-0003)"
    },
    "labels": {
      "type": "array",
      "itemShape": "string",
      "required": true,
      "description": "x축 눈금 라벨. 데이터 prop — Figma 대응 없음"
    },
    "showLegend": {
      "type": "boolean",
      "default": true,
      "figmaProperty": "ShowLegend",
      "description": "계열 범례 표시 여부. 범례는 장식이 아니라 계열 식별 수단이므로 기본 노출"
    },
    "ariaLabel": {
      "type": "string",
      "required": true,
      "description": "role=img 의 접근 가능한 이름. 차트가 전달하는 추세를 문장으로 기술한다"
    }
  },
  "states": ["default"],
  "tokens": {
    "gridLine": "color.chart.axis",
    "axisLabel": "color.chart.label",
    "legendText": "color.chart.label",
    "legendDotRadius": "radius.full",
    "legendGap": "space.4",
    "legendItemGap": "space.1",
    "lineColor": "color.chart.series-1",
    "pointColor": "color.chart.series-1",
    "areaColor": "color.chart.series-1-fill",
    "surface": "color.surface.default",
    "typography": "typography.label.md",
    "focusRing": "color.border.focus",
    "lineColor2": "color.chart.series-2",
    "areaColor2": "color.chart.series-2-fill",
    "lineColor3": "color.chart.series-3",
    "areaColor3": "color.chart.series-3-fill",
    "lineColor4": "color.chart.series-4",
    "areaColor4": "color.chart.series-4-fill",
    "lineColor5": "color.chart.series-5",
    "areaColor5": "color.chart.series-5-fill",
    "lineColor6": "color.chart.series-6",
    "areaColor6": "color.chart.series-6-fill"
  },
  "a11y": {
    "role": "img",
    "keyboard": ["Tab"],
    "focusVisible": true,
    "aria": {
      "aria-label": "ariaLabel prop — 차트 전체의 이름",
      "aria-hidden": "범례 색 점 — 장식용이므로 true"
    },
    "contrastMin": 3
  },
  "responsive": {
    "breakpoints": ["sm", "md", "lg"],
    "behavior": "fluid"
  },
  "compat": {
    "breakingSince": null,
    "deprecatedProps": []
  },
  "dependencies": []
}
