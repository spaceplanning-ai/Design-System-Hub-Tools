{
  "$schema": "https://tds.internal/schemas/component.v1.json",
  "name": "ListRow",
  "version": "1.0.0",
  "level": "molecule",
  "status": "beta",
  "description": "리스트 한 줄 — 좌측 아이콘 + 제목 + 메타(보조 텍스트). href 가 있으면 링크로, 없으면 onClick 만 갖는 행으로 렌더한다. 목록 컨테이너(ul)와 도메인 의미는 조립하는 organism(ListCard 등)이 소유한다. 출처 구현: apps/admin/src/pages/dashboard/components/ListCard.tsx 의 행(row) 부분",
  "owner": { "code": "component-eng", "design": "ui-design", "figma": "figma-eng" },

  "props": {
    "title": {
      "type": "string",
      "required": true,
      "description": "행 제목. 길면 줄바꿈(overflow-wrap: anywhere)"
    },
    "meta": {
      "type": "string",
      "default": "",
      "description": "제목 아래 보조 텍스트 (예: '작성자 · 날짜'). 빈 문자열이면 렌더하지 않는다"
    },
    "icon": {
      "type": "slot",
      "accepts": ["Icon"],
      "default": null,
      "description": "좌측 아이콘 슬롯. 장식용이므로 aria-hidden"
    },
    "href": {
      "type": "string",
      "default": "",
      "description": "링크 대상. 빈 문자열이면 링크가 아닌 행으로 렌더한다"
    }
  },

  "events": {
    "onClick": {
      "payload": "MouseEvent",
      "description": "행 클릭. href 가 있어도 라우팅 가로채기/분석 계측을 위해 함께 발화한다"
    }
  },

  "states": ["default", "hover", "focus-visible"],

  "tokens": {
    "title": "color.text.default",
    "meta": "color.text.muted",
    "icon": "color.text.muted",
    "borderBottom": "color.border.default",
    "backgroundHover": "color.surface.raised",
    "radius": "radius.sm",
    "paddingX": "space.2",
    "paddingY": "space.3",
    "gap": "space.2",
    "titleTypography": "typography.label.md",
    "focusRing": "color.border.focus",
    "transitionDuration": "motion.duration.fast",
    "transitionEasing": "motion.easing.standard"
  },

  "a11y": {
    "role": "link",
    "keyboard": ["Tab", "Enter"],
    "focusVisible": true,
    "aria": {
      "aria-hidden": "아이콘 슬롯 — 장식용이므로 true"
    },
    "contrastMin": 4.5
  },

  "responsive": {
    "breakpoints": ["sm", "md", "lg"],
    "behavior": "fluid"
  },

  "compat": {
    "breakingSince": null,
    "deprecatedProps": []
  },

  "dependencies": []
}
