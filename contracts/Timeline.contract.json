{
  "$schema": "https://tds.internal/schemas/component.v1.json",
  "name": "Timeline",
  "version": "1.0.0",
  "level": "molecule",
  "category": "Data Display",
  "taxonomyItem": "timeline",
  "status": "beta",
  "description": "이벤트 타임라인 — 시간순 이력 목록. StatusBadge 를 조립해 각 이벤트를 배지 톤·라벨·작성자·시각·본문으로 보여준다 (ADR-0003). 도메인을 모른다 — 무슨 이벤트인지 알지 못하고, 각 페이지가 자기 이벤트(문의·티켓·예약)를 표시용 TimelineEvent 로 매핑해 넘긴다.\n\n[시각 포맷] at 은 ISO 문자열이고 컴포넌트가 'YYYY-MM-DD HH:mm' 로 표기한다(로컬 타임존). 포맷터는 외부 의존이 없는 순수 함수로 컴포넌트에 co-locate 한다(앱 shared/format 을 끌어오지 않는다 — @tds/ui 자립).\n\n[events 는 데이터 prop] Figma Component Property 대응이 없다 (ADR-0003). 빈 배열이면 emptyLabel 문구를 렌더한다.",
  "owner": {
    "code": "component-eng",
    "design": "ui-design",
    "figma": "figma-eng"
  },
  "props": {
    "events": {
      "type": "array",
      "itemShape": "{ id: string; at: string; badgeTone: 'neutral' | 'success' | 'warning' | 'danger' | 'info'; badgeLabel: string; author: string; text: string }",
      "required": true,
      "description": "표시용으로 환산된 타임라인 이벤트 목록. at 은 ISO 시각, badgeTone/badgeLabel 은 StatusBadge 로 렌더, author/text 는 작성자/본문. 빈 배열이면 emptyLabel 을 렌더한다. 데이터 prop — Figma 대응 없음 (ADR-0003)"
    },
    "label": {
      "type": "string",
      "required": true,
      "description": "스크린 리더용 목록 이름 — '문의 처리 이력' 등. <ol> 의 aria-label 이 된다"
    },
    "emptyLabel": {
      "type": "string",
      "default": "기록된 이력이 없습니다.",
      "description": "events 가 빈 배열일 때 표시할 문구"
    }
  },
  "states": ["default"],
  "tokens": {
    "itemBorder": "color.border.default",
    "itemSurface": "color.surface.raised",
    "radius": "radius.md",
    "author": "color.text.default",
    "time": "color.text.muted",
    "text": "color.text.default",
    "empty": "color.text.muted",
    "gap": "space.3",
    "typography": "typography.label.md"
  },
  "a11y": {
    "role": "list",
    "keyboard": ["none — 정적 이력 목록이라 상호작용 키가 없다 (탭 순서에 들어가지 않는다)"],
    "focusVisible": false,
    "aria": {
      "aria-label": "label prop — <ol> 에 목록 이름을 부여한다",
      "badge": "각 이벤트의 상태는 StatusBadge(tone+label)로 색과 문구로 이중 전달한다 (dependencies: StatusBadge)"
    },
    "contrastMin": 4.5
  },
  "responsive": {
    "breakpoints": ["sm", "md", "lg"],
    "behavior": "fluid"
  },
  "compat": {
    "breakingSince": null,
    "deprecatedProps": []
  },
  "dependencies": ["StatusBadge"],
  "anatomy": {
    "kind": "frame",
    "name": "Timeline",
    "layout": "VERTICAL",
    "styles": {
      "gap": "gap"
    },
    "children": [
      {
        "kind": "frame",
        "name": "Event Item",
        "layout": "VERTICAL",
        "repeat": 4,
        "styles": {
          "fill": "itemSurface",
          "stroke": "itemBorder",
          "radius": "radius",
          "pad": "gap",
          "gap": "gap"
        },
        "children": [
          {
            "kind": "frame",
            "name": "Item Head",
            "layout": "HORIZONTAL",
            "align": "CENTER",
            "styles": {
              "gap": "gap"
            },
            "children": [
              {
                "kind": "instance",
                "name": "StatusBadge",
                "fixedWidth": 56,
                "fixedHeight": 22
              },
              {
                "kind": "text",
                "name": "Author",
                "text": "관리자 홍길동",
                "grow": true,
                "styles": {
                  "color": "author",
                  "typography": "typography"
                },
                "samples": ["관리자 홍길동", "상담원 김영희", "시스템", "관리자 박철수"]
              },
              {
                "kind": "text",
                "name": "Time",
                "text": "2026-07-18 14:32",
                "styles": {
                  "color": "time",
                  "typography": "typography"
                },
                "samples": [
                  "2026-07-18 14:32",
                  "2026-07-18 11:07",
                  "2026-07-17 22:15",
                  "2026-07-17 09:40"
                ]
              }
            ]
          },
          {
            "kind": "text",
            "name": "Item Text",
            "text": "담당자를 배정하고 고객에게 회신했습니다.",
            "styles": {
              "color": "text",
              "typography": "typography"
            },
            "samples": [
              "담당자를 배정하고 고객에게 회신했습니다.",
              "문의 내용을 확인했습니다.",
              "접수 알림을 발송했습니다.",
              "문의가 등록되었습니다."
            ]
          }
        ]
      },
      {
        "kind": "text",
        "name": "Empty",
        "text": "기록된 이력이 없습니다.",
        "textProp": "emptyLabel",
        "styles": {
          "color": "empty",
          "typography": "typography"
        }
      }
    ]
  }
}
