%% 어드민 전체 플로우 — 진입부터 업무 완료까지 한 장
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
%% mermaid.live 에 이 파일 내용을 그대로 붙여넣는다 (``` 펜스 없이)
flowchart TD
    Start(["운영자 진입"]) --> Auth{"RequireAuth<br/>세션 있나"}
    Auth -->|"없음"| Login["로그인 화면<br/>셸 바깥 단독"]
    Auth -->|"있음"| Shell["AppShell<br/>사이드바 + 헤더"]

    Login --> AuthOk{"인증 성공"}
    AuthOk -->|"실패"| LoginErr["오류 표시 · 폼 유지"] --> Login
    AuthOk -->|"성공"| ReturnUrl{"returnUrl 있나"}
    ReturnUrl -->|"있음"| Target
    ReturnUrl -->|"없음"| Dash

    Shell --> Dash["대시보드<br/>/dashboard"]
    Dash --> Nav["사이드바에서 업무 선택"]
    Nav --> Perm{"RequirePermission"}
    Perm -->|"권한 없음"| Deny["403 화면"]
    Perm -->|"권한 있음"| Target["lazy 청크 로드 후 화면 진입"]

    Target --> Ex{"렌더 중 예외"}
    Ex -->|"예외"| Boundary["ErrorBoundary<br/>셸은 살리고 본문만 복구"] --> Nav
    Ex -->|"정상"| Work{"업무 성격"}

    Work -->|"만들고 고친다"| GW["쓰기 업무"]
    Work -->|"들어온 건을 처리한다"| GP["처리 업무"]
    Work -->|"보기만 한다"| GR["조회 업무"]

    GW --> W1["콘텐츠 발행<br/>공지·FAQ·팝업·배너·약관"]
    GW --> W2["기업·포트폴리오·상품<br/>단순 CRUD · 단일 문서"]
    GW --> W3["마케팅 캠페인·템플릿"]
    GW --> W4["회원·운영자·권한"]

    GP --> P1["영업<br/>문의 → 견적 → 계약·프로젝트"]
    GP --> P2["고객센터 티켓"]
    GP --> P3["교환·반품 · 리뷰"]

    GR --> R1["통계 · 로그 · 로그인 이력<br/>쓰기 라우트 없음"]
    GR --> R2["AI 에이전트<br/>대화는 ?c= 쿼리에"]

    W1 --> CRUD
    W2 --> CRUD
    W3 --> CRUD
    W4 --> CRUD
    P1 --> CRUD
    P2 --> TL["상세 인라인 처리<br/>타임라인 append-only"] --> Gate
    P3 --> Gate

    CRUD["폼 · 모달 · 인라인 토글"] --> Gate{"도메인 게이트<br/>상태 전이 · 잠금 규칙"}
    Gate -->|"차단"| Blocked["사유 표시 · 원상태 유지"] --> CRUD
    Gate -->|"통과"| Valid{"Zod 검증"}
    Valid -->|"실패"| VErr["필드 오류 · 첫 오류로 포커스"] --> CRUD
    Valid -->|"통과"| Mut["mutation 실행"]

    Mut --> Res{"서버 응답"}
    Res -->|"실패"| MErr["실패 토스트 · 입력값 보존"] --> CRUD
    Res -->|"성공"| Inv["쿼리 캐시 무효화"] --> Toast["성공 토스트"] --> Log["관리자 로그에 기록"]

    Log --> Back(["다음 업무"])
    R1 --> Back
    R2 --> Back
    Back --> Nav

    classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    class Auth,AuthOk,ReturnUrl,Perm,Ex,Work,Gate,Valid,Res gate
    class Deny,LoginErr,Blocked,VErr,MErr,Boundary err
    class Toast,Inv,Log ok
