%% 목록 → 상세 → 폼 공통 CRUD (대부분 도메인이 공유하는 모양)
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
    List["목록 화면"] --> Q{"조회 상태"}
    Q -->|"로딩"| Skel["스켈레톤 · aria-busy"] --> Table
    Q -->|"실패"| Efail["오류 상태 + 다시 시도"] --> List
    Q -->|"결과 0건"| Empty["빈 상태 + 등록 CTA"]
    Q -->|"성공"| Table["테이블 · 검색 · 필터 · 페이지네이션"]

    Table --> Act{"운영자 행동"}
    Act -->|"등록"| New["폼 화면 /new"]
    Act -->|"행 클릭"| Detail["상세 화면 /:id"]
    Act -->|"더보기 › 수정"| Edit["폼 화면 /:id/edit"]
    Act -->|"더보기 › 삭제"| Confirm{"삭제 확인 다이얼로그"}
    Act -->|"인라인 토글"| Inline["ON/OFF 즉시 반영<br/>팝업·배너·리뷰 노출"]
    Act -->|"검색·필터 변경"| Url["쿼리스트링 갱신<br/>URL 이 화면 상태의 원천"] --> List
    Empty --> New

    Detail --> DAct{"상세에서"}
    DAct -->|"수정"| Edit
    DAct -->|"삭제"| Confirm
    DAct -->|"목록으로"| List

    New --> Form
    Edit --> Form["React Hook Form + Zod 검증<br/>등록·수정을 :id 유무로 겸한다"]
    Form --> Valid{"검증 통과"}
    Valid -->|"실패"| FieldErr["필드 오류 · 첫 오류로 포커스"] --> Form
    Valid -->|"통과"| Mut["mutation 실행"]

    Inline --> Mut
    Mut --> MRes{"서버 응답"}
    MRes -->|"실패"| MErr["실패 토스트 · 입력값 보존"] --> Form
    MRes -->|"성공"| Inv["쿼리 캐시 무효화"] --> Toast["성공 토스트"] --> List

    Confirm -->|"취소"| Table
    Confirm -->|"확인"| DMut["삭제 mutation"] --> DRes{"응답"}
    DRes -->|"실패"| DErr["실패 토스트"] --> Table
    DRes -->|"성공"| Inv

    classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    class Q,Act,DAct,Valid,MRes,DRes,Confirm gate
    class Efail,FieldErr,MErr,DErr err
    class Toast,Inv ok
