%% 영업 파이프라인 — 문의 → 견적 → 계약 · 청구·입금 · 프로젝트 (실제 상태값 기준)
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
    In0(["고객 문의 유입"]) --> Ch{"어느 창구인가<br/>QuoteSourceChannel"}
    Ch -->|"sales"| I1["영업 문의 접수 · received<br/>/sales/inquiries"]
    Ch -->|"product"| PI["상품 문의 · received<br/>/products/inquiries · pg-off 메뉴"]
    Ch -->|"program"| GI["프로그램 문의 · received<br/>/programs/inquiries · pg-off 메뉴"]

    I1 --> I2["배정 · assigned"] --> I3["처리중 · in_progress"]
    I3 --> IHold["보류 · hold"] --> I3
    PI --> PA["답변중 · answering"]
    GI --> PA
    I3 --> IQ{"견적이 필요한가"}
    PA --> Basket["견적 바구니에 담기<br/>여러 문의를 한 견적으로"]
    IQ -->|"아니오"| I5["완료 · answered"] --> I6["종결 · closed"]
    IQ -->|"예"| Gate
    Basket --> Gate

    Gate{"발행 게이트<br/>quoteIssueBlock(candidates)"}
    Gate -->|"QUOTE_ISSUE_EMPTY"| Blocked
    Gate -->|"QUOTE_ISSUE_ALREADY<br/>hasIssuedQuote · quoteId ≠ ''"| Blocked
    Gate -->|"QUOTE_ISSUE_NOT_ISSUABLE"| Blocked
    Gate -->|"QUOTE_ISSUE_UNWIRED"| Blocked
    Blocked["발행 차단<br/>기존 견적으로 이동"]
    Gate -->|"null"| Cross{"견적 저장소 교차 확인<br/>findQuoteBySource(sourceId)"}
    Cross -->|"이미 있음"| Blocked
    Cross -->|"없음"| Issue["견적 발행 · quote_issued<br/>issueQuote(sources) → issueQuoteFromSources"]

    Issue --> Q1["견적 작성중 · draft<br/>buildQuoteFromSources 는 항상 draft 로 시작"]
    Q1 -.->|"문의에서 상속된 필드는 잠김<br/>isInherited = sources.length > 0"| Q1
    Q1 --> Q2["발송 · sent"]
    Q2 --> QRes{"고객 회신"}
    QRes -->|"승인"| Q3["승인 · accepted"]
    QRes -->|"반려"| Q4["반려 · rejected"]
    QRes -->|"기한 경과"| Q5["만료 · expired"]

    Q3 --> Conv{"수주 전환<br/>canConvertToOrder · quoteConvertBlock"}
    Q4 --> NoConv["전환 불가"]
    Q5 --> NoConv
    Conv -->|"accepted 에서만 가능"| Q6["수주전환 · ordered"]

    Q6 --> CGate{"계약 초안 게이트<br/>contractDraftBlock(status, contractId)"}
    CGate -->|"CONTRACT_DRAFT_NOT_ORDERED"| CNo["초안 불가"]
    CGate -->|"CONTRACT_DRAFT_DONE<br/>findContractIdByQuote"| CNo
    CGate -->|"null"| C1["계약 초안 · draft<br/>/sales/contracts/new?quoteId=…<br/>buildContractFromQuote → quoteId · quoteNo"]
    C1 --> C2["검토중 · review"] --> C3["진행중 · active"]
    C3 --> C4["만료 · expired"]
    C3 --> C5["해지 · terminated"]
    C3 --> Renew{"isRenewalDue<br/>autoRenew 이고 남은일수 ≤ 통지일수"}
    Renew -->|"해당"| RenewAct["갱신 안내"] --> C3

    C1 --- S0["서명 축은 별개다"]
    S0 --> S1["미발송 · unsigned"] --> S2["서명대기 · sent"] --> S3["일부서명 · partial"] --> S4["서명완료 · signed"]

    Q6 --> BGate{"청구 생성 게이트<br/>billingCreateBlock(quoteStatus, billingId)"}
    BGate -->|"BILLING_CREATE_NOT_ORDERED"| BNo["청구 불가"]
    BGate -->|"BILLING_CREATE_DONE<br/>findBillingIdByQuote · 멱등키 quoteId"| BNo
    BGate -->|"null"| B1["청구 생성 · /sales/billing<br/>method: bank_transfer | payment_link"]
    B1 --> B2["입금 안내 발송 · append only<br/>sendNoticeBlock · email/sms/kakao/phone"]
    B2 --> B3{"입금확인 기록<br/>recordPaymentBlock"}
    B3 -->|"PAYMENT_AMOUNT_POSITIVE<br/>PAYMENT_OVER_OUTSTANDING<br/>PAYMENT_DATE_REQUIRED<br/>PAYMENT_ALREADY_PAID"| BErr["기록 거절"]
    B3 -->|"null"| B4["payments 에 추가 · applyPayment"]
    B4 --> BState["입금 상태는 저장하지 않는다<br/>billingPaymentState = 누적 합에서 파생<br/>미입금 unpaid → 부분입금 partial → 입금완료 paid"]
    BState -.->|"되돌리는 전이가 없다 — 감액 엔트리를 만들 수 없다"| B4
    BState --> BOk["입금완료 · paid"]

    Q6 --> P1["프로젝트 리드 · lead · 10%"]
    P1 --> P2["상담 · qualified · 30%"] --> P3["제안 · proposal · 50%"] --> P4["협상 · negotiation · 70%"] --> P5["수주 · won · 100%"]
    P2 --> PL["실주 · lost · 0%<br/>lostReason 필수 · 스텝퍼 밖"]
    P3 --> PL
    P4 --> PL

    I3 --> CS["상담 이력 기록<br/>조회 전용 · 생성·수정 UI 없음"]
    CS --> CSO{"결과 outcome"}
    CSO -->|"긍정 positive"| CSF
    CSO -->|"보통 neutral"| CSF
    CSO -->|"부정 negative"| CSF
    CSF["후속조치 followUpAction<br/>미완료면 hasPendingFollowUp"]

    classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    class Ch,IQ,Gate,Cross,QRes,Conv,CGate,BGate,B3,Renew,CSO gate
    class Blocked,NoConv,CNo,BNo,BErr,Q4,Q5,C5,PL err
    class Q3,Q6,C3,B4,BOk,P5,S4 ok
