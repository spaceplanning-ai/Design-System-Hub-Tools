%% 콘텐츠 발행 — 공지 · 팝업 · 배너 · 약관/개인정보
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
    subgraph NOTICE["공지사항 · /content/notices"]
        N0["작성"] --> N1{"발행 방식"}
        N1 -->|"지금 게시"| N2["게시 · published"]
        N1 -->|"나중에"| N3["임시저장 · draft"]
        N1 -->|"시점 지정"| N4["예약 · scheduled"]
        N4 -->|"예약 시각 도달"| N2
        N3 --> N1
        N2 --> N5["상단 고정 pinned 토글"]
        N2 --> N6["분류 · 공지 / 이벤트 / 점검"]
    end

    subgraph POPUP["팝업 · 배너 · /content/popups · /content/banners"]
        P0["등록 폼 + 우측 실시간 미리보기"] --> P1["노출 기간 startAt · endAt"]
        P1 --> P2["우선순위 priority · 정렬 order"]
        P2 --> P3{"enabled"}
        P3 -->|"ON"| P4{"지금이 노출 기간 안인가"}
        P3 -->|"OFF"| P5["노출 안 함<br/>끄면 기간 안이라도 노출되지 않는다"]
        P4 -->|"예"| P6["노출"]
        P4 -->|"아니오"| P5
        P6 --> P7["배너는 위치 선택 · main / sub"]
    end

    subgraph TERMS["약관 · 개인정보 · /content/terms · /content/privacy"]
        T0["새 버전 작성 · v1.2 + 시행일"] --> T1{"시행일 기준"}
        T1 -->|"미래"| T2["시행예정 · scheduled"]
        T1 -->|"현재"| T3["시행중 · active · isCurrent"]
        T2 -->|"시행일 도달"| T3
        T3 -->|"새 버전이 시행되면"| T4["만료 · archived"]
        T3 --> T5["버전 이력에 남는다<br/>과거 버전은 지우지 않는다"]
    end

    %% 서브그래프를 세로로 쌓는다 — 보이지 않는 링크가 없으면 옆으로 늘어서 폭이 5000px 를 넘는다
    NOTICE ~~~ POPUP
    POPUP ~~~ TERMS

    classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    class N1,P3,P4,T1 gate
    class N2,P6,T3 ok
