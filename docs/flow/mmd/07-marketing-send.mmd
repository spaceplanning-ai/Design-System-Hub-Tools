%% 마케팅 발송 (SMS · 이메일 · 뉴스레터) + 발송 템플릿 · 알림톡 심사
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
    M0(["캠페인 작성"]) --> Ch{"채널"}
    Ch -->|"SMS"| CS["isAd 광고 여부<br/>광고면 (광고) 표기 · 무료수신거부 · 야간 발송 제한<br/>바이트로 SMS / LMS / MMS 자동 판정"]
    Ch -->|"이메일"| CE["includeUnsubscribe 수신거부 링크"]
    Ch -->|"뉴스레터"| CN["issueNo 자동 채번 · 수신거부 항상 포함"]

    CS --> Save
    CE --> Save
    CN --> Save
    Save{"저장 방식<br/>저장은 전송이 아니다"}
    Save -->|"초안 저장"| D1["초안 · draft"]
    Save -->|"예약 저장"| D2["예약 · scheduled"]

    D1 --> Edit1["수정 가능 · 삭제 가능"]
    D1 --> D2
    D2 --> Act{"예약 상태 액션"}
    Act -->|"수정"| D2
    Act -->|"예약 취소"| D5["취소 · canceled"]
    Act -->|"예약 시각 도달"| D3["발송중 · sending"]

    D3 --> Lock["수정·취소·삭제 모두 불가"]
    D3 --> D4["발송완료 · sent"]
    D4 --> NoEdit["수정 불가<br/>수신자가 받은 것과 화면이 달라지고<br/>오픈율 귀속이 깨진다"]
    NoEdit --> Clone["복제해 새 캠페인으로"]
    Clone --> M0

    TP0(["발송 템플릿 · /marketing/templates"]) --> TP1["초안 · draft<br/>수정 · 삭제 · 발행"]
    TP1 -->|"발행 · draft 에서만"| TP2["사용중 · active<br/>토글 · 삭제만 · 수정 불가"]
    TP2 -->|"먼저 꺼야 수정할 수 있다"| TP3["미사용 · inactive<br/>토글 · 삭제 · 수정"]
    TP3 --> TP2
    TP2 -.->|"재발행해도 상태는 그대로"| TP2

    %% 알림톡 심사는 화면이 둘이고 잠금 규칙이 서로 다르다 — 한 덩어리로 그리면 거짓말이 된다
    AK0(["알림톡 심사"]) --> AK1["초안 · draft"]
    AK1 -->|"심사 요청"| AK2["검수중 · inspecting"]
    AK2 --> AKR{"카카오 심사"}
    AKR -->|"승인"| AK3["승인 · approved<br/>isAlimtalkSendable = approved 만"]
    AKR -->|"반려"| AK4["반려 · rejected · 반려 사유 확인"] --> AK1
    AK3 --> AKWhich{"어느 화면에서 여는가"}

    AKWhich -->|"신규 편집기<br/>message-templates/AlimtalkTemplateEditor"| N1{"alimtalkLockReasonOf<br/>상태 + hasBeenSent 를 함께 본다"}
    N1 -->|"sent · 한 번이라도 발송됨"| N2["영구 잠금<br/>승인 취소해도 안 풀린다 · 복제 후 재심사만"]
    N1 -->|"review · 검수중"| N3["잠금 · 심사 끝나면 해제"]
    N1 -->|"approved · 미발송"| N4["잠금 · 승인 취소하면 되돌릴 수 있다"]

    AKWhich -->|"레거시 화면<br/>/marketing/templates/alimtalk"| L1{"isTemplateContentLocked<br/>승인 상태만 본다 · 2갈래"}
    L1 -->|"approved 또는 inspecting"| L2["잠금"]
    L1 -->|"draft 또는 rejected"| L3["수정 가능"]

    AK3 --> AKName["템플릿명은 심사 대상이 아니라 잠기지 않는다"]

    classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    class Ch,Save,Act,AKR,AKWhich,N1,L1 gate
    class D5,Lock,NoEdit,AK4,N2,N3,N4,L2 err
    class D4,TP2,AK3 ok
