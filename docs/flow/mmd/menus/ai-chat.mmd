%% 새 채팅 · /ai/chat
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /ai/chat"]) --> URL["useSearchParams<br/>c = 열어 둔 대화 id (IA-13)<br/>q = 레일 검색어 (replace)<br/>※ 대화는 라우트가 아니라 쿼리스트링이다"]
  URL --> LOCAL["로컬 상태<br/>draft(입력값) · modeId(DEFAULT_MODE_ID='rules')<br/>pending(방금 보낸 질문) · gone"]
  LOCAL --> Q1["useConversationsQuery() — 레일 기록<br/>useConversationQuery(c) — 열린 대화"]

  Q1 --> ST{"대화 조회 상태"}
  ST -->|"c!==null && isFetching && data===undefined"| L1["'대화를 불러오는 중…' aria-busy<br/>빈 상태를 번쩍이지 않는다 (STATE-01)"]
  ST -->|"c!==null && isSuccess && data===null"| GONE["warning 배너<br/>'이 대화는 삭제되었습니다'<br/>+ '새 채팅 시작' 버튼"]
  ST -->|"messages.length===0 && pending===null"| EMP["빈 상태 '무엇을 조회할까요?'<br/>@ 사용법 안내 + STARTER_FOLLOW_UPS"]
  ST -->|"성공"| OK1["메시지 목록<br/>user 버블 / agent AnswerView<br/>'N초 동안 조회함'(실측 elapsedMs)"]

  L1 --> OK1
  EMP --> COMP
  OK1 --> COMP["Composer — 입력줄"]

  COMP ~~~ SUB1

  subgraph SUB1["입력 · 멘션 · 모드"]
    C1["@ 입력 → mentionSuggestions() 필터<br/>combobox 로 후보 표시"] --> C2["Enter/Tab 으로 후보 확정<br/>입력값을 @alias 로 치환"]
    C3["ModePicker — rules(규칙 기반 조회) 기본<br/>fast · expert · heavy 는 aria-disabled<br/>+ aria-describedby 로 잠금 사유"]
    C4["Enter(shift 없음)=보내기<br/>단 isComposing 이면 무시 — 한글 조합 확정키 (COMP-10)<br/>+ 명시 보내기 버튼(입력 비었거나 조회 중이면 native disabled)"]
  end

  SUB1 ~~~ SUB2

  subgraph SUB2["send(question) — 유일한 쓰기 경로"]
    D1{"text.trim() === '' ?"} -->|"예"| D2["아무것도 하지 않음"]
    D1 -->|"아니오"| D3["이전 요청 abort<br/>새 AbortController<br/>setPending(text) · draft 비움 · gone=false"]
    D3 --> D4["useAskAgent.mutate({c, question, signal})<br/>parseQuery → 픽스처 실조회<br/>답을 짓는 언어 모델 없음 (FEEDBACK-03)"]
    D4 --> D5{"결과"}
    D5 -->|"isAbort"| D6["조용히 무시 — 취소는 실패가 아니다"]
    D5 -->|"ConversationGoneError"| D7["gone=true → 삭제 배너"]
    D5 -->|"기타 오류"| D8["errorAnswer 메시지 한 건으로 남김<br/>'조회하지 못했습니다'<br/>※ 대화는 죽지 않는다"]
    D5 -->|"성공"| D9["pending 해제 · 답변 메시지 추가<br/>c===null 이었으면 URL 에 ?c=새 id 붙임(push)"]
  end

  COMP --> D1
  D9 --> OK1
  D8 --> OK1
  D7 --> GONE
  GONE --> NEW["startNew(): abort · pending/gone 초기화<br/>URL 에서 c 삭제"]
  NEW --> EMP

  OK1 --> FU["후속 질문(↳) 클릭 → send(followUp.query)"]
  FU --> D1
  Q1 --> RAIL{"레일 상태"}
  RAIL -->|"isFetching && data===undefined"| RL["레일 스켈레톤"]
  RAIL -->|"isError"| RE["레일 failed 표시"]
  RAIL -->|"성공"| ROK["오늘/이전 기록 · 검색어(q)로 좁힘<br/>항목 클릭 → ?c= 교체"]
  ROK --> Q1
  ROK --> LIST["'대화 목록' 메뉴로 이동 시 /ai/conversations"]

  A11Y["role=status aria-live=polite<br/>'조회 중입니다' / '응답이 도착했습니다'<br/>목록 바깥에 둔다"] --- OK1

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,D1,D5,RAIL gate
  class GONE,D7,D8,RE err
  class OK1,D9,ROK ok
