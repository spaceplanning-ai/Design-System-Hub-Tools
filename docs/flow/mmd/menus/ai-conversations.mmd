%% 대화 목록 · /ai/conversations
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /ai/conversations"]) --> Q["useConversationsQuery()<br/>로컬 상태: confirming(삭제 대상 id) 뿐<br/>※ 필터·정렬·페이지 없음 — URL 파라미터를 쓰지 않는다"]
  Q --> NOTE["상시 info 배너<br/>'대화는 브라우저 메모리에만 있습니다 —<br/>새로고침하면 사라집니다. 보관은 백엔드 연동 후 가능'"]
  NOTE --> ST{"조회 상태"}

  ST -->|"isError"| E1["인라인 danger 배너<br/>'대화 목록을 불러오지 못했습니다'"]
  ST -->|"isFetching && data===undefined"| L1["'불러오는 중…' (STATE-01)"]
  ST -->|"items.length===0"| EMP["Empty label='대화' createVerb='시작'<br/>+ '새 채팅 시작' → /ai/chat"]
  ST -->|"성공"| OK1["Card + 목록<br/>제목 · 'N개 메시지' · 갱신 시각"]

  L1 --> OK1
  OK1 --> ACT["행 액션"]
  ACT --> A1["제목 링크 → /ai/chat?c=(id)<br/>대화는 라우트가 아니라 쿼리스트링으로 열린다"]
  ACT --> A2["삭제 버튼 → setConfirming(id)"]
  OK1 --> A3["헤더 '새 채팅' 버튼 → /ai/chat"]

  A2 --> C1["ConfirmDialog intent='delete'<br/>'대화를 삭제할까요?'<br/>'삭제한 대화는 되돌릴 수 없습니다'<br/>※ open 프롭 없음 — 존재 = 열림"]
  C1 --> C2{"확인 / 취소"}
  C2 -->|"취소"| CX["setConfirming(null)"]
  CX --> OK1
  C2 -->|"확인"| M1["이전 요청 abort → 새 AbortController<br/>useDeleteConversations.mutate({ids:[id], signal})<br/>busy=remove.isPending"]

  M1 --> MR{"결과"}
  MR -->|"isAbort"| MX["조용히 무시 — 취소는 실패가 아니다"]
  MR -->|"실패"| MERR["confirming 해제 + 실패 토스트<br/>'대화를 삭제하지 못했습니다'<br/>+ retry: confirmDelete (자동으로 사라지지 않음)"]
  MR -->|"성공"| MOK["confirming 해제 + 성공 토스트<br/>'대화를 삭제했습니다'<br/>목록 무효화 → 재조회"]

  MERR --> M1
  MX --> OK1
  MOK --> Q
  A1 --> CHAT(["/ai/chat?c= 로 이동"])
  A3 --> CHAT
  EMP --> CHAT

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,C2,MR gate
  class E1,MERR err
  class OK1,MOK ok
