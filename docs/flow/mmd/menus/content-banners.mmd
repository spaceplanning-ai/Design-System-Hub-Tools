flowchart TD
  S(["진입 · /content/banners"]) --> URL["useListState<br/>조회 상태는 URL 쿼리스트링이 소유 (IA-13)<br/>placement · keyword · page"]
  URL --> Q["useBannersQuery<br/>fetchBanners(query, signal)"]
  Q --> ST{"목록 조회 상태"}
  ST -->|"isPending"| LOAD["스켈레톤 표<br/>placeholderData 로 이전 목록 유지"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너 + 다시 시도"]
  ST -->|"total = 0"| EMPTY["빈 상태 안내"]
  ST -->|"성공"| LIST["BannersTable<br/>order 오름차순 · 위치(main/sub)<br/>노출 기간 · ON/OFF ToggleSwitch"]
  ERRL -->|"재시도"| Q

  LIST --> F{"조회 조건 변경"}
  F -->|"PLACEMENT_FILTERS · all/main/sub"| SETQ
  F -->|"제목 검색 · 디바운스"| SETQ
  F -->|"페이지 이동 · PAGE_SIZE 10"| SETQ
  SETQ["URL 쿼리 갱신 · 기본값(all)은 URL 에서 제거<br/>조건 변경 시 page=1 · 선택 해제"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"등록 / 수정"| FORMENTRY
  ACT -->|"ON/OFF 토글"| TG
  ACT -->|"드래그·키보드 재정렬"| RO0
  ACT -->|"삭제 · 일괄"| DELG

  %% ── ON/OFF 인라인 토글 ──
  TG["useSetBannerEnabled<br/>PATCH /api/banners/:id/enabled"] --> TR{"토글 결과"}
  TR -->|"성공"| TOK["토스트 '~을 켰습니다/껐습니다'"]
  TR -->|"실패 · ?fail=save"| TERR["롤백 + 토스트 (재시도 버튼)"]
  TOK --> Q
  TERR --> LIST

  %% ── 재정렬 ──
  RO0{"reorderable ?<br/>placement=all && keyword 빈값"} -->|"아니오"| ROOFF["재정렬 핸들 비활성<br/>필터/검색 해제 필요"]
  RO0 -->|"예"| RO["useReorderBanners<br/>reorderByIds 로 order 1..n 재부여"]
  RO --> RR{"재정렬 결과"}
  RR -->|"성공"| ROK["토스트 '정렬 순서를 변경했습니다'"]
  RR -->|"실패"| RERR["스냅샷 롤백 + 토스트 (재시도)"]
  ROK --> Q
  RERR --> LIST
  ROOFF --> LIST

  %% ── 등록 · 수정 폼 (좌 입력 / 우 실시간 미리보기) ──
  FORMENTRY{"진입 경로"} -->|"등록"| NEW["/content/banners/new<br/>fetchNextBannerOrder 로 정렬 순서 자동 채움"]
  FORMENTRY -->|"수정"| EDIT["/content/banners/:id/edit<br/>fetchBanner(id)"]
  NEW --> FORM
  EDIT --> FORM
  FORM["BannerFormPage 2단 레이아웃<br/>좌: 제목·ImageUploadField·링크·위치<br/>DateRangeField·ON/OFF·정렬 순서"] --> PV["우: BannerPreview<br/>watch() 값으로 실시간 렌더"]
  PV --> V{"zodResolver(bannerSchema)"}
  V -->|"제목 공백 · TITLE_MAX_LENGTH 100 초과"| VE
  V -->|"imageUrl 빈값 → '이미지를 등록하세요'<br/>linkUrl 이 http(s) 형식 아님"| VE
  V -->|"startAt/endAt 이 YYYY-MM-DD 아님<br/>또는 endAt < startAt"| VE
  V -->|"통과"| MUT["createBanner / updateBanner<br/>saving = isPending · 버튼 잠금"]
  VE["필드 인라인 에러 (첫 이슈만) · 제출 차단"] --> FORM
  MUT --> MR{"저장 결과"}
  MR -->|"성공"| OKS["토스트 성공 + 목록 무효화"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너<br/>재제출 = 재시도"]
  ERRS --> FORM
  OKS --> BACK["navigate('/content/banners', replace: true)"]
  BACK --> Q

  %% ── 삭제 ──
  DELG{"삭제 범위"} -->|"행 삭제"| DEL1["ConfirmDialog '배너 삭제'<br/>되돌릴 수 없음 안내"]
  DELG -->|"선택 → SelectionBar"| BULK0["ConfirmDialog '배너 일괄 삭제'<br/>선택 n건"]
  DEL1 --> DC{"확인 / 취소"}
  DC -->|"취소"| LIST
  DC -->|"확인"| DMUT["useDeleteBanner · AbortController"]
  DMUT --> DR{"삭제 결과"}
  DR -->|"성공"| DOK["토스트 '배너를 삭제했습니다'<br/>invalidate lists"]
  DR -->|"실패 · ?fail=delete"| DERR["다이얼로그 안 Alert 배너<br/>재클릭 = 재시도"]
  DERR --> DC
  DOK --> Q

  BULK0 --> BC{"확인 / 취소"}
  BC -->|"취소"| LIST
  BC -->|"확인"| BMUT["settleAll(ids, deleteBanner)<br/>또는 일괄 ON/OFF 처리"]
  BMUT --> BR{"실패 건수 failed"}
  BR -->|"failed = 0"| BOK["전건 성공 토스트 · invalidate lists"]
  BR -->|"failed > 0"| BERR["부분 실패 토스트(건수)"]
  BOK --> Q
  BERR --> LIST

