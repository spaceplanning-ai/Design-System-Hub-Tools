%% FAQ · /content/faq
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/faq"]) --> URL["useListState<br/>조회 상태는 URL 쿼리스트링이 소유 (IA-13)<br/>category · visibility · keyword · page"]
  URL --> Q["useFaqsQuery + useFaqCategoriesQuery<br/>fetchFaqs(query, signal)"]
  Q --> ST{"목록 조회 상태"}
  ST -->|"isPending"| LOAD["스켈레톤 표<br/>placeholderData 로 이전 목록 유지"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너 + 다시 시도"]
  ST -->|"total = 0"| EMPTY["빈 상태 안내"]
  ST -->|"성공"| LIST["FaqTable<br/>order 오름차순 · 카테고리 라벨<br/>노출/숨김 ToggleSwitch"]
  ERRL -->|"재시도"| Q

  LIST --> F{"조회 조건 변경"}
  F -->|"카테고리 (CATEGORY_ALL 기본)"| SETQ
  F -->|"노출 VISIBILITY_FILTERS<br/>all/visible/hidden"| SETQ
  F -->|"질문 검색 · 디바운스"| SETQ
  F -->|"페이지 이동 · PAGE_SIZE 10"| SETQ
  SETQ["URL 쿼리 갱신 · 기본값은 URL 에서 제거<br/>조건 변경 시 page=1 · 선택 해제"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"등록 / 상세 / 수정"| CRUD
  ACT -->|"노출 토글 · 드래그 재정렬"| INLINE
  ACT -->|"카테고리 관리 (모달)"| CATM
  ACT -->|"선택 → SelectionBar 일괄"| BULK

  %% ── 인라인 액션 ──
  INLINE{"인라인 조작 종류"} -->|"ToggleSwitch"| TG["useSetFaqVisibility<br/>onMutate 낙관적 반영"]
  INLINE -->|"드래그/키보드 재정렬"| RO0{"reorderable ?<br/>categoryId=all && visibility=all<br/>&& keyword 빈값"}
  RO0 -->|"아니오"| ROOFF["재정렬 핸들 비활성<br/>필터/검색 해제 안내"]
  RO0 -->|"예"| RO["useReorderFaqs<br/>onMutate 로 행 순서 즉시 반영"]
  TG --> TR{"토글 결과"}
  TR -->|"성공"| TOK["토스트 '노출/숨김 처리'<br/>invalidate lists"]
  TR -->|"실패"| TERR["스냅샷 롤백 + 토스트(재시도 버튼)"]
  RO --> RR{"재정렬 결과"}
  RR -->|"성공"| ROK["토스트 '정렬 순서를 변경했습니다'"]
  RR -->|"실패 · ?fail=reorder"| RERR["스냅샷 롤백 + 토스트(재시도)"]
  TOK --> Q
  ROK --> Q
  TERR --> LIST
  RERR --> LIST
  ROOFF --> LIST

  %% ── 카테고리 관리 모달 ──
  CATM["ManageFaqCategoriesModal<br/>useFaqCategoryUsageQuery(enabled)"] --> CATA{"모달 내 작업"}
  CATA -->|"카테고리 등록"| CV{"faqCategorySchema<br/>이름 공백 · 30자 초과"}
  CATA -->|"카테고리 삭제"| CDG{"faqCount > 0 ?"}
  CATA -->|"닫기"| LIST
  CV -->|"불통과"| CVE["모달 인라인 에러"]
  CV -->|"통과"| CC["useCreateFaqCategory"]
  CVE --> CATA
  CDG -->|"사용 중 (1건 이상)"| CBLK["삭제 버튼 잠금<br/>'사용 중인 카테고리는 삭제할 수 없습니다'"]
  CDG -->|"0건"| CD["useDeleteFaqCategory"]
  CC --> CR{"결과 · ?fail=category"}
  CD --> CR
  CR -->|"성공"| COK["토스트 + invalidate<br/>categories · categoryUsage · lists"]
  CR -->|"실패"| CERR["모달 내 배너 · 재시도"]
  COK --> Q
  CERR --> CATA
  CBLK --> CATA

  %% ── 등록 · 상세 · 수정 ──
  CRUD{"경로 분기"} -->|"등록"| NEW["/content/faq/new<br/>useNextFaqOrder 로 order 자동 채움"]
  CRUD -->|"행 클릭"| DETAIL["/content/faq/:id<br/>useFaqQuery"]
  CRUD -->|"수정"| EDIT["/content/faq/:id/edit"]
  CRUD -->|"행 삭제"| DEL1
  DETAIL --> DST{"상세 조회 상태"}
  DST -->|"isPending"| DLOAD["상세 스켈레톤"]
  DST -->|"'FAQ 를 찾을 수 없습니다' · ?fail=detail"| DERR["오류 안내 + 목록으로"]
  DST -->|"성공"| DVIEW["질문 · 답변 · 카테고리 · 노출 배지"]
  DVIEW --> EDIT
  NEW --> FORM
  EDIT --> FORM
  FORM["폼 입력<br/>질문 · 카테고리 · 답변 · 노출 · 정렬 순서"] --> V{"zodResolver(faqSchema)"}
  V -->|"질문 공백 · 200자 초과"| VE
  V -->|"답변 공백 · 5000자 초과"| VE
  V -->|"카테고리 미선택 · order 가 정수 아님"| VE
  V -->|"통과"| MUT["createFaq / updateFaq"]
  VE["필드 인라인 에러 · 제출 차단"] --> FORM
  MUT --> MR{"저장 결과"}
  MR -->|"성공"| OKS["토스트 + invalidate lists · detail"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너"]
  ERRS --> FORM
  OKS --> BACK["navigate(replace: true) 로 복귀"]
  BACK --> Q

  %% ── 삭제 ──
  DEL1["ConfirmDialog 'FAQ 삭제'"] --> DC{"확인 / 취소"}
  DC -->|"취소"| LIST
  DC -->|"확인"| DMUT["useDeleteFaq"]
  DMUT --> DR{"삭제 결과"}
  DR -->|"성공"| DOK["토스트 'FAQ 를 삭제했습니다'<br/>invalidate lists"]
  DR -->|"실패 · ?fail=delete"| DERR2["다이얼로그 안 배너 · 재클릭 재시도"]
  DERR2 --> DC
  DOK --> Q

  %% ── 일괄 ──
  BULK{"일괄 작업 선택"} -->|"노출 / 숨김"| BV["useBulkSetFaqVisibility<br/>settleAll(ids, setFaqVisibility)"]
  BULK -->|"일괄 삭제"| BD0["ConfirmDialog 'FAQ 일괄 삭제'"]
  BD0 --> BC{"확인 / 취소"}
  BC -->|"취소"| LIST
  BC -->|"확인"| BD["useBulkDeleteFaqs<br/>settleAll(ids, deleteFaq)"]
  BV --> BR{"실패 건수 failed"}
  BD --> BR
  BR -->|"failed = 0"| BOK["전건 성공 토스트 · invalidate lists"]
  BR -->|"failed > 0"| BERR["부분 실패 토스트(건수)"]
  BOK --> Q
  BERR --> LIST

