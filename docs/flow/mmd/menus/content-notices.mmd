%% 공지사항 · /content/notices
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/notices"]) --> URL["useListState<br/>조회 상태는 URL 쿼리스트링이 소유 (IA-13)<br/>category · status · keyword · page"]
  URL --> Q["useNoticesQuery<br/>fetchNotices(query, signal)"]
  Q --> ST{"목록 조회 상태"}
  ST -->|"isPending"| LOAD["스켈레톤 표<br/>placeholderData 로 이전 목록 유지"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너<br/>다시 시도 버튼"]
  ST -->|"total = 0"| EMPTY["빈 상태 안내<br/>조건에 맞는 공지 없음"]
  ST -->|"성공"| LIST["NoticesTable<br/>pinned 우선 → publishedAtIso 최신순<br/>published/draft/scheduled StatusBadge · 조회수"]
  ERRL -->|"재시도"| Q

  LIST --> F{"조회 조건 변경"}
  F -->|"분류 CATEGORY_FILTERS<br/>notice/event/maintenance"| SETQ
  F -->|"상태 STATUS_FILTERS<br/>published/draft/scheduled"| SETQ
  F -->|"제목 검색 · 디바운스"| SETQ
  F -->|"페이지 이동 · PAGE_SIZE 10"| SETQ
  SETQ["URL 쿼리 갱신<br/>기본값(all)은 URL 에서 제거<br/>조건 변경 시 page=1 · 선택 해제"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"등록"| NEW["/content/notices/new<br/>NoticeFormPage"]
  ACT -->|"행 클릭"| DETAIL
  ACT -->|"행 삭제"| DEL1
  ACT -->|"체크박스 → SelectionBar"| BULK

  %% ── 상세 ──
  DETAIL["/content/notices/:id<br/>useNoticeQuery"] --> DST{"상세 조회 상태"}
  DST -->|"isPending"| DLOAD["상세 스켈레톤"]
  DST -->|"'공지를 찾을 수 없습니다'<br/>· ?fail=detail"| DERR["오류 안내 + 목록으로 돌아가기"]
  DST -->|"성공"| DVIEW["제목 · 본문 · 작성자 · 게시일<br/>pinned 이면 '고정' 배지(tone=warning)"]
  DVIEW --> DACT{"상세 액션"}
  DACT -->|"수정"| EDIT["/content/notices/:id/edit"]
  DACT -->|"삭제"| DEL1
  DACT -->|"목록"| BACK

  %% ── 등록 · 수정 폼 ──
  NEW --> FORM
  EDIT --> FORM
  FORM["폼 입력<br/>제목 · 분류 · 상태 · 상단고정 · 게시일 · 본문"] --> V{"zodResolver(noticeSchema)"}
  V -->|"제목 공백 · TITLE_MAX_LENGTH 100 초과"| VE
  V -->|"본문 공백 · BODY_MAX_LENGTH 5000 초과"| VE
  V -->|"status=scheduled 인데 게시일이<br/>YYYY-MM-DD 아님 또는 과거"| VE
  V -->|"통과"| MUT["createNotice / updateNotice<br/>saving = isPending · 버튼 잠금"]
  VE["필드 인라인 에러 (첫 이슈만)<br/>제출 차단"] --> FORM
  MUT --> MR{"mutation 결과"}
  MR -->|"성공"| OKS["토스트 성공<br/>invalidateQueries lists · detail"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너<br/>재제출 = 재시도"]
  ERRS --> FORM
  OKS --> BACK["복귀 · navigate(replace: true)<br/>수정→상세 / 등록→목록"]
  BACK --> Q

  %% ── 단건 삭제 ──
  DEL1["ConfirmDialog '공지 삭제'<br/>되돌릴 수 없음 안내"] --> DC{"확인 / 취소"}
  DC -->|"취소"| LIST
  DC -->|"확인"| DMUT["useDeleteNotice<br/>AbortController signal"]
  DMUT --> DR{"삭제 결과"}
  DR -->|"성공"| DOK["토스트 '삭제했습니다'<br/>invalidate lists · 상세면 목록으로 replace"]
  DR -->|"실패 · ?fail=delete"| DERR2["다이얼로그 안 Alert 배너<br/>재클릭 = 재시도"]
  DERR2 --> DC
  DOK --> Q

  %% ── 일괄 삭제 ──
  BULK["SelectionBar n건 선택<br/>ConfirmDialog '공지 일괄 삭제'"] --> BC{"확인 / 취소"}
  BC -->|"취소"| LIST
  BC -->|"확인"| BMUT["useBulkDeleteNotices<br/>settleAll(ids, deleteNotice)"]
  BMUT --> BR{"실패 건수 failed"}
  BR -->|"failed = 0"| BOK["전건 성공 토스트<br/>invalidate lists"]
  BR -->|"failed > 0"| BERR["부분 실패 토스트(건수)<br/>목록 무효화하지 않음"]
  BOK --> Q
  BERR --> LIST

