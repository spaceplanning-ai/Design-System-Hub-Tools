%% 개인정보 처리방침 · /content/privacy
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/privacy"]) --> URL["useListState()<br/>조회 상태는 URL 쿼리스트링이 소유 (IA-13)<br/>keyword · 선택 (단일 문서라 종류 선택 없음)"]
  URL --> Q["usePrivacyVersionsQuery<br/>fetchPrivacyVersions(signal)"]
  Q --> ST{"버전 이력 조회 상태"}
  ST -->|"isPending"| LOAD["스켈레톤 표"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너 + 다시 시도"]
  ST -->|"결과 0건"| EMPTY["빈 상태 안내<br/>등록된 버전 없음"]
  ST -->|"성공"| LIST["VersionHistoryTable<br/>sortVersions() 로 정렬<br/>active/scheduled/archived 배지<br/>isCurrent 이면 '현재' 강조"]
  ERRL -->|"재시도"| Q

  LIST --> F{"조회 조건 변경"}
  F -->|"처리방침 버전 검색<br/>(keyword, 클라이언트 필터)"| SETQ
  SETQ["URL 쿼리 갱신 (?keyword=...)<br/>검색어 변경 시 선택 자동 해제"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"새 버전 등록"| NEW["/content/privacy/new"]
  ACT -->|"행 클릭 → 전문 보기"| DETAIL
  ACT -->|"수정"| EDIT["/content/privacy/:id/edit"]
  ACT -->|"삭제 · 일괄 삭제"| DELG

  %% ── 버전 상세 (sub-flow) ──
  DETAIL["/content/privacy/:id<br/>usePrivacyVersionQuery"] --> DST{"상세 조회 상태"}
  DST -->|"isPending"| DLOAD["상세 스켈레톤"]
  DST -->|"'처리방침 버전을 찾을 수 없습니다'<br/>· ?fail=detail"| DERR["오류 안내 + 목록으로 돌아가기"]
  DST -->|"성공"| DVIEW["버전 표기 · 시행일 · 상태 배지<br/>isCurrent 이면 '현재' 배지(tone=info)<br/>본문 전문"]
  DVIEW --> DACT{"상세 액션"}
  DACT -->|"수정"| EDIT
  DACT -->|"삭제"| DEL1
  DACT -->|"목록"| BACK

  %% ── 등록 · 수정 폼 ──
  NEW --> FORM
  EDIT --> FORM
  FORM["PrivacyFormPage · VersionForm<br/>버전 표기 · 시행일 · 상태 · 본문"] --> V{"zodResolver(privacyVersionSchema)"}
  V -->|"version 공백 · VERSION_MAX_LENGTH 20 초과"| VE
  V -->|"effectiveDate 공백 또는<br/>YYYY-MM-DD 아님"| VE
  V -->|"body 공백 · BODY_MAX_LENGTH 20000 초과"| VE
  V -->|"통과 (status: active/scheduled/archived)"| MUT["createPrivacyVersion / updatePrivacyVersion"]
  VE["필드 인라인 에러 (첫 이슈만) · 제출 차단"] --> FORM
  MUT --> MR{"저장 결과"}
  MR -->|"성공"| OKS["토스트 성공<br/>invalidate 버전 목록 · 상세"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너<br/>재제출 = 재시도"]
  ERRS --> FORM
  OKS --> BACK["navigate('/content/privacy', replace: true)"]
  BACK --> Q

  %% ── 삭제 ──
  DELG{"삭제 범위"} -->|"행 삭제"| DEL1["ConfirmDialog '처리방침 버전 삭제'"]
  DELG -->|"선택 → SelectionBar"| BULK0["ConfirmDialog '처리방침 버전 일괄 삭제'<br/>선택 n건"]
  DEL1 --> DC{"확인 / 취소"}
  DC -->|"취소"| LIST
  DC -->|"확인"| DMUT["useDeletePrivacyVersion<br/>AbortController signal"]
  DMUT --> DR{"삭제 결과"}
  DR -->|"성공"| DOK["토스트 '~ 버전을 삭제했습니다'<br/>상세면 목록으로 replace"]
  DR -->|"실패 · ?fail=delete"| DERR2["다이얼로그 안 Alert 배너<br/>재클릭 = 재시도"]
  DERR2 --> DC
  DOK --> Q

  BULK0 --> BC{"확인 / 취소"}
  BC -->|"취소"| LIST
  BC -->|"확인"| BMUT["settleAll(ids, deletePrivacyVersion)"]
  BMUT --> BR{"실패 건수 failed"}
  BR -->|"failed = 0"| BOK["'버전 n건을 삭제했습니다' 토스트<br/>목록 무효화"]
  BR -->|"failed > 0"| BERR["부분 실패 토스트(건수)"]
  BOK --> Q
  BERR --> LIST

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
  class ST,F,ACT,DST,DACT,V,MR,DELG,DC,DR,BC,BR gate
  class ERRL,DERR,VE,ERRS,DERR2,BERR err
  class OKS,DOK,BOK ok
