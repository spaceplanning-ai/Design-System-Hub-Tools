%% 관리자 로그 · /logs/admin
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /logs/admin"]) --> PERM["read 게이팅은 AppShell 이 한다<br/>&lt;Outlet&gt; 을 RequirePermission 으로 감싼다<br/>셸은 useRouteCan('export') 만 본다 (EXC-03)"]
  PERM --> URL["useLogListState — 조회 상태의 단일 원천은 URL (IA-13)<br/>period·from·to·q·page·size·sort·dir<br/>+ 축 outcome·action<br/>필터/기간/정렬/페이지=push · 검색어=replace"]

  URL --> RANGE{"useResolvedRange<br/>period==='custom' ? validateCustomRange : presetRange"}
  RANGE -->|"range === null (입력 오류)"| RERR["입력 칸 옆 인라인 오류(zod, validation.ts)<br/>요약줄 '조회 기간을 확인해 주세요.'<br/>enabled:false — 조회 자체를 걸지 않는다<br/>빈 표를 보이면 '기록이 지워졌다'고 의심한다"]
  RANGE -->|"정상"| Q["useLogQuery('logs-admin', query, fetchAdminLogs)<br/>query = range·axes·keyword·sort·page·pageSize"]

  Q --> ST{"조회 상태"}
  ST -->|"error !== null"| E1["인라인 danger Alert<br/>'관리자 로그를 불러오지 못했습니다' + 다시 시도<br/>토스트 아님 — 비어 있는 것과 못 불러온 것을<br/>감사에서 헷갈리는 것은 치명적 (STATE-02)"]
  ST -->|"loading && data===undefined"| L1["LogTable 스켈레톤 pageSize 행"]
  ST -->|"성공 · 0건"| EMP["빈 상태 3분기 (STATE-05)<br/>hasQuery → 검색어 지우기 / hasActiveFilters → 필터 초기화 / 순수 0건"]
  ST -->|"성공"| OK1["요약 '전체 N건 중 a–b'(rangeTextOf)<br/>+ highlightOf 경고: 권한 변경 N건 → 실패 N건<br/>+ LogTable"]
  E1 --> Q
  L1 --> OK1
  EMP --> FILT

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    A["좌측 축 2개 — 결과(전체·성공·실패) · 액션(ADMIN_ACTION_LABEL 전체)"]
    C["컬럼 — 시각·행위자·액션·대상·결과·IP"]
    R["보존기간 3년<br/>'내부 통제·감사 대응 기록. 지나면 자동 폐기'<br/>4화면 중 가장 길다"]
    H["검색 — 행위자 · 대상 · IP"]
  end

  OK1 --> FILT["조회 조건 변경 → URL 직렬화"]
  FILT --> F1["LogFilterPanel setAxis(outcome/action)<br/>ALL 이면 파라미터 삭제 · page 되돌림"]
  FILT --> F2["setPeriod / setDraft<br/>프리셋 복귀 시 from·to 삭제 (기본 last-30d)"]
  FILT --> F3["LogToolbar 검색(useDebouncedSearch, COMP-10)<br/>값이 실제로 바뀔 때만 커밋 · replace"]
  FILT --> F4["setPageSize(기본 20) · setPage · toggleSort<br/>시각 컬럼은 desc 기본, 나머지는 asc (ERP-04)<br/>총 페이지가 줄면 마지막 페이지로 보정 (STATE-04)"]
  F1 --> Q
  F2 --> Q
  F3 --> Q
  F4 --> Q

  OK1 --> ROW["행 클릭 → setDetailEntry"]
  ROW --> DLG["LogPayloadDialog — 라우트가 아니다 (IA-06/IA-11)<br/>목록의 맥락을 잃지 않고 읽는다<br/>페이로드는 formatMaskedPayload 만 거친다<br/>키는 남기고 값만 가림(비밀번호·토큰·카드번호)"]
  DLG --> DC{"닫기 / Esc / 딤 클릭 / ×"}
  DC -->|"닫힘"| OK1
  DLG --> RO["푸터에 '닫기' 하나뿐 — 저장·삭제 없음<br/>dirty 해질 입력이 없어 이탈 가드 대상도 아니다"]

  OK1 --> EXP["내보내기 — export 권한 없으면 버튼 부재"]
  EXP --> EX1["useLogExport(fetchAdminLogsForExport)<br/>현재 페이지가 아니라 필터 전체 (ERP-12)"]
  EX1 --> EXR{"결과"}
  EXR -->|"취소(abort)"| EXC["아무 토스트도 없음 — 취소는 실패가 아니다 (EXC-09)"]
  EXR -->|"실패"| EXE["실패 토스트 + 다시 시도"]
  EXR -->|"성공"| EXO["admin-log-(KST 날짜).csv 다운로드<br/>성공 토스트 'N건 (현재 필터 조건 전체)'"]
  EXE --> EX1
  EXC --> OK1
  EXO --> OK1

  OK1 --> IMM["쓰기 라우트가 존재하지 않는다 (App.tsx)<br/>감사 기록은 불변 — 수정·삭제 경로 없음"]

