%% API 로그 · /logs/api
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /logs/api"]) --> PERM["read 게이팅은 AppShell 의 RequirePermission<br/>셸은 useRouteCan('export') 만 본다 (EXC-03)"]
  PERM --> URL["useLogListState — 조회 상태의 단일 원천은 URL (IA-13)<br/>period·from·to·q·page·size·sort·dir<br/>+ 축 status·method<br/>필터/기간/정렬/페이지=push · 검색어=replace"]

  URL --> RANGE{"useResolvedRange<br/>custom 이면 validateCustomRange"}
  RANGE -->|"range === null (입력 오류)"| RERR["입력 칸 옆 인라인 오류(zod)<br/>요약줄 '조회 기간을 확인해 주세요.'<br/>enabled:false — 조회하지 않는다"]
  RANGE -->|"정상"| Q["useLogQuery('logs-api', query, fetchApiLogs)"]

  Q --> ST{"조회 상태"}
  ST -->|"error !== null"| E1["인라인 danger Alert<br/>'API 로그를 불러오지 못했습니다' + 다시 시도 (STATE-02)"]
  ST -->|"loading && data===undefined"| L1["LogTable 스켈레톤 pageSize 행"]
  ST -->|"성공 · 0건"| EMP["빈 상태 3분기 (STATE-05)<br/>검색어 지우기 / 필터 초기화 / 순수 0건"]
  ST -->|"성공"| OK1["요약 '전체 N건 중 a–b'<br/>+ highlightOf 경고: 5xx N건 → 4xx N건<br/>(5xx 는 우리가 깨진 것이라 먼저 말한다)<br/>+ LogTable"]
  E1 --> Q
  L1 --> OK1
  EMP --> FILT

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    A["좌측 축 2개 — 상태(STATUS_CLASS_LABEL: 2xx·4xx·5xx …) · 메서드(HTTP_METHODS)"]
    C["컬럼 — 시각·메서드·경로·상태·응답시간(ms)·클라이언트<br/>SLOW_THRESHOLD_MS=1000 초과는 느린 호출로 톤 처리"]
    R["보존기간 90일 — 4화면 중 가장 짧다<br/>'트래픽 부피가 커 단기 보존합니다'"]
    H["검색 — 경로 · 클라이언트 · 요청 ID"]
  end

  OK1 --> FILT["조회 조건 변경 → URL 직렬화"]
  FILT --> F1["setAxis(status/method) — ALL 이면 삭제 · page 되돌림"]
  FILT --> F2["setPeriod / setDraft (기본 last-30d)"]
  FILT --> F3["검색(useDebouncedSearch, COMP-10) — 실제 변경 시에만 커밋"]
  FILT --> F4["setPageSize(기본 20) · setPage · toggleSort (ERP-04)<br/>총 페이지가 줄면 마지막 페이지로 보정 (STATE-04)<br/>컬럼 8개 초과 시 카드 안에서 가로 스크롤 (IA-14·ERP-15)"]
  F1 --> Q
  F2 --> Q
  F3 --> Q
  F4 --> Q

  OK1 --> ROW["행 클릭 → setDetailEntry"]
  ROW --> DLG["LogPayloadDialog — 라우트가 아니다 (IA-06/IA-11)<br/>시각·메서드·경로·상태·응답시간·클라이언트<br/>API 키는 maskTail 로 꼬리만 · 요청 ID·클라이언트 IP·로그 ID<br/>요청/응답 본문은 formatMaskedPayload 만 거친다"]
  DLG --> DC{"닫기 / Esc / 딤 클릭 / ×"}
  DC -->|"닫힘"| OK1
  DLG --> RO["푸터에 '닫기' 하나뿐 — 저장·삭제 없음<br/>재요청·리플레이 같은 쓰기 액션도 없다"]

  OK1 --> EXP["내보내기 — export 권한 없으면 버튼 부재"]
  EXP --> EX1["useLogExport(fetchApiLogsForExport)<br/>현재 페이지가 아니라 필터 전체 (ERP-12)"]
  EX1 --> EXR{"결과"}
  EXR -->|"취소(abort)"| EXC["아무 토스트도 없음 (EXC-09)"]
  EXR -->|"실패"| EXE["실패 토스트 + 다시 시도"]
  EXR -->|"성공"| EXO["api-log-(KST 날짜).csv<br/>성공 토스트 'N건 (현재 필터 조건 전체)'"]
  EXE --> EX1
  EXC --> OK1
  EXO --> OK1

  OK1 --> IMM["쓰기 라우트가 존재하지 않는다 (App.tsx)<br/>감사 기록은 불변 — 수정·삭제 경로 없음"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class RANGE,ST,DC,EXR gate
  class RERR,E1,EXE err
  class OK1,EXO ok
