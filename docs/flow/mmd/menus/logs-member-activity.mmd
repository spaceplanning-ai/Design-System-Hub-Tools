%% 회원 활동 로그 · /logs/member-activity
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /logs/member-activity"]) --> PERM["read 게이팅은 AppShell 의 RequirePermission<br/>셸은 useRouteCan('export') 만 본다 (EXC-03)"]
  PERM --> URL["useLogListState — 조회 상태의 단일 원천은 URL (IA-13)<br/>period·from·to·q·page·size·sort·dir<br/>+ 축 outcome·activity<br/>필터/기간/정렬/페이지=push · 검색어=replace"]

  URL --> RANGE{"useResolvedRange<br/>custom 이면 validateCustomRange"}
  RANGE -->|"range === null (입력 오류)"| RERR["입력 칸 옆 인라인 오류(zod)<br/>요약줄 '조회 기간을 확인해 주세요.'<br/>enabled:false — 조회하지 않는다"]
  RANGE -->|"정상"| Q["useLogQuery('logs-member', query, fetchMemberActivityLogs)"]

  Q --> ST{"조회 상태"}
  ST -->|"error !== null"| E1["인라인 danger Alert<br/>'회원 활동 로그를 불러오지 못했습니다' + 다시 시도 (STATE-02)"]
  ST -->|"loading && data===undefined"| L1["LogTable 스켈레톤 pageSize 행"]
  ST -->|"성공 · 0건"| EMP["빈 상태 3분기 (STATE-05)<br/>검색어 지우기 / 필터 초기화 / 순수 0건"]
  ST -->|"성공"| OK1["요약 '전체 N건 중 a–b'<br/>+ highlightOf 경고: 탈퇴 N건 → 실패 N건<br/>(탈퇴는 되돌릴 수 없는 사건이라 실패보다 앞선다)<br/>+ LogTable"]
  E1 --> Q
  L1 --> OK1
  EMP --> FILT

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    A["좌측 축 2개 — 결과(전체·성공·실패) · 활동(MEMBER_ACTIVITY_LABEL 전체)"]
    C["컬럼 — 시각·회원·활동·내용·결과·접속<br/>회원 셀은 계정 링크(탈퇴 회원이면 memberId=null)"]
    R["보존기간 1년<br/>'개인정보 최소 보관 원칙'<br/>관리자 로그(3년)보다 짧다 — 남의 개인정보이기 때문"]
    H["검색 — 회원 · 내용 · IP"]
  end

  OK1 --> FILT["조회 조건 변경 → URL 직렬화"]
  FILT --> F1["setAxis(outcome/activity) — ALL 이면 삭제 · page 되돌림"]
  FILT --> F2["setPeriod / setDraft (기본 last-30d)"]
  FILT --> F3["검색(useDebouncedSearch, COMP-10) — 실제 변경 시에만 커밋"]
  FILT --> F4["setPageSize(기본 20) · setPage · toggleSort (ERP-04)<br/>총 페이지가 줄면 마지막 페이지로 보정 (STATE-04)"]
  F1 --> Q
  F2 --> Q
  F3 --> Q
  F4 --> Q

  OK1 --> ROW["행 클릭 → setDetailEntry<br/>계정 클릭 → 회원 상세로 이동(별도 라우트)"]
  ROW --> DLG["LogPayloadDialog — 라우트가 아니다 (IA-06/IA-11)<br/>시각·회원·회원 상태·활동·내용·결과·IP·기기·로그 ID<br/>페이로드는 formatMaskedPayload 만 거친다<br/>주문 페이로드의 배송지·결제수단이 여기 있다"]
  DLG --> DC{"닫기 / Esc / 딤 클릭 / ×"}
  DC -->|"닫힘"| OK1
  DLG --> RO["푸터에 '닫기' 하나뿐 — 저장·삭제 없음"]

  OK1 --> EXP["내보내기 — export 권한 없으면 버튼 부재"]
  EXP --> EX1["useLogExport(fetchMemberActivityLogsForExport)<br/>현재 페이지가 아니라 필터 전체 (ERP-12)"]
  EX1 --> EXR{"결과"}
  EXR -->|"취소(abort)"| EXC["아무 토스트도 없음 (EXC-09)"]
  EXR -->|"실패"| EXE["실패 토스트 + 다시 시도"]
  EXR -->|"성공"| EXO["member-activity-log-(KST 날짜).csv<br/>성공 토스트 'N건 (현재 필터 조건 전체)'"]
  EXE --> EX1
  EXC --> OK1
  EXO --> OK1

  OK1 --> IMM["쓰기 라우트가 존재하지 않는다 (App.tsx)<br/>감사 기록은 불변 — 수정·삭제 경로 없음"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class RANGE,ST,DC,EXR gate
  class RERR,E1,EXE err
  class OK1,EXO ok
