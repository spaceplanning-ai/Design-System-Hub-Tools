    A10["브랜드 발송 가능 시간<br/>08:00 ~ 20:50"]
    A2 --> A9
    A6 --> A9
  end
  S4 --> A1
  S4 --> A5

  S4 --> SUBMIT{"저장 제출"}
  A9 --> SUBMIT
  A10 --> SUBMIT
