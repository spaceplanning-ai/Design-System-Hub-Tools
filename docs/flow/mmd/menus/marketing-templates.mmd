  LOAD -->|"정상"| ROWS["템플릿명·종류 배지<br/>상태 배지(초안/사용중/미사용)"]
  SKEL --> LOAD
  ERRL --> LOAD

  subgraph SUB1["조회 조건 · IA-13 URL 소유"]
    Q1["useListState<br/>?status=&kind=&q="]
    Q2["parseFilter status<br/>all·draft·active·inactive"]
    Q3["parseFilter kind<br/>문자·이메일·알림톡·브랜드메시지"]
    Q4["모르는 값 → 'all' · IME 안전 검색"]
    Q1 --> Q2 --> Q4
    Q1 --> Q3
  end
  ROWS --> Q1
  Q4 --> ROWS
  Q3 --> ROWS

  ROWS --> ACT{"목록 액션"}
  ACT -->|"등록"| DLG["NewTemplateKindDialog<br/>종류 선택"]
  ACT -->|"행클릭"| DETAIL["/marketing/templates/:id<br/>상세"]
  ACT -->|"선택 후 삭제"| DEL["삭제 확인 팝업"]

  DLG --> KIND{"TemplateKind 선택"}
  KIND -->|"text 문자"| ED1["TextTemplateEditor<br/>?kind=text"]
  KIND -->|"email 이메일"| ED2["EmailTemplateEditor<br/>블록 빌더 ?kind=email"]
  KIND -->|"alimtalk 카카오 알림톡"| ED3["AlimtalkTemplateEditor"]
  KIND -->|"brandmessage 브랜드 메시지"| ED4["BrandMessageTemplateEditor"]

  subgraph SUB2["편집기 공통 (TemplateEditorShell)"]
    S1["템플릿명 입력 · aria-label A11Y-11"]
    S2["발신 프로필 선택"]
    S3["내용 입력 + 치환변수 #{}"]
    S4["실시간 미리보기"]
    S1 --> S2 --> S3 --> S4
  end
  ED1 --> S1
  ED2 --> S1
  ED3 --> S1
  ED4 --> S1

  subgraph SUB3["알림톡 · 브랜드 분기 규칙"]
    A1{"알림톡 messageType"}
    A1 -->|"extra-info"| A2["부가정보 ≤ 500자"]
