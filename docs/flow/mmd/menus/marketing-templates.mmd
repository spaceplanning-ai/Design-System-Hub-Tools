  DEL --> DRES{"삭제 결과 · canDelete 항상 true"}
  DRES -->|"성공"| OK2["삭제 토스트<br/>목록으로 replace 이동"]
  DRES -->|"실패"| E5["삭제 실패 알림"]
  OK2 --> BACK["목록 복귀 · URL 조건 복원"]
  E5 --> ROWS
  BACK --> END(["종료"])

  SUB1 ~~~ SUB2
  SUB2 ~~~ SUB3
  SUB3 ~~~ SUB4

