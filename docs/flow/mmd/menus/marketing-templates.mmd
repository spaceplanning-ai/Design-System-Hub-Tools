  RES -->|"실패"| E4["서버 오류 알림"]
  E1 --> S1
  E2 --> S3
  E3 --> S3
  E4 --> S1

  subgraph SUB4["발행 상태 전이 · actionsFor"]
    P1["draft 초안<br/>[삭제][수정][발행]"]
    P1 -->|"publishedStatusOf<br/>draft→active 만"| P2["active 사용중<br/>[토글 ON][삭제] · 수정 없음"]
    P2 -->|"toggledStatusOf"| P3["inactive 미사용<br/>[토글 OFF][삭제][수정]"]
    P3 -->|"toggledStatusOf"| P2
    P2 -->|"수정하려면 먼저 끈다"| P3
  end
  OK1 --> DETAIL
