%% 취소/교환/반품 · /orders/claims
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /orders/claims"]) --> URL["useListState({filterDefaults:{kind:'all', status:'all'}})<br/>kind·status·keyword 를 URL 이 소유 (IA-13)<br/>parseFilter × 2 (KIND_FILTER_VALUES / STATUS_FILTER_VALUES)"]
  URL --> Q["useCrudListQuery('claims', claimAdapter)<br/>**CrudReadListShell** — 선택 체크박스도 액션 열도 없다<br/>고객이 접수하고 관리자는 처리만 한다(감사 성격이라 삭제 없음)"]
  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도(refetch)"]
  ST -->|"성공 · 0건"| EMP["Empty createVerb='접수'<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  ST -->|"성공"| OK1["표 · 주문번호·유형·상품·옵션·신청자·사유·접수일·상태·**환불**<br/>sortClaims(접수일 DESC · 동일자는 id)<br/>환불 열이 따로 있는 이유: 클레임 완료 ≠ 환불 완료"]
  E1 --> Q
  L --> OK1

  OK1 --> K["유형 3종 ClaimKind — 셋을 가르는 것은 '출고' 시점이다<br/>cancel 취소(출고 전에 멈춤) · return 반품(나갔다 돌아옴) · exchange 교환(돌아오고 다시 나감)<br/>kindTone: cancel danger / exchange info / return warning"]
  OK1 --> STS["상태 6종 ClaimStatus<br/>requested 접수 · collecting 수거중 · inspecting 검수중<br/>completed 완료 · rejected 반려 · withdrawn 철회<br/>claimFlow(kind): cancel 은 **2단** [requested, completed]<br/>나머지는 4단 — 취소는 물건이 창고에 있어 수거·검수가 없다"]
  OK1 --> RF["refundCellMeta — 교환은 '해당 없음'(neutral)<br/>교환에 '환불 없음' 을 달면 '아직 안 했다' 로 읽혀 할 일처럼 보인다"]
  OK1 --> DET(["행 클릭(rowTarget kind='detail') · DetailCellLink(주문번호)<br/>→ /orders/claims/:id"])

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 · /orders/claims/:id — 클레임 축"]
    DET --> DQ["useCrudItem('claims', claimAdapter, id)<br/>+ variantQuery ['claims','variants',productId]<br/>enabled = claim.kind === 'exchange' 일 때만"]
    DQ --> DERR{"detailQuery.error (EXC-12)"}
    DERR -->|"isNotFound"| DNF["'클레임을 찾을 수 없습니다. 이미 삭제되었을 수 있습니다.'<br/>[목록으로]만"]
    DERR -->|"그 외"| DER["'클레임을 불러오지 못했습니다.' [다시 시도] · [목록으로]"]
    DERR -->|"정상"| VIEW["요청 정보 카드 + Stepper(claimFlow)<br/>status 가 rejected/withdrawn 이면 Stepper 대신<br/>StatusBadge '반려 — 처리 종료' / '철회 — 처리 종료'<br/>주문번호 → orderDetailPath 링크 · 주문 상태 표시"]
    DER --> VIEW

    VIEW --> CW{"cancelWarning = kind==='cancel' 이면 cancelBlock(order)"}
    CW -->|"order === null"| CW1["Alert warning CLAIM_ORDER_UNKNOWN<br/>'연결된 주문을 확인할 수 없어 취소를 진행할 수 없습니다…'<br/>모르면 막는다(fail-closed)"]
    CW -->|"hasLeftWarehouse(order.status)"| CW2["Alert warning CLAIM_CANCEL_SHIPPED<br/>'배송이 시작된 주문은 취소로 처리할 수 없습니다. 반품으로 접수해 주세요.'<br/>판정은 주문 도메인의 hasLeftWarehouse 를 그대로 읽는다"]
    CW -->|"null"| EDIT

    VIEW --> EDIT["처리 상태 SelectField — 선택지 = [현재 상태, ...nextClaimStatuses(claim, order)]<br/>갈 수 없는 상태는 애초에 열지 않는다 · isClaimStatus 타입가드<br/>처리 메모 TextareaField (CLAIM_NOTE_MAX 500)"]
    EDIT --> TB{"transitionBlock = claimTransitionBlock(claim, status, order)<br/>순서에 뜻이 있다 — 앞의 것이 더 근본적인 거절"}
    TB -->|"to === claim.status"| T0["'이미 그 상태입니다.'"]
    TB -->|"isTerminal(현재)"| T1["CLAIM_TRANSITION_TERMINAL<br/>'완료·반려·철회된 클레임은 상태를 바꿀 수 없습니다.'"]
    TB -->|"to === 'withdrawn' — **유일한 역방향**"| T2{"철회 조건<br/>stockAppliedAt !== '' → CLAIM_WITHDRAW_STOCK<br/>'재고가 이미 반영되어 철회할 수 없습니다…'<br/>refund.status !== 'none' → CLAIM_WITHDRAW_REFUND<br/>'환불이 접수되어 철회할 수 없습니다…'"}
    TB -->|"to === 'rejected'"| T3["언제나 통과 — 어느 단계에서나 종료시킬 수 있다"]
    TB -->|"흐름에 없는 단계"| T4["CLAIM_TRANSITION_OFF_FLOW '이 유형에는 없는 처리 단계입니다.'<br/>(취소에 수거중·검수중을 고르는 경우)"]
    TB -->|"flowIndex 역행"| T5["CLAIM_TRANSITION_BACKWARD<br/>'클레임 처리는 되돌릴 수 없습니다. 접수를 취소하려면 철회로 종료하세요.'"]
    TB -->|"kind==='cancel' 이면 cancelBlock(order)"| T6["CW 와 같은 두 사유"]
    TB -->|"null"| BTN

    T0 --> HINT["버튼 옆에 사유를 그대로 쓴다 · 저장 버튼 disabled"]
    T1 --> HINT
    T2 --> HINT
    T4 --> HINT
    T5 --> HINT
    T6 --> HINT
    T3 --> BTN

    EDIT --> XCH{"isExchange — 교환 재발송 · 재고 카드"}
    XCH -->|"variantQuery.error"| XE["'연결된 상품을 찾을 수 없어 교환 옵션을 불러오지 못했습니다.'(404)<br/>또는 '상품 옵션을 불러오지 못했습니다.' + 다시 시도"]
    XCH -->|"applied = isStockApplied(claim)"| XL["StatusBadge '재고 반영 완료'<br/>'재고가 이미 반영되어 교환 옵션을 바꿀 수 없습니다. 재발송 옵션: …'<br/>optionLocked = applied || !canUpdate"]
    XCH -->|"편집 가능"| XF["ExchangeOptionField"]

    XF --> PRE{"pendingIssue = validateStockPlan(...)<br/>단, movesStock({kind,status}) && !applied 일 때만"}
    PRE -->|"'unknown-origin'"| I1["Alert danger '주문된 옵션을 상품에서 찾을 수 없어 재고를 반영할 수 없습니다.'"]
    PRE -->|"'no-option'"| I2["필드 인라인 '교환할 옵션을 선택하세요.'"]
    PRE -->|"'unknown-option'"| I3["'선택한 교환 옵션을 상품에서 찾을 수 없습니다. 옵션을 다시 선택하세요.'"]
    PRE -->|"'insufficient-stock'"| I4["'교환할 옵션의 재고가 부족해 완료 처리할 수 없습니다.'"]
    PRE -->|"null"| BTN["[처리 저장]<br/>disabled = saving || !dirty || pendingIssue !== null || transitionBlock !== null"]
    I1 --> HINT
    I2 --> HINT
    I3 --> HINT
    I4 --> HINT

    BTN --> WILL{"willMoveStock = movesStock({kind,status}) && !applied<br/>movesStock = status==='completed' && kind !== 'cancel'<br/>**취소 클레임은 재고를 안 건드린다** — 복원은 주문 취소가 한다"}
    WILL -->|"false (진행·반려·철회·메모)"| SAVE["saveClaim() 즉시 — 확인 없음"]
    WILL -->|"true"| CS{"ConfirmDialog intent='update'<br/>'교환 재고 반영' / '반품 재고 반영'<br/>'…N개의 재고가 이동합니다. 재고 반영은 되돌릴 수 없으며,<br/>반영 후에는 교환 옵션을 바꿀 수 없습니다.'"}
    CS -->|"취소 (abort)"| EDIT
    CS -->|"[재고 반영]"| SAVE
  end

  subgraph SUB2["환불 축 — 나란한 별개의 축 (RefundSection)"]
    VIEW --> RS{"isRefundable(kind) — **교환은 카드 자체가 없다**<br/>refund.status: none 환불 없음 → requested 환불 접수 → completed 환불 완료"}
    RS --> CALC["refundBreakdown(draft) — 화면은 스스로 빼지 않는다<br/>total = max(0, paidAmount − returnShippingFee − couponClawback)<br/>couponClawback = couponRestored 면 couponDiscount, 아니면 0<br/>(쿠폰을 복원하면 그 할인을 두 번 받게 되므로 환불에서 회수한다)"]
    CALC --> FEE["반품배송비(원) TextField — parseFeeInput 은 원 단위 정수(숫자만) 문자열만 받는다<br/>실패 시 REFUND_FEE_INVALID '반품배송비는 0 이상의 원 단위 숫자로 입력하세요.'<br/>초기값 defaultReturnFee(kind, policyReturnFee()) — cancel 은 언제나 0<br/>정책을 모르면 null → '배송 정책의 반품배송비를 불러오지 못했습니다. 금액을 직접 입력하세요.'<br/>※ 이미 접수된 건은 정책값을 덮어쓰지 않는다(운영자의 판단을 지우지 않는다)"]
    FEE --> RB{"refundTransitionBlock(claim, to)"}
    RB -->|"to === 현재"| R0["'이미 그 환불 상태입니다.'"]
    RB -->|"!isRefundable(kind)"| R1["REFUND_NOT_REFUNDABLE '교환은 환불 대상이 아닙니다.'"]
    RB -->|"이미 completed"| R2["REFUND_TRANSITION_DONE '환불이 완료되어 더 이상 바꿀 수 없습니다.'"]
    RB -->|"역행"| R3["REFUND_TRANSITION_BACKWARD '환불 처리는 되돌릴 수 없습니다.'"]
    RB -->|"클레임이 rejected/withdrawn"| R4["REFUND_CLAIM_CLOSED '반려·철회된 클레임은 환불할 수 없습니다.'"]
    RB -->|"to==='completed' && 클레임 미완료"| R5["REFUND_CLAIM_INCOMPLETE '클레임 처리를 완료해야 환불을 완료할 수 있습니다.'<br/>※ completeBlock 은 **편집 중인 status** 로 판정한다({...claim, status})"]
    RB -->|"pointUsed &gt; 0 && memberId === ''"| R6["REFUND_NO_MEMBER '비회원 주문이라 적립금 원장이 없습니다…<br/>환불을 완료할 수 없습니다.'"]
    RB -->|"null"| RACT["[환불 접수] (disabled = requestBlock !== null)<br/>[환불 완료 처리] (disabled = completeBlock !== null || feeError)<br/>막힌 사유는 버튼 옆에 그대로"]
    R0 --> RHINT["사유를 버튼 옆에 · 완료된 환불은 차감 입력도 잠긴다(locked = disabled || done)"]
    R1 --> RHINT
    R2 --> RHINT
    R3 --> RHINT
    R4 --> RHINT
    R5 --> RHINT
    R6 --> RHINT

    RACT --> RQ["saveRefund('requested') → 즉시 저장 · toast '환불을 접수했습니다.'"]
    RACT --> RC{"ConfirmDialog '환불 완료 처리'<br/>'N원을 환불 완료로 기록하고, 사용한 적립금 M원을<br/>원장에 복원합니다. 이 처리는 되돌릴 수 없습니다.'"}
    RC -->|"취소 (abort)"| RACT
    RC -->|"[환불 완료]"| RCOK["saveRefund('completed')"]
  end

  SAVE --> MUT["useCrudUpdate.mutate({...toClaimInput(claim), ...patch})"]
  RQ --> MUT
  RCOK --> MUT
  MUT --> PATCH{"어댑터 patchClaim — 전이검사 → 재고 → 환불 복원, **한 덩이**"}
  PATCH --> AT["assertTransitions: 화면과 **같은 술어**를 다시 부른다<br/>claimTransitionBlock → 422 field 'status'<br/>refundTransitionBlock → 422 field 'refundStatus'<br/>(환불 가드는 **저장 이후의 클레임 상태**로 판정한다)<br/>completedAt 이 찍힌 뒤 차감 변경 → '환불이 완료되어 차감 내역을 바꿀 수 없습니다.'"]
  AT --> SEF["applyStockEffects: !movesStock || isStockApplied 면 무변경<br/>variantsOf 가 null 이면 422 '연결된 상품의 옵션을 확인할 수 없어…'<br/>planStockMovements — 반품=회수분 in, 교환=회수분 in + 재발송 out<br/>applyStockMovements 가 false 면 **stockAppliedAt 을 찍지 않는다**"]
  SEF --> REF["applyRefundEffects — status==='completed' && completedAt==='' 일 때만<br/>= **환불완료 진입 순간에만** 복원한다(접수·수거에서 미리 되돌리지 않는다)<br/>planRefundRestoration: 이미 완료했거나 비회원이면 point 0<br/>appendPointRestore(양수 1건 append) 실패 시 500<br/>'적립금 원장에 연결되지 않아 환불을 완료하지 못했습니다…'<br/>성공하면 refund.completedAt + restoredPoint 각인(멱등키)"]
  REF --> RES{"결과"}
  RES -->|"성공"| MOK["toast '처리 내용을 저장하고 재고를 반영했습니다.' /<br/>'처리 내용을 저장했습니다.' / '환불을 접수했습니다.' / '환불을 완료 처리했습니다.'<br/>detailQuery.refetch() + (교환이면) variantQuery.refetch()"]
  RES -->|"422 isUnprocessable"| E422["setFieldError = violations[0].message<br/>필드 인라인으로 되돌린다 (EXC-07)<br/>다이얼로그는 닫히지 않는다 — 재클릭이 재시도"]
  RES -->|"그 외"| E500["serverError 배너 + 오류 코드 referenceOf(cause)"]
  RES -->|"isAbort"| ABT["무시"]
  E422 --> EDIT
  E500 --> EDIT
  MOK --> DQ

  VIEW --> PERM{"canUpdate (EXC-03)"}
  PERM -->|"아니오"| NOPERM["Alert info '이 클레임을 처리할 권한이 없습니다. 조회만 가능합니다.'<br/>[처리 저장] 미노출 · 입력 disabled"]
  VIEW --> HIST["재고 이동 이력 StockMovementTable<br/>취소면 '취소는 이 화면에서 재고를 움직이지 않습니다.<br/>출고 전 재고는 주문을 취소할 때 되돌아갑니다.'<br/>아니면 '아직 반영된 재고 이동이 없습니다. 완료 처리 시 기록됩니다.'"]
  VIEW --> UNS["useUnsavedChangesDialog(dirty && !saving)<br/>'처리 내용에 저장하지 않은 변경이 있습니다…'"]
  UNS --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,DERR,CW,TB,T2,XCH,PRE,WILL,CS,RS,RB,RC,PATCH,RES,PERM gate
  class E1,EMP,DNF,DER,CW1,CW2,T0,T1,T4,T5,T6,HINT,XE,I1,I2,I3,I4,R0,R1,R2,R3,R4,R5,R6,RHINT,E422,E500,NOPERM err
  class OK1,MOK,T3 ok
