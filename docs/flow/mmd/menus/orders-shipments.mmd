%% 배송 처리 · /orders/shipments
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /orders/shipments"]) --> URL["useListState({filterDefaults:{work:'all'}})<br/>work·keyword 를 URL 이 소유 (IA-13)<br/>parseFilter(SHIPMENT_WORK_FILTER_VALUES, 'all')"]
  URL --> Q2["**조회 두 벌** — 행은 배송 건이 아니라 **주문**이다<br/>useCrudListQuery('orders', orderAdapter)<br/>useCrudListQuery('shipments', shipmentAdapter)<br/>배송 건만 읽으면 송장 없는 주문이 목록에서 사라진다"]
  Q2 --> ROWS0["buildShipmentRows(orders, shipments)<br/>isShippable: !isCanceled && status !== 'pending'<br/>행 id = 주문번호 · shipments = orderId 일치분<br/>coverage = shipmentCoverage(lines, dispatchedShipments(own))<br/>remaining = uninvoicedLines(lines, own)"]
  ROWS0 --> ST{"조회 상태<br/>firstLoading = 둘 중 하나라도 첫 로드<br/>loadError = orders.error ?? shipments.error"}

  ST -->|"firstLoading"| L["ShipmentTable loading — 스켈레톤 (STATE-01)"]
  ST -->|"loadError !== null"| E1["Alert danger '배송 목록을 불러오지 못했습니다.'<br/>[다시 시도] → orders.refetch() + shipments.refetch()"]
  ST -->|"성공"| OK1["표 · 주문번호·주문일·수령인·품목·택배사·송장번호·배송 상태<br/>InvoiceCell: trackingUrl(carrier, invoiceNo) 이 null 이면 링크 없이 번호만<br/>(실시간 추적을 흉내 내지 않는다 — 템플릿에 번호만 끼운다)"]
  E1 --> Q2
  L --> OK1

  Q2 --> WORK["shipmentWorkStatus(order, own) — **주문 하나의 작업 상태** 4갈래<br/>pending 발송대기 / waiting 배송대기 / shipping 배송중 / delivered 배송완료<br/>'pending' 은 도메인 ShipmentStatus 에 없다 — '배송 건이 아직 없다' 는 사실이라서<br/>coverage.complete 아니면 무조건 pending — **부분발송은 발송대기다**"]
  WORK --> RAIL["FilterRail + FilterPanel '배송 상태'<br/>countRowsByWork — 필터 이전 전체에서 · 못 셌으면 null → '—'<br/>안내: 택배사는 배송 설정(/products/shipping)에 등록된 목록에서만"]
  RAIL --> APPLY["searchShipmentRows(filterRowsByWork(rows, work), keyword)<br/>검색 대상: 주문번호·수령인·**송장번호**<br/>(택배사가 부르는 것은 송장번호다)"]
  APPLY --> EMPTY{"visible.length === 0"}
  EMPTY -->|"예"| EMP["Empty createVerb='접수'<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  EMPTY -->|"아니오"| SEL["행 렌더 · 선택은 selectable = canUpdate (EXC-03)<br/>배송 처리는 주문의 **수정**이다"]

  SUB1 ~~~ SUB2

  subgraph SUB1["일괄 처리 — 세 버튼 (서로를 밀어낸다: PendingAction 하나)"]
    SEL --> BAR["SelectionBar · 버튼 글자에 처리 가능 건수를 미리 싣는다<br/>배송준비중 처리 (eligibleForPreparing = canTransitionOrder(order,'preparing'))<br/>송장 입력 (eligibleForInvoice = remaining.length &gt; 0)<br/>발송처리 (eligibleForDispatch = some(canDispatchShipment))<br/>disabled = count === 0 || busy"]

    BAR --> A1["① 배송준비중 — ConfirmDialog intent='update'<br/>일부만 가능하면 '나머지는 이미 지난 단계이거나<br/>입금이 확인되지 않은 주문입니다.'<br/>runPrepare: applyOrderStatus(order,'preparing') — 주문 축만 움직인다"]

    BAR --> A2["② 송장 입력 → InvoiceBulkDialog (주문별 한 줄)<br/>carriers = activeCarriers() — **배선 전에는 null**"]
    A2 --> CAR{"택배사 목록"}
    CAR -->|"carriers === null"| CAR1["Alert warning '택배사 목록을 확인하지 못해 송장을 등록할 수 없습니다.'<br/>빈 배열로 뭉개면 '등록하러 가라' 로 잘못 읽힌다"]
    CAR -->|"options.length === 0"| CAR2["Alert warning '사용 중인 택배사가 없습니다.<br/>상품 관리 &gt; 배송에서 택배사를 먼저 등록해 주세요.'"]
    CAR -->|"있음"| CAR3["첫 줄 택배사가 초기값 · 빈 목록이면 '' (임의 선택 금지)<br/>송장 입력은 inputMode='numeric' · maxLength=INVOICE_NO_MAX(30)"]
    CAR1 --> LOCK["저장 버튼 disabled = busy || noCarriers"]
    CAR2 --> LOCK

    CAR3 --> V{"submit → validate() — 한 줄이라도 틀리면 **아무것도 저장하지 않는다**"}
    V -->|"carrierId === ''"| V0["'택배사를 선택하세요.'"]
    V -->|"invoiceNoBlock"| V1["INVOICE_NO_REQUIRED '송장번호를 입력하세요.'<br/>INVOICE_NO_TOO_LONG '송장번호는 30자를 넘을 수 없습니다.'<br/>INVOICE_NO_FORMAT '숫자와 하이픈(-)만 입력할 수 있습니다.<br/>한글·공백이 섞이면 택배사 접수 파일이 깨집니다.'"]
    V -->|"duplicateInvoiceBlock(existing, entry)"| V2["'이미 ORD-… 주문에 쓰인 송장번호입니다.<br/>같은 택배사에 같은 번호를 두 번 붙일 수 없습니다.'<br/>**같은 carrierId 안에서만** 중복 — 택배사가 다르면 같은 숫자는 정상"]
    V -->|"다이얼로그 안 다른 줄과 충돌"| V3["'이 다이얼로그의 ORD-… 줄과 송장번호가 같습니다.'<br/>붙여넣기 실수는 대부분 화면 안 두 줄 사이에서 난다"]
    V0 --> VE["errors[orderId] · aria-invalid + errorIdOf (A11Y-11)<br/>제출 때만 채운다 — 치는 도중 붉게 물들이지 않는다"]
    V1 --> VE
    V2 --> VE
    V3 --> VE
    VE --> CAR3
    V -->|"통과"| RUNI["runInvoice(entries) — normalizeInvoiceNo 로 앞뒤 공백만 제거<br/>createShipment(status:'waiting', shippedAt:'', deliveredAt:'')<br/>lines = row.remaining 전부(잔량 전량을 이 송장에)"]

    BAR --> A3["③ 발송처리 — ConfirmDialog<br/>'전 품목이 나간 주문만 배송중이 되고,<br/>일부만 나간 주문은 발송대기에 남습니다. 되돌릴 수 없습니다.'"]
    A3 --> RUND["runDispatch: canDispatchShipment 인 건만<br/>applyShipmentStatus(shipment,'shipping',at)<br/>= shipmentTransitionBlock 재판정 후 throw or 시각 도장<br/>SHIPMENT_TRANSITION_BACKWARD '배송 상태는 되돌릴 수 없습니다.'<br/>SHIPMENT_DISPATCH_NO_INVOICE '송장번호가 없어 발송처리할 수 없습니다.'<br/>shippedAt 은 이미 찍혔으면 덮지 않는다"]
    RUND --> QTY["applyShippedQuantities(order.lines, next)<br/>allocateCovered(module-private) 가 SKU 풀에서 품목 순서대로 배정<br/>→ 주문의 **shippedQuantity** 는 이 계산의 결과다(화면이 더하지 않는다)"]
  end

  subgraph SUB2["주문 축과의 다리 — orderShipmentBlock"]
    RUNI --> B1{"orderShipmentBlock(row.order, [...own, created], 'waiting')"}
    QTY --> B2{"orderShipmentBlock(withQuantities, next, 'shipping')"}
    B1 --> BR["① 먼저 **주문 축**에 묻는다 — orderTransitionBlock<br/>취소됐거나 · 입금 전이거나 · 이미 지난 단계면 그 사유를 그대로<br/>② 그 위에 배송 축이 얹는 것은 하나뿐 — 전 품목이 덮였는가"]
    B2 --> BR
    BR --> BC{"coverage.complete<br/>waiting 은 '송장이 다 붙었는가'<br/>shipping 은 '실제로 다 나갔는가'(dispatchedShipments)"}
    BC -->|"null (통과)"| PUSH["applyOrderStatus(order, waiting|shipping, at, '운영자')<br/>→ updateOrder.mutateAsync (주문 어댑터가 쓴다)<br/>배송 어댑터는 주문을 만지지 않는다 — 재고 부수효과를 우회하지 않으려고"]
    BC -->|"'송장이 붙지 않은 품목이 있어 배송대기로 넘길 수 없습니다 (1/3).'"| HOLD1["주문 상태를 밀지 않고 배송 건만 남긴다"]
    BC -->|"'전 품목이 발송되어야 배송중으로 넘어갑니다 (1/3).'"| HOLD2["상태는 그대로 · shippedQuantity 만 올라간다<br/>주문 목록의 '부분배송 1/3' 배지가 그 사실을 말한다<br/>부분발송을 상태로 만들지 않는다(한 주문 = 한 상태)"]
  end

  PUSH --> RES{"settleAllDetailed 결과"}
  HOLD1 --> RES
  HOLD2 --> RES
  A1 --> RES
  RES -->|"failed === 0"| OKT["toast — 'N건을 배송준비중으로 처리했습니다.' /<br/>'N건에 송장을 등록했습니다. 발송처리하면 배송중이 됩니다.' /<br/>'N건을 발송처리했습니다.'<br/>clearSelection · 다이얼로그 닫힘"]
  RES -->|"failed &gt; 0 (부분 실패)"| PERR["다이얼로그 **닫지 않는다**<br/>'N건을 처리하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>재클릭 = 재시도"]
  RES -->|"isAbort"| AB["무시 — closeAction 이 controller.abort()"]
  RES -->|"그 외 오류"| PERR2["'처리하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
  PERR --> RES
  PERR2 --> RES
  OKT --> Q2

  CAR3 --> GUARD["useModalDirtyGuard(dirty && !busy, onCancel)<br/>dirty = 송장번호를 한 칸이라도 쳤는가<br/>discardDialog 는 Modal **밖**에 — 안이면 포커스 트랩에 갇힌다"]
  GUARD --> S

