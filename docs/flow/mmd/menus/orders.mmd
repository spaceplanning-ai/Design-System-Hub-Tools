%% 주문 · /orders
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /orders"]) --> URL["useListState({filterDefaults:{status:'all'}})<br/>status·keyword 를 URL 이 소유 (IA-13)<br/>parseFilter(ORDER_STATUS_FILTER_VALUES, 'all')"]
  URL --> Q["useCrudListQuery('orders', orderAdapter)<br/>※ 등록 폼도 삭제도 없다 — 주문은 고객의 결제가 만든다<br/>어댑터에 build 는 있으나 그 문을 여는 버튼이 없다"]
  Q --> ST{"조회 상태"}

  ST -->|"firstLoading = isFetching && data===undefined"| L["OrderTable loading — 스켈레톤 (STATE-01)<br/>refetch 중에는 이전 행 유지"]
  ST -->|"error !== null"| E1["Alert danger '주문 목록을 불러오지 못했습니다.'<br/>[다시 시도] → refetch"]
  ST -->|"성공"| OK1["OrderTable (CrudListShell 아님 — DS Table 직접 조립)<br/>주문번호·주문일시·주문자·상품·결제수단·결제금액·상태<br/>sortOrders(주문일시 DESC · 동시각은 id)"]
  E1 --> Q
  L --> OK1

  Q --> RAIL["FilterRail + FilterPanel '주문 상태'<br/>countOrdersByStatus — **필터 이전** 전체에서 센다<br/>아직 못 셌으면 null → '—' (0 과 '모름' 은 다르다)"]
  RAIL --> FLT["ORDER_STATUS_FILTERS = 전체 + 7단 + 취소<br/>pending 입금전 → preparing 배송준비중 → holding 배송보류<br/>→ waiting 배송대기 → shipping 배송중 → delivered 배송완료 → confirmed 구매확정<br/>취소는 상태가 아니라 canceledAt 이라 **별도 항목**"]
  FLT --> APPLY["searchOrders(filterOrdersByStatus(items,status), keyword)<br/>filterOrdersByStatus: 상태 필터에서 취소건은 빠진다<br/>검색은 주문번호·주문자·**모든 품목의 상품명**"]
  APPLY --> EMPTY{"visible.length === 0<br/>왜 비었는가"}
  EMPTY -->|"canArrive===false && !hasQuery && !hasActiveFilters"| PGOFF["Alert info — '오늘 0건' 과 구조적으로 다른 사실<br/>'현재 결제를 사용하지 않아 주문이 들어오지 않습니다…<br/>구매하기 대신 문의하기이며, 고객의 글은 상품 문의로 접수됩니다'<br/>[결제 설정 열기] · [상품 문의 열기]<br/>ordersCanArrive() = checkoutCta(...).kind === 'purchase'"]
  EMPTY -->|"그 외 0건"| EMP["Empty createVerb='접수'<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  EMPTY -->|"행 있음"| ROWS["행 렌더 · onActivate → navigate(detail)<br/>+ DetailCellLink(주문번호) 로 키보드 경로 (A11Y-08)<br/>취소행 tone='danger' + '취소' 배지 · 부분배송 배지"]
  ROWS --> DETAIL

  SUB1 ~~~ SUB2

  subgraph SUB1["일괄 상태 처리 — 목록 (canUpdate 에만)"]
    ROWS --> SEL["RowSelectCell 선택 — selectable = canUpdate<br/>(canRemove 가 아니다: 여기서 선택이 하는 일은 **수정**이다)"]
    SEL --> BULK["SelectionBar · BULK_TRANSITIONS 4종만<br/>preparing / waiting / shipping / delivered<br/>pending 은 되돌리는 방향, confirmed 는 무더기로 찍을 일이 아니다"]
    BULK --> CNT["버튼 글자 = bulkTransitionLabel(target) + 처리 가능 건수<br/>count = eligibleForTransition(selectedOrders, to).length<br/>disabled = count === 0 || bulkBusy"]
    CNT --> BCONF{"ConfirmDialog intent='update'<br/>eligible.length === selectedCount ?"}
    BCONF -->|"전부 가능"| BM1["'선택한 주문 N건을 …(으)로 진행합니다.<br/>주문 상태는 되돌릴 수 없습니다.'"]
    BCONF -->|"일부만"| BM2["'선택한 N건 중 M건만 … 진행합니다.<br/>나머지는 이미 지난 단계이거나, 취소되었거나,<br/>' + ORDER_TRANSITION_UNPAID"]
    BM1 --> RUN
    BM2 --> RUN["runBulk → settleAllDetailed(eligible, …)<br/>건마다 applyOrderStatus(order,to,at,'운영자') → toOrderInput"]
    RUN --> BR{"failed"}
    BR -->|"0"| BOK["toast 'N건을 …(으)로 처리했습니다.'<br/>clearSelection · 다이얼로그 닫힘"]
    BR -->|"&gt; 0 (부분 실패)"| BERR["다이얼로그 **닫지 않는다**<br/>'N건을 처리하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>재클릭 = 재시도"]
    BR -->|"isAbort"| BAB["무시 (닫기 시 controller.abort())"]
    BERR --> RUN
    BOK --> Q
  end

  subgraph SUB2["상세 · /orders/:id — 처리 워크플로(화면 유형 E)"]
    DETAIL["OrderDetailPage · useCrudItem('orders',…, id)"] --> DERR{"detailQuery.error (EXC-12)"}
    DERR -->|"isNotFound"| DNF["'주문을 찾을 수 없습니다. 주문번호를 다시 확인해 주세요.'<br/>[다시 시도] 없음 · [목록으로]만"]
    DERR -->|"그 외"| DER["'주문을 불러오지 못했습니다.' [다시 시도] · [목록으로]"]
    DERR -->|"정상"| VIEW["요약 카드 — StatusBadge(orderStatusTone) + '취소' + 부분배송<br/>재고 차감 줄: 미차감이면 '(설정: 입금 확인 시)' 를 함께<br/>주문자·수령인 / 주문 품목(스냅숏) / 결제 정보(orderAmounts) / 처리 이력 Timeline"]
    DER --> VIEW
    VIEW --> PERM{"canUpdate (EXC-03)"}
    PERM -->|"아니오"| NOPERM["Alert info '이 주문을 처리할 권한이 없습니다. 조회만 가능합니다.'<br/>액션 줄 자체를 렌더하지 않는다"]
    PERM -->|"예"| ACT["액션"]

    ACT --> A0{"unpaid = payment.paidAt === '' && !canceled"}
    A0 -->|"예"| PAID["[입금 확인] → ConfirmDialog<br/>'…재고 차감 시점이 <br/>입금 확인 시 이면 이 시점에 재고가 빠지며, 되돌릴 수 없습니다.'<br/>applyOrderPaid — canceledAt 이면 throw ORDER_TRANSITION_CANCELED"]
    ACT --> A1{"nextStatuses = nextOrderStatuses(order)<br/>= ORDER_STATUS_SEQUENCE.filter(canTransitionOrder)"}
    A1 -->|"비어 있음"| STUCK["버튼 없음 · stuckReason = orderTransitionBlock(order,'confirmed')<br/>ORDER_TRANSITION_CANCELED '취소된 주문은 상태를 바꿀 수 없습니다.'<br/>ORDER_TRANSITION_CONFIRMED '구매확정된 주문은 더 이상 진행할 단계가 없습니다.'"]
    A1 -->|"있음"| NEXT["'…처리' 버튼 N개 — index 0 && !unpaid 만 primary<br/>ConfirmDialog '주문 ORD-…을(를) …(으)로 진행합니다.<br/>주문 상태는 되돌릴 수 없습니다.'"]
    ACT --> A2{"cancelBlocked = orderCancelBlock(order)"}
    A2 -->|"ORDER_CANCEL_DONE"| CB1["버튼 대신 이유: '이미 취소된 주문입니다.'"]
    A2 -->|"ORDER_CANCEL_SHIPPED (hasLeftWarehouse)"| CB2["'배송이 시작된 주문은 취소할 수 없습니다.<br/>교환/반품으로 접수해 주세요.' → /orders/claims 가 받는다"]
    A2 -->|"null"| CANCEL["[주문 취소] → **Modal**(ConfirmDialog 아님 — 사유를 받아야 한다)<br/>orderCancelReasonError: 공백 '취소 사유를 입력하세요.'<br/>200자 초과 거절 · applyOrderCancel"]
    ACT --> NOTE["처리 메모 TextareaField (ORDER_NOTE_MAX 500)<br/>noteDirty 일 때만 [메모 저장] 활성 — **확인 창 없음**<br/>되돌릴 수 있는 변경이라 곧바로 저장한다"]

    PAID --> GATE
    NEXT --> GATE{"applyOrderStatus / applyOrderPaid / applyOrderCancel<br/>내부에서 orderTransitionBlock·orderCancelBlock 재판정<br/>막히면 **throw** — 같은 술어가 버튼과 저장을 함께 지배한다"}
    CANCEL --> GATE
    GATE -->|"throw (화면과 규칙이 어긋난 버그)"| GX["catch → serverError 에 cause.message 그대로<br/>ORDER_TRANSITION_BACKWARD '주문 상태는 되돌릴 수 없습니다.'"]
    GATE -->|"통과"| SAVE["save(next) → useCrudUpdate.mutate(toOrderInput(next))"]
    NOTE --> SAVE
  end

  SAVE --> PATCH{"어댑터 patch = applyStockEffects<br/>복원을 먼저 본다"}
  PATCH -->|"shouldRestoreStock<br/>(취소 && 차감함 && 미복원)"| P1["planOrderRestore — **기록된 out 이동을 뒤집는다**<br/>품목에서 다시 만들지 않는다(정정된 수량과 어긋나지 않게)<br/>applyStockMovements 성공 시에만 withStockRestored(stockRestoredAt)"]
  PATCH -->|"shouldDeductStock(next, readStockDeductAt())<br/>미취소 && stockAppliedAt==='' && 시점 도달"| P2["planOrderDeduction → withStockApplied(stockAppliedAt)<br/>StockDeductAt = 'order'(주문 즉시) | 'payment'(입금 확인 시, 기본값)"]
  PATCH -->|"둘 다 아님"| P3["재고 무변경 — 멱등키가 이미 찍혀 있다"]
  P1 --> RES
  P2 --> RES
  P3 --> RES{"결과"}
  RES -->|"applyStockMovements 가 false"| PX["**멱등키를 찍지 않는다** — 재고는 그대로인데<br/>'차감 완료' 라고 말하는 주문을 남기지 않는다"]
  RES -->|"성공"| MOK["toast(입금을 확인했습니다 / …로 처리했습니다 /<br/>주문을 취소했습니다 / 처리 메모를 저장했습니다)<br/>detailQuery.refetch()"]
  RES -->|"실패"| ME["serverError '저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>+ 오류 코드 referenceOf(cause) · 다이얼로그 유지"]
  PX --> MOK
  ME --> SAVE
  MOK --> DETAIL

  VIEW --> UNS["useUnsavedChangesDialog(noteDirty && !saving)<br/>'처리 메모에 저장하지 않은 변경이 있습니다…'"]
  UNS --> S

