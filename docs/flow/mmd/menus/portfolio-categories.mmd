%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  START(["진입 · /portfolio/categories"]) --> Q["useCrudListQuery<br/>키 ['portfolio-categories','list']<br/>listCategoryUsage"]

  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| SKEL["'불러오는 중…'"]
  ST -->|"refreshing"| REF["' · 새로고침 중…'"]
  ST -->|"error !== null"| ERR1["Alert danger<br/>'카테고리를 불러오지 못했습니다.'<br/>[다시 시도] → refetch"]
  ST -->|"성공"| LIST["Card + ul/CategoryRow<br/>label + StatusBadge usageLabel<br/>'미사용' / 'N개 사용 중'<br/>헤더 '전체 N개'"]

  ERR1 --> Q
  SKEL --> LIST
  REF --> LIST

  LIST --> NOFILTER["※ 필터·검색·정렬·페이지네이션 없음<br/>URL 쿼리스트링 미사용 (IA-13 미적용)<br/>순서 = 삽입 순서"]
  NOFILTER --> EMPTY{"categories.length === 0"}
  EMPTY -->|"예"| EMP["'등록된 카테고리가 없습니다.'"]
  EMPTY -->|"아니오"| ROWS["행 렌더<br/>안내: 사용 중인 카테고리는 삭제할 수 없습니다"]

  ROWS --> ACT{"액션 선택 (IA-06 모달 편집)"}
  ACT -->|"[카테고리 추가]"| MCREATE["modal = {kind:'create'}"]
  ACT -->|"연필 '{label} 수정'"| MEDIT["modal = {kind:'edit', category}"]
  ACT -->|"휴지통"| GATE

  GATE{"인유즈 게이트<br/>inUse = category.itemCount > 0"} -->|"inUse → 버튼 disabled"| BLOCK["aria-label '{label} — {usage}라 삭제할 수 없습니다'<br/>title '{usage} — 삭제할 수 없습니다'"]
  GATE -->|"미사용"| DLG{"ConfirmDialog intent=delete<br/>'카테고리 삭제'<br/>confirmLabel '카테고리 삭제'"}
  BLOCK --> ROWS

  DLG -->|"취소 closeDelete"| ROWS
  DLG -->|"확인 onConfirmDelete"| DELM["useCrudDelete → removeCategory(id)<br/>2차 게이트: countItemsUsingCategory > 0<br/>→ throw '사용 중인 카테고리는 삭제할 수 없습니다.'"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast '{label} 카테고리를 삭제했습니다.'<br/>invalidate ['portfolio-categories','list']"]
  DELR -->|"실패"| DELER["setDeleteError<br/>'삭제하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>다이얼로그 내부 표시"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["PortfolioCategoryFormModal (생성·수정 공용)"]
    MCREATE --> MODAL
    MEDIT --> MODAL
    MODAL["isEdit = editing !== null<br/>제목 '카테고리 추가' / '카테고리 수정'<br/>필드 name (id portfolio-category-name)<br/>maxLength 40 · initialFocusRef"] --> TYPE["입력 · isDirty 추적"]
    TYPE --> CLOSE{"닫기 시도<br/>useModalDirtyGuard(isDirty && !saving)<br/>Esc·딤·×·취소 모두 requestClose"}
    CLOSE -->|"계속 편집"| TYPE
    CLOSE -->|"버리기"| LIST
    TYPE --> SUBMIT["Modal onSubmit<br/>clearErrors → handleSubmit(onValid, focus)"]
  end

  subgraph SUB2["검증 · 저장"]
    SUBMIT --> ZOD{"portfolioCategorySchema<br/>requiredText('카테고리 이름', 40)"}
    ZOD -->|"실패"| ZERR["'카테고리 이름을 입력하세요.'<br/>'카테고리 이름은 40자를 넘을 수 없습니다.'"]
    ZERR --> TYPE
    ZOD -->|"통과"| MUT["useCrudCreate → addCategory(name)<br/>useCrudUpdate → updateCategory(id, name)<br/>※ 중복 이름 검사 없음"]
    MUT --> RES{"결과"}
    RES -->|"성공"| OK["modal = {kind:'closed'}<br/>toast '{name} 카테고리를 추가/저장했습니다.'<br/>invalidate list (+detail on update)<br/>※ ['portfolio','list'] 는 무효화 안 함"]
    RES -->|"isAbort"| ABORT["무시 (조용히 종료)"]
    RES -->|"그 외"| SERR["setServerError Alert danger<br/>'저장하지 못했습니다…' · 모달 유지"]
    SERR --> TYPE
  end

  OK --> Q
  ABORT --> LIST

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,EMPTY,ACT,GATE,DLG,CLOSE,ZOD,RES,DELR gate
  class ERR1,EMP,BLOCK,ZERR,SERR,DELER err
