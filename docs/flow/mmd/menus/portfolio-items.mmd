  ST -->|"refreshing"| REFRESH["기존 행 유지<br/>' · 새로고침 중…'"]
  ST -->|"error !== null"| ERR1["Alert danger<br/>'포트폴리오 목록을 불러오지 못했습니다.'<br/>[다시 시도] → controller.refetch"]
  ST -->|"성공"| LIST["CrudListShell · CrudTable<br/>분류·제목·고객사·일자·노출"]

  ERR1 --> Q
  SKEL --> LIST
  REFRESH --> LIST

  LIST --> FILTER["분류 필터 · useState(filter)<br/>PORTFOLIO_FILTER_ALL='all'<br/>※ URL 쿼리스트링 아님(로컬 상태)"]
  FILTER --> APPLY["filterPortfolioItems(list, categoryId)<br/>정렬 고정 sortPortfolioItems(일자 DESC)"]
  APPLY --> EMPTY{"visible.length === 0"}
  EMPTY -->|"예"| EMP["Empty<br/>hasActiveFilters → [필터 초기화]"]
  EMPTY -->|"아니오"| ROWS["행 렌더 · 선택 초기화 clear()"]

  ROWS --> ACT{"액션 선택"}
  ACT -->|"등록 · canCreate"| FORM
  ACT -->|"행 클릭·연필 · canUpdate"| FORM
  ACT -->|"휴지통 · canRemove"| DEL
  ACT -->|"노출 토글"| TOG

  TOG["useCrudRowUpdate.run<br/>{...toPortfolioInput(item), published: next}"] --> TOGR{"결과"}
  TOGR -->|"성공"| TOGOK["toast '게시했습니다' / '숨겼습니다'"]
  TOGR -->|"실패"| TOGER["toast '변경하지 못했습니다.'"]
  TOGOK --> Q
  TOGER --> LIST

  DEL["requestDelete / requestBulkDelete"] --> DLG{"ConfirmDialog intent=delete<br/>'포트폴리오 삭제' / '일괄 삭제'"}
  DLG -->|"취소"| LIST
  DLG -->|"확인"| DELM["useCrudDelete · useCrudBulkDelete"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast 삭제 완료<br/>invalidate ['portfolio','list']"]
  DELR -->|"실패"| DELER["deleteErrorMessage<br/>409 원문 · 그 외 '삭제하지 못했습니다.'<br/>다이얼로그 유지"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 · /portfolio/items/new · /:id/edit"]
    FORM["FormPageShell + useCrudForm<br/>title·categoryId·client·summary<br/>date·coverImageUrl·imageUrls·published"] --> LOAD{"loadFailure (수정 모드)"}
    LOAD -->|"'not-found'"| LNF["'포트폴리오를 찾을 수 없습니다.'<br/>[목록으로]만"]
    LOAD -->|"'error'"| LER["'포트폴리오를 불러오지 못했습니다.'<br/>[다시 시도] retryLoad · [목록으로]"]
    LOAD -->|"정상"| EDIT["입력 · isDirty 추적"]
    LER --> EDIT
    EDIT --> LEAVE{"이탈 시도<br/>useUnsavedChangesDialog<br/>isDirty && !saving"}
    LEAVE -->|"머무르기"| EDIT
    LEAVE -->|"나가기"| START
    EDIT --> SUBMIT["submit = handleSubmit(onValid, onInvalid)<br/>submitLockRef 중복 제출 차단"]
  end

  subgraph SUB2["검증 · 저장"]
    SUBMIT --> ZOD{"portfolioSchema"}
    ZOD -->|"실패"| ZERR["'제목을 입력하세요.' · '카테고리를 선택하세요.'<br/>'일자 형식이 올바르지 않습니다.'<br/>'대표 이미지를 등록하세요.'<br/>'본문 이미지는 최대 10장까지…'"]
    ZERR --> EDIT
    ZOD -->|"통과"| MUT["takeIdempotencyKey()<br/>useCrudCreate / useCrudUpdate<br/>exists(id) 검사"]
    MUT --> RES{"결과"}
    RES -->|"성공"| OK["toast '등록/저장했습니다.'<br/>invalidate list(+detail)<br/>navigate('/portfolio/items', replace)"]
    RES -->|"409 isConflict"| CONF["FormConflictDialog<br/>'다른 사용자가 먼저 삭제한 항목입니다.'<br/>reload / dismiss"]
    RES -->|"422 isUnprocessable"| F422["setError(violation.field) + setFocus"]
    RES -->|"그 외"| F500["FormServerError<br/>'저장하지 못했습니다…' + errorReference"]
    CONF --> EDIT
    F422 --> EDIT
    F500 --> EDIT
  end

  OK --> START

