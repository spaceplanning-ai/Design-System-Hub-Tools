%% 상품 카테고리 · /products/categories
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  START(["진입 · /products/categories"]) --> URL["useListState (IA-13 URL 쿼리스트링)<br/>?usage=all|in-use|unused<br/>parseFilter(list.filters['usage'], CATEGORY_USAGE_FILTER_VALUES, 'all')<br/>※ q·page·sort 미사용"]
  URL --> PERM{"canCreate"}
  PERM --> Q["useCrudListQuery<br/>키 ['product-categories','list']<br/>listProductCategoryUsage"]

  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| SKEL["'불러오는 중…' (툴바 + 카드)"]
  ST -->|"error !== null"| ERR1["Alert danger<br/>'카테고리를 불러오지 못했습니다.'<br/>[다시 시도] → refetch"]
  ST -->|"loaded"| LIST["Card + ul/CategoryRow<br/>label + usageLabel '미사용' / 'N개 상품'<br/>'전체 N개' · countCategoriesByUsage<br/>미로드 시 배지 '—'"]

  ERR1 --> Q
  SKEL --> LIST

  LIST --> FILT["CategoryUsageFilter 좌측 1축<br/>list.setFilter('usage', next)"]
  FILT --> EMPTY{"visible.length === 0"}
  EMPTY -->|"예"| EMP["Empty label='카테고리'<br/>hasActiveFilters → [필터 초기화]<br/>+ createButton"]
  EMPTY -->|"아니오"| ROWS["행 렌더<br/>안내: 사용 중인 카테고리는 삭제할 수 없습니다"]

  ROWS --> ACT{"액션 선택 (IA-06 모달 편집)"}
  ACT -->|"[카테고리 추가] · canCreate"| MCREATE["modal = {kind:'create'}"]
  ACT -->|"연필 '{label} 수정'"| MEDIT["modal = {kind:'edit', category}"]
  ACT -->|"휴지통"| GATE

  GATE{"인유즈 게이트<br/>inUse = category.productCount > 0"} -->|"inUse → disabled"| BLOCK["title '{usage} — 삭제할 수 없습니다'<br/>aria-label '{label} — {usage}라 삭제할 수 없습니다'"]
  GATE -->|"미사용"| DLG{"ConfirmDialog intent=delete<br/>'카테고리 삭제'<br/>confirmLabel '카테고리 삭제'"}
  BLOCK --> ROWS

  DLG -->|"취소 closeDelete (abort + reset)"| ROWS
  DLG -->|"확인 onConfirmDelete"| DELM["useCrudDelete → removeProductCategory(id)<br/>2차 게이트 countProductsUsingCategory > 0<br/>→ throw '사용 중인 카테고리는 삭제할 수 없습니다.' (서버 409)"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast '{label} 카테고리를 삭제했습니다.'<br/>invalidate ['product-categories','list']"]
  DELR -->|"실패"| DELER["setDeleteError<br/>'삭제하지 못했습니다…' (409 원문 미노출)"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["ProductCategoryFormModal (생성·수정 공용)"]
    MCREATE --> MODAL
    MEDIT --> MODAL
    MODAL["isEdit = editing !== null<br/>필드 name (id product-category-name)<br/>label '카테고리 이름' · maxLength 40<br/>placeholder '예: 아우터'"] --> TYPE["입력 · isDirty"]
    TYPE --> CLOSE{"닫기 시도<br/>useModalDirtyGuard(isDirty && !saving)<br/>Esc·딤·×·취소 → requestClose"}
    CLOSE -->|"계속 편집"| TYPE
    CLOSE -->|"버리기"| LIST
    TYPE --> SUBMIT["Modal onSubmit → clearErrors<br/>handleSubmit(onValid, focus)"]
  end

  subgraph SUB2["검증 · 저장"]
    SUBMIT --> ZOD{"productCategorySchema<br/>requiredText('카테고리 이름', 40)"}
    ZOD -->|"실패"| ZERR["'카테고리 이름을 입력하세요.'<br/>'카테고리 이름은 40자를 넘을 수 없습니다.'"]
    ZERR --> TYPE
    ZOD -->|"통과"| MUT["create.mutate → addProductCategory(name)<br/>update.mutate → updateProductCategory(id, name)<br/>수정 시 product.categoryLabel 연쇄 갱신<br/>※ 중복 라벨 검사 없음"]
    MUT --> RES{"결과"}
    RES -->|"성공"| OK["modal = {kind:'closed'}<br/>toast '{name} 카테고리를 추가/저장했습니다.'<br/>invalidate list(+detail)<br/>※ ['products','list'] 는 무효화 안 함"]
    RES -->|"isAbort"| ABORT["무시"]
    RES -->|"그 외"| SERR["setServerError Alert danger<br/>'저장하지 못했습니다…' · 모달 유지"]
    SERR --> TYPE
  end

  OK --> Q
  ABORT --> LIST

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class PERM,ST,EMPTY,ACT,GATE,DLG,CLOSE,ZOD,RES,DELR gate
  class ERR1,EMP,BLOCK,ZERR,SERR,DELER err
