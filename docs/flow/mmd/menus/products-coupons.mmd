  DLG -->|"확인"| DELM["useCrudDelete / useCrudBulkDelete"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast 삭제 완료 · invalidate ['coupons','list']"]
  DELR -->|"실패"| DELER["deleteErrorMessage · bulkDeleteErrorMessage<br/>다이얼로그 유지"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 · /products/coupons/new · /:id/edit"]
    FORM["FormPageShell 단일 카드 '쿠폰 정보'<br/>+ 우측 CouponCardPreview<br/>name·code·issueType·discountValue·maxDiscount<br/>minOrderAmount·target·totalQuantity·enabled"] --> LOAD{"loadFailure"}
    LOAD -->|"'not-found'"| LNF["'쿠폰을 찾을 수 없습니다.'<br/>[목록으로]만"]
    LOAD -->|"'error'"| LER["'쿠폰을 불러오지 못했습니다.'<br/>[다시 시도] · [목록으로]"]
    LOAD -->|"정상"| EDIT["입력 · isDirty"]
    LER --> EDIT
    EDIT --> COND{"issueType 조건부 필드"}
    COND -->|"'free_shipping'"| C1["discountValue 숨김 · 할인 검증 생략"]
    COND -->|"'percent'"| C2["'할인율 (%)' + maxDiscount 노출<br/>힌트 '0 이면 상한 없음'"]
    COND -->|"'amount'"| C3["'할인 금액 (원)'"]
    C1 --> RANGE
    C2 --> RANGE
    C3 --> RANGE
    RANGE["DateRangeField 사용 기간<br/>startAt·endAt setValue(shouldDirty)<br/>totalQuantity 힌트 '0 이면 무제한'"] --> LEAVE{"이탈 시도<br/>useUnsavedChangesDialog"}
    LEAVE -->|"머무르기"| EDIT
    LEAVE -->|"나가기"| START
    RANGE --> SUBMIT["submit · submitLockRef"]
  end

  subgraph SUB2["검증 · 저장"]
    SUBMIT --> ZOD{"couponSchema (필드 + .check 2종)"}
    ZOD -->|"필드 실패"| ZERR["'쿠폰명을 입력하세요.'<br/>'쿠폰 코드는 영문·숫자·하이픈만 사용할 수 있습니다.'<br/>'발급 수량은 숫자만 입력할 수 있습니다.'<br/>※ 코드 중복 검사 없음"]
    ZOD -->|"할인 .check 실패"| DERR["'할인값은 숫자만 입력할 수 있습니다.'<br/>'할인율은 1% 이상 100% 이하로 입력하세요.'<br/>path ['discountValue']"]
    ZOD -->|"기간 .check 실패"| PERR["'사용 기간을 YYYY-MM-DD 형식으로 입력하세요.' (startAt)<br/>'종료일은 시작일보다 빠를 수 없습니다.' (endAt)<br/>※ totalQuantity >= issuedCount 검사는 없음"]
    ZERR --> EDIT
    DERR --> EDIT
    PERR --> EDIT
    ZOD -->|"통과"| MUT["toInput: code.trim().toUpperCase()<br/>free_shipping 이면 discountValue=0<br/>useCrudCreate / useCrudUpdate"]
    MUT --> RES{"결과"}
    RES -->|"성공"| OK["toast '쿠폰을 등록/저장했습니다.'<br/>invalidate list(+detail)<br/>navigate('/products/coupons', replace)"]
    RES -->|"409"| CONF["FormConflictDialog reload / dismiss"]
    RES -->|"422"| F422["setError(violation.field) + setFocus"]
    RES -->|"그 외"| F500["FormServerError + errorReference"]
    CONF --> EDIT
    F422 --> EDIT
    F500 --> EDIT
  end

  OK --> START

