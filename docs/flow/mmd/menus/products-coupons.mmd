  ST -->|"refreshing"| REF["행 유지 · ' · 새로고침 중…'"]
  ST -->|"error !== null"| ERR1["Alert danger<br/>'쿠폰 목록을 불러오지 못했습니다.'<br/>[다시 시도]"]
  ST -->|"성공"| LIST["CrudListShell<br/>쿠폰명·코드·할인·사용기간·소진율·상태·발급<br/>couponStatus(item, today) → 예정/진행중/만료/중지"]

  ERR1 --> Q
  SKEL --> LIST
  REF --> LIST

  LIST --> EMPTY{"visible.length === 0"}
  EMPTY -->|"예"| EMP["Empty<br/>hasQuery → [검색 지우기]<br/>hasActiveFilters → [필터 초기화]"]
  EMPTY -->|"아니오"| ROWS["행 렌더 · discountLabel · usageRate<br/>'무제한' 또는 'issued/total (N%)'"]

  ROWS --> ACT{"액션 선택"}
  ACT -->|"쿠폰 등록 · canCreate"| FORM
  ACT -->|"연필 · canUpdate"| FORM
  ACT -->|"휴지통·일괄 · canRemove"| DEL
  ACT -->|"발급 토글"| TOG

  TOG["useCrudRowUpdate.run<br/>{...toCouponInput(item), enabled: next}"] --> TOGR{"결과"}
  TOGR -->|"성공"| TOGOK["toast '발급중으로 바꿨습니다' / '발급을 중지했습니다'"]
  TOGR -->|"실패"| TOGER["toast '변경하지 못했습니다.'"]
  TOGOK --> Q
  TOGER --> LIST

  DEL["requestDelete / requestBulkDelete"] --> DLG{"ConfirmDialog intent=delete<br/>'쿠폰 삭제' / '쿠폰 일괄 삭제'"}
