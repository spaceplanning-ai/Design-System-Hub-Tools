%% 문의 (상품) · /products/inquiries
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  MENU{"메뉴는 조건부다 — nav-config 의 visibleWhen: 'pg-off'<br/>inquiryMenuState(settings, backlog)"} -->|"!pgSellable → 'open'"| M1["평소의 메뉴 — 문의가 지금도 들어온다"]
  MENU -->|"pgSellable && backlog === null"| M2["'archive' — **모르면 남긴다(fail-open)**<br/>라벨에 INQUIRY_ARCHIVE_SUFFIX ' · 읽기 전용'"]
  MENU -->|"pgSellable && total === 0"| M3["'hidden' — 사이드바에서 사라진다<br/>**라우트는 살아 있다** (URL 로는 여전히 열린다)"]
  MENU -->|"pgSellable && total &gt; 0"| M2
  M1 --> S
  M2 --> S
  M3 --> S

  S(["진입 /products/inquiries"]) --> URL["useListState({filterDefaults:{status:'all'}})<br/>status·keyword 를 URL 이 소유 (IA-13)<br/>parseFilter(INQUIRY_STATUS_FILTER_VALUES, 'all')"]
  URL --> Q["useCrudListQuery('product-inquiries', productInquiryAdapter)<br/>**CrudReadListShell** — 등록 폼 없음(고객이 만든다)<br/>삭제·일괄작업·선택 체크박스가 어떤 역할에게도 없다"]
  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도(refetch)"]
  ST -->|"성공 · 0건"| EMP["Empty createVerb='접수'<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  ST -->|"성공"| OK1["표 · 문의번호·상품명·문의자·제목·채널·상태·접수일·**경과**<br/>sortProductInquiries(접수 DESC · 동시각은 문의번호)<br/>중심 열은 상품도 제목도 아니고 '얼마나 오래 답을 못 받았나' 다"]
  E1 --> Q
  L --> OK1

  Q --> STS["상태 5종 InquiryStatus — 되돌아가는 전이 없음<br/>received 접수(warning) → answering 답변 중(info)<br/>→ quote_issued 견적 발행(info) → answered 답변 완료(success) → closed 종결(neutral)<br/>어휘는 영업 문의에서 **빌려 왔다** — 새로 지으면 건수가 영원히 안 합쳐진다"]
  STS --> RAIL["FilterRail — '답변을 기다리는 문의가 N건 있습니다.' unansweredCount<br/>isUnanswered = received | answering (견적 발행은 미답변이 아니다)<br/>FilterPanel '처리 상태' · countInquiriesByStatus (필터 이전 전체 · 못 셌으면 null → '—')"]
  RAIL --> ELAP["경과 배지 — 색만으로 말하지 않고 문구를 함께 싣는다<br/>elapsedLabel(item, TODAY='2026-07-21' 상수)<br/>'오늘 접수' / 'N일째 미답변' / '당일 답변' / 'N일 만에 답변' / '견적 발행' / '—'<br/>OVERDUE_DAYS 3 이상이면 danger"]
  ELAP --> APPLY["searchProductInquiries(filterInquiriesByStatus(items, status), keyword)<br/>검색 대상: 문의번호·상품명·문의자·제목"]
  APPLY --> OK1
  OK1 --> DET(["행 클릭(rowTarget kind='detail') · DetailCellLink(제목)<br/>→ /products/inquiries/:id"])

  GATE{"quoteIssueBlock(candidates) — **버튼과 저장이 같은 술어**<br/>candidate = toQuoteIssueCandidate: {id, quoteId, issuable: canIssueQuote(status)}<br/>목록의 바구니와 상세의 [견적 발행] 이 이 하나를 함께 읽는다"}
  GATE -->|"candidates.length === 0"| G1["QUOTE_ISSUE_EMPTY '견적을 발행할 문의를 한 건 이상 선택하세요.'"]
  GATE -->|"some(hasIssuedQuote) — quoteId !== ''"| G2["QUOTE_ISSUE_ALREADY '이미 견적이 발행된 문의가 있습니다. 발행된 견적을 여세요.'<br/>**quoteId 가 멱등키다**"]
  GATE -->|"some(!issuable) — status === 'closed'"| G3["QUOTE_ISSUE_NOT_ISSUABLE '종결된 문의는 견적을 발행할 수 없습니다.'<br/>(canIssueQuote 는 종결만 막는다 — 답변 뒤 '그럼 견적 주세요' 는 흔하다)"]
  GATE -->|"!isQuoteIssuerWired()"| G4["QUOTE_ISSUE_UNWIRED '견적 발행을 사용할 수 없습니다. 관리자에게 문의하세요.'<br/>미배선을 조용히 통과시키지 않는다 — 반응 없는 버튼을 다시 누르게 된다"]
  GATE -->|"null"| ISSUE["issueQuote(sources) — sources = toQuoteIssueSource(...)<br/>channel:'product' · accountLabel = 문의자 이름(개인 고객이라 회사명이 없다)<br/>itemName = 상품명 → 견적의 첫 품목 · 여러 건이면 **한 견적으로 합쳐진다**<br/>배선은 src/wiring.ts 가 꽂는다 (pages/products → pages/sales import 금지)"]
  G1 --> GX["막대·버튼 자리에 사유를 그대로 · disabled"]
  G2 --> GX
  G3 --> GX
  G4 --> GX

  SUB1 ~~~ SUB2

  subgraph SUB1["견적 바구니 — 목록 (canUpdate 에만 있는 열)"]
    OK1 --> BSK{"item.quoteId !== '' ?"}
    BSK -->|"예"| BQ["'견적 보기' → issuedQuoteHref(quoteId) = /sales/quotes/:id"]
    BSK -->|"아니오"| BT["[담기] / [담김] 토글 (aria-pressed)<br/>CrudReadListShell 의 선택이 아니다 — 그건 일괄 삭제용이고<br/>여기 필요한 것은 지우는 선택이 아니라 **담는** 선택이다"]
    BT --> BCLR["useEffect: status·keyword 가 바뀌면 setBasket(new Set())<br/>화면에 없는 문의가 담긴 채 '선택 3건 견적 발행' 이 되지 않게 (STATE-04-b)"]
    BCLR --> BAR["담은 것이 있을 때만 나타나는 Alert info 막대<br/>[비우기] · [견적 발행]"]
    BAR --> GATE
  end

  subgraph SUB2["상세 · /products/inquiries/:id"]
    DET --> DQ["useQuery ['product-inquiries','detail',id] → adapter.fetchOne"]
    DQ --> DERR{"detailQuery.error (EXC-12)"}
    DERR -->|"isNotFound"| DNF["'문의를 찾을 수 없습니다. 이미 삭제되었을 수 있습니다.'<br/>[목록으로]만"]
    DERR -->|"그 외"| DER["'문의를 불러오지 못했습니다.' [다시 시도] · [목록으로]"]
    DERR -->|"undefined"| DL["'불러오는 중…' 카드"]
    DERR -->|"정상"| VIEW["제목 + 상태 배지 + 채널 배지 + 경과 배지<br/>dl: 문의번호·상품·접수일시·답변일시·문의 내용(pre-wrap)·**발행 견적**<br/>quoteId==='' 면 '아직 발행된 견적이 없습니다.' 아니면 '견적 보기' 링크<br/>처리 이력 Timeline — inquiryHistory 는 **저장된 사실에서 파생**한다<br/>(별도 로그를 쌓으면 답변을 고쳤을 때 갈라진다)"]
    DL --> VIEW

    VIEW --> CA{"canAnswer(status) = status !== 'closed'"}
    CA -->|"아니오"| CLOSED["'발송한 답변' 읽기 표시<br/>'종결된 문의라 답변을 수정할 수 없습니다.'"]
    CA -->|"예"| FORM["TextareaField 라벨은 answer==='' 면 '답변 작성' 아니면 '답변 수정'<br/>hint '저장하면 상태가 답변 완료 로 넘어갑니다.'<br/>PRODUCT_INQUIRY_ANSWER_MAX 1000"]
    FORM --> AV{"onSaveAnswer → answerError(answer) (zod 정본)"}
    AV -->|"공백만"| AV1["'답변 내용을 입력하세요.' — 필드 인라인<br/>빈 답변이 '답변 완료' 로 넘어가면 고객은 아무것도 못 받는다"]
    AV -->|"1000자 초과"| AV2["'답변은 1000자를 넘을 수 없습니다.'"]
    AV -->|"통과"| AOK["applyAnswer — 본문·answeredAt·status 를 **함께** 옮긴다<br/>answeredAt 은 **최초 답변 시각**이라 재수정에서 바뀌지 않는다<br/>(오탈자를 고칠 때마다 갱신되면 응대 속도가 사후에 조작된다)<br/>저장소도 같은 함수로 막는다 — ANSWER_ON_CLOSED_ERROR · EMPTY_ANSWER_ERROR"]

    VIEW --> ACT["액션 — 누를 수 없는 것을 보여 주지 않는다 (EXC-03)"]
    ACT --> A1{"canBeginAnswering = status === 'received'"}
    A1 -->|"예"| B1["[답변 착수] → applyBeginAnswering<br/>위반 시 BEGIN_ANSWERING_ERROR '접수 상태의 문의만 답변 착수로 바꿀 수 있습니다.'"]
    ACT --> A2{"canClose = status === 'answered'"}
    A2 -->|"예"| B2["[문의 종결] → applyClose<br/>위반 시 CLOSE_UNANSWERED_ERROR '답변하지 않은 문의는 종결할 수 없습니다.'"]
    ACT --> A3["[견적 발행] — issueBlock === null 일 때만 존재"]
    A3 --> GATE
    VIEW --> PERM{"canUpdate"}
    PERM -->|"아니오"| NOPERM["Alert info '이 문의에 답변할 권한이 없습니다. 조회만 가능합니다.'<br/>목록 좌측 안내도 '답변 권한이 없어 조회만 가능합니다.'"]
  end

  ISSUE --> CROSS["견적 저장소가 **findQuoteBySource 로 한 번 더 교차 확인**(이중 방어)<br/>이미 있으면 새로 만들지 않고 그 견적을 돌려준다"]
  CROSS --> MARK["applyQuoteIssued(inquiry, issued.id) — quoteId 와 status 가 함께 옮겨 간다<br/>이미 발행된 문의는 그대로 돌려준다(멱등)<br/>QUOTE_ISSUE_ON_CLOSED_ERROR '종결된 문의는 견적을 발행할 수 없습니다.'<br/>합친 문의는 **모두 같은 견적 id** — 하나라도 빠지면 그 문의는 견적 없이 남는다"]
  MARK --> COMMIT
  AOK --> COMMIT["commit(next, message) — 저장의 단일 경로<br/>답변도 상태 전환도 '다음 문의 한 벌' 을 통째로 보낸다<br/>useCrudUpdate.mutate(toProductInquiryInput(next))"]
  B1 --> COMMIT
  B2 --> COMMIT

  COMMIT --> RES{"결과"}
  RES -->|"성공 (상세)"| MOK["toast '답변을 저장하고 답변 완료로 변경했습니다.' / '답변을 수정했습니다.' /<br/>'답변 중으로 변경했습니다.' / '문의를 종결했습니다.' /<br/>'견적 Q-…을(를) 발행했습니다.'(objectParticle 로 조사 계산)<br/>detailQuery.refetch()"]
  RES -->|"성공 (목록 바구니)"| BOK["invalidateQueries([RESOURCE,'list']) · setBasket(new Set())<br/>toast + navigate(issuedQuoteHref(issued.id))"]
  RES -->|"실패"| ME["serverError '저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>목록 쪽은 toast.error '견적을 발행하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
  RES -->|"isAbort"| AB["무시"]
  ME --> COMMIT
  MOK --> DQ
  BOK --> Q

  VIEW --> UNS["useUnsavedChangesDialog(dirty && !saving)<br/>dirty = answer.trim() !== inquiry.answer"]
  UNS --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class MENU,ST,BSK,DERR,CA,AV,A1,A2,PERM,GATE,RES gate
  class E1,EMP,DNF,DER,CLOSED,AV1,AV2,G1,G2,G3,G4,GX,NOPERM,ME,M3 err
  class OK1,MOK,BOK,ISSUE,AOK ok
