%% 상품 · /products
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  START(["진입 · /products"]) --> URL["useListState (IA-13 URL 쿼리스트링)<br/>?category= · ?status= · ?q=<br/>기본값과 같으면 URL 에서 제거 · replace 이동"]
  URL --> PERM{"useRouteWritePermissions"}
  PERM --> Q["useCrudListQuery ['products','list']<br/>+ categoriesQuery ['products','category-options']"]

  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| SKEL["스켈레톤 · '불러오는 중…'"]
  ST -->|"refreshing"| REF["행 유지 · ' · 새로고침 중…'"]
  ST -->|"error !== null"| ERR1["Alert danger<br/>'상품 목록을 불러오지 못했습니다.'<br/>[다시 시도]"]
  ST -->|"성공"| LIST["CrudListShell<br/>상품명·SKU·카테고리·판매가·재고·전시·판매상태"]

  ERR1 --> Q
  SKEL --> LIST
  REF --> LIST

  LIST --> FILT["ProductFilterPanel 좌측 2축<br/>category · status(parseFilter, SALE_STATUS_FILTER_VALUES)<br/>SearchField q (IME 안전 COMP-10)<br/>배지 countProductsByCategory / countProductsBySaleStatus"]
  FILT --> APPLY["searchProducts(filterBySaleStatus(filterProducts(items, category), status), keyword)<br/>list.setFilter → resetPage:true · clear() 선택 해제"]
  APPLY --> EMPTY{"visible.length === 0"}
  EMPTY -->|"예"| EMP["Empty<br/>hasQuery → [검색 지우기]<br/>hasActiveFilters → [필터 초기화]<br/>createAction"]
  EMPTY -->|"아니오"| ROWS["행 렌더<br/>finalPrice · totalStock · isLowStock '부족' · '품절'"]

  ROWS --> ACT{"액션 선택"}
  ACT -->|"상품 등록 · canCreate"| FORM
  ACT -->|"연필 · canUpdate"| FORM
  ACT -->|"휴지통·일괄 · canRemove"| DEL
  ACT -->|"전시 토글"| TOG

  TOG["useCrudRowUpdate.run(displayed: next)"] --> TOGR{"결과"}
  TOGR -->|"성공"| TOGOK["toast '전시했습니다' / '숨겼습니다'"]
  TOGR -->|"실패"| TOGER["toast '변경하지 못했습니다.'"]
  TOGOK --> Q
  TOGER --> LIST

  DEL["requestDelete / requestBulkDelete"] --> DLG{"ConfirmDialog intent=delete<br/>'상품 삭제' / '상품 일괄 삭제'"}
  DLG -->|"취소"| LIST
  DLG -->|"확인"| DELM["useCrudDelete / useCrudBulkDelete"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast 삭제 완료 · invalidate ['products','list']"]
  DELR -->|"실패"| DELER["deleteErrorMessage(409 원문)<br/>bulkDeleteErrorMessage · 다이얼로그 유지"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 · /products/new · /products/:id/edit"]
    FORM["FormPageShell · SECTIONS 7구획 + FormSectionNav<br/>기본정보/가격·할인/적립금/옵션·재고/배송/이미지/상세설명<br/>useActiveSection · invalid 구획 표시<br/>우측 ProductCardPreview 실시간"] --> LOAD{"loadFailure"}
    LOAD -->|"'not-found'"| LNF["'상품을 찾을 수 없습니다.'<br/>[목록으로]만"]
    LOAD -->|"'error'"| LER["'상품을 불러오지 못했습니다.'<br/>[다시 시도] · [목록으로]"]
    LOAD -->|"정상"| EDIT["입력 · isDirty"]
    LER --> EDIT
    EDIT --> MATRIX["ProductOptionMatrix<br/>addGroup 게이트 MAX_OPTION_GROUPS=3<br/>regenerate → buildVariantMatrix(groups, variants, code)<br/>기존 조합은 id·sku·stock 보존"]
    MATRIX --> EDIT
    EDIT --> LEAVE{"이탈 시도<br/>useUnsavedChangesDialog"}
    LEAVE -->|"머무르기"| EDIT
    LEAVE -->|"나가기"| START
    EDIT --> SUBMIT["submit · submitLockRef"]
  end

  subgraph SUB2["검증 · 저장"]
    SUBMIT --> ZOD{"productSchema (필드 + .check 3종)"}
    ZOD -->|"필드 실패"| ZERR["'상품명을 입력하세요.' · '카테고리를 선택하세요.'<br/>'옵션/재고를 한 줄 이상 구성하세요.'<br/>'SKU 코드가 중복되었습니다…'<br/>'재고는 0 이상 999999 이하로 입력하세요.'"]
    ZOD -->|"교차 검증 실패"| XERR["할인: '할인율은 1% 이상 100% 이하로…'<br/>'할인 금액은 1원 이상 판매가 미만으로…'<br/>적립: points.rate / points.amount<br/>배송: shipping.fee / shipping.freeThreshold"]
    ZERR --> EDIT
    XERR --> EDIT
    ZOD -->|"통과"| MUT["toInput 정규화(미사용 축 0 처리)<br/>takeIdempotencyKey · useCrudCreate/Update"]
    MUT --> RES{"결과"}
    RES -->|"성공"| OK["toast '상품을 등록/저장했습니다.'<br/>invalidate list(+detail)<br/>navigate('/products', replace)"]
    RES -->|"409"| CONF["FormConflictDialog reload / dismiss"]
    RES -->|"422"| F422["setError(violation.field) + setFocus"]
    RES -->|"그 외"| F500["FormServerError + errorReference"]
    CONF --> EDIT
    F422 --> EDIT
    F500 --> EDIT
  end

  OK --> START

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class PERM,ST,EMPTY,ACT,DLG,LOAD,LEAVE,ZOD,RES,TOGR,DELR gate
