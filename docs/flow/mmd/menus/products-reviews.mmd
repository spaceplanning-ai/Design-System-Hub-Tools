%% 리뷰 · /products/reviews
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  START(["진입 · /products/reviews"]) --> URL["useListState (IA-13 URL 쿼리스트링)<br/>?rating=all|1|2|3|4|5<br/>?q= (상품명·작성자, IME 안전 COMP-10)<br/>toRatingFilter: 숫자 섞인 유니온이라 parseFilter 대신<br/>RATING_FILTER_OPTIONS 에서 id 조회 → 미지값은 'all'"]
  URL --> Q["useCrudList ['reviews','list']<br/>sortReviews(작성일 DESC)"]

  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| SKEL["스켈레톤 · '불러오는 중…'"]
  ST -->|"refreshing"| REF["행 유지 · ' · 새로고침 중…'"]
  ST -->|"error !== null"| ERR1["Alert danger<br/>'리뷰 목록을 불러오지 못했습니다.'<br/>[다시 시도]"]
  ST -->|"성공"| LIST["CrudListShell<br/>상품명·작성자·별점·내용·표시·작성일·노출<br/>※ 상태 enum 없음 — boolean visible/reported"]

  ERR1 --> Q
  SKEL --> LIST
  REF --> LIST

  LIST --> APPLY["searchReviews(filterByRating(items, filter), keyword)<br/>useEffect → clear() 선택 해제<br/>표시 배지: isPhotoReview→'포토' · reply≠''→'답변' · reported→'신고'"]
  APPLY --> EMPTY{"visible.length === 0"}
  EMPTY -->|"예"| EMP["Empty<br/>hasQuery → [검색 지우기]<br/>hasActiveFilters → [필터 초기화]"]
  EMPTY -->|"아니오"| ROWS["행 렌더 · starText(rating)<br/>aria-label '5점 만점에 N점'"]

  ROWS --> ACT{"액션 선택"}
  ACT -->|"연필 → 상세"| DETAIL
  ACT -->|"휴지통·일괄 · canRemove"| DEL
  ACT -->|"노출 인라인 토글"| TOG

  TOG["useCrudRowUpdate.run(item.id,<br/>{...toReviewInput(item), visible: next})<br/>busy = toggle.pendingId === item.id<br/>※ 검증·확인 게이트 없음 — 즉시 mutation"] --> TOGR{"결과"}
  TOGR -->|"성공"| TOGOK["toast '{상품명} 리뷰를 노출했습니다.'<br/>/ '…숨겼습니다.'"]
  TOGR -->|"실패"| TOGER["toast '변경하지 못했습니다.'<br/>토글 원상 복귀"]
  TOGOK --> Q
  TOGER --> LIST

  DEL["requestDelete / requestBulkDelete"] --> DLG{"ConfirmDialog intent=delete"}
  DLG -->|"취소"| LIST
  DLG -->|"확인"| DELM["useCrudDelete / useCrudBulkDelete"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast 삭제 완료 · invalidate ['reviews','list']"]
  DELR -->|"실패"| DELER["deleteErrorMessage · 다이얼로그 유지"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 · /products/reviews/:id"]
    DETAIL["ReviewDetailPage<br/>detailQuery ['reviews','detail',id]<br/>좌: 리뷰 정보 · 우: 고객 화면 미리보기"] --> DERR{"detailQuery.error"}
    DERR -->|"에러"| DNF["Alert danger '리뷰를 불러오지 못했습니다.'<br/>[목록으로]"]
    DERR -->|"로딩"| DL["'불러오는 중…'"]
    DERR -->|"정상"| META["dl: 상품·작성자·별점·작성일<br/>reported → Alert warning<br/>'신고 접수됨 — {reportReason 또는 사유 미기재}'"]
    DL --> META
    META --> EDITF["ToggleSwitch visible '노출'/'숨김' (boolean)<br/>TextareaField reply (REVIEW_REPLY_MAX 500)<br/>ReviewPreview 가 reply·visible 실시간 반영"]
    EDITF --> DIRTY{"dirty = reply !== review.reply<br/>|| visible !== review.visible"}
    DIRTY -->|"false"| IDLE["저장 버튼 disabled(saving || !dirty)"]
    DIRTY -->|"true"| READY["저장 버튼 활성 · '저장 중…' / '저장'"]
    IDLE --> EDITF
    READY --> LEAVE{"이탈 시도<br/>useUnsavedChangesDialog(dirty && !saving)<br/>'리뷰에 저장하지 않은 변경 사항이 있습니다.'"}
    LEAVE -->|"머무르기"| READY
    LEAVE -->|"나가기"| START
  end

  subgraph SUB2["저장 · 삭제 (상세)"]
    READY --> SAVE["onSave → AbortController<br/>update.mutate({id, input:{...toReviewInput(review),<br/>reply: reply.trim(), visible}, signal})<br/>※ zod 스키마 없음 — maxLength 만 제약"]
    SAVE --> RES{"결과"}
    RES -->|"성공"| OK["toast '리뷰를 저장했습니다.'<br/>detailQuery.refetch() · 화면 유지"]
    RES -->|"isAbort"| ABORT["무시"]
    RES -->|"그 외"| SERR["setServerError Alert danger<br/>'저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
    SERR --> READY

    META --> DDEL["[리뷰 삭제] danger 버튼"]
    DDEL --> DDLG{"ConfirmDialog intent=delete<br/>'리뷰 삭제' · confirmLabel '리뷰 삭제'<br/>'{상품명} 리뷰를 삭제합니다. 되돌릴 수 없습니다.'"}
    DDLG -->|"취소 closeDelete (abort + reset)"| META
    DDLG -->|"확인 onConfirmDelete"| DREM["remove.mutate({id, signal})"]
    DREM --> DRES{"결과"}
    DRES -->|"성공"| DOK["toast '리뷰를 삭제했습니다.'<br/>navigate('/products/reviews', replace)"]
    DRES -->|"실패"| DERR2["setDeleteError '삭제하지 못했습니다…'<br/>다이얼로그 유지"]
    DERR2 --> DDLG
  end

  OK --> DETAIL
  ABORT --> DETAIL
  DOK --> START

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,EMPTY,ACT,DLG,DERR,DIRTY,LEAVE,RES,DDLG,DRES,TOGR,DELR gate
  class ERR1,EMP,DNF,SERR,DERR2,DELER,TOGER err
  class OK,DOK,DELOK,TOGOK ok
