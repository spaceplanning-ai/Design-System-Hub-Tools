%% 카테고리 (프로그램) · /programs/categories
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /programs/categories"]) --> URL["useListState({filterDefaults:{usage:'all'}})<br/>usage 를 URL 이 소유 (IA-13)<br/>parseFilter(USAGE_FILTER_VALUES, 'all') — 손편집 URL 은 '전체' 로"]
  URL --> Q["useCrudListQuery('program-categories', programCategoryAdapter)<br/>list = listProgramCategoryUsage — 항목마다 programCount·hasChildren 을 함께 든다<br/>(삭제 차단 판정과 배지가 같은 값을 읽는다)"]
  Q --> ST{"조회 상태"}
  ST -->|"firstLoading = isFetching && data===undefined"| L["'불러오는 중…' (STATE-01)<br/>재조회 중에는 이전 행을 유지한다 (STATE-03)"]
  ST -->|"error !== null"| E1["Alert danger '카테고리를 불러오지 못했습니다.'<br/>[다시 시도] → refetch"]
  ST -->|"성공 · visible.length === 0"| EMP["Empty — 필터 초기화 / 추가 CTA (STATE-05)"]
  ST -->|"성공"| OK1["2단계 트리 목록 — 대분류(1Depth) 아래 중분류(2Depth)를 들여쓴다<br/>toolbar: '전체 N개' + [카테고리 추가](canCreate 일 때만 · EXC-03)"]
  E1 --> Q
  L --> OK1

  Q --> FLT["FilterRail · FilterPanel '사용 여부'<br/>USAGE_FILTERS 전체 / 사용 중(programCount &gt; 0) / 미사용<br/>countCategoriesByUsage — 키를 빠짐없이 적은 Record<br/>이 화면의 핵심 제약이 '사용 중은 못 지운다' 라<br/>정리하려는 운영자는 '지울 수 있는 것만 보기' 를 먼저 원한다"]
  FLT --> TREE["filterCategoriesByUsage → tree<br/>**필터에 걸린 중분류의 부모는 화면에 남긴다**<br/>부모가 사라지면 자식이 어디 소속인지 알 수 없다(계층이 곧 정보다)"]
  TREE --> OK1

  OK1 --> ROW["CategoryRow — 라벨 + 사용 배지 + '하위 N개' 배지 + 액션 3개"]
  ROW --> BADGE{"inUse = programCount &gt; 0"}
  BADGE -->|"예"| B1["categoryUsageLabel 'N개 프로그램' 을 **링크**로<br/>→ /programs?category=:id (그 카테고리로 이미 걸러진 목록)<br/>목록의 카테고리 필터는 롤업이라 대분류를 열면 중분류까지 함께 보인다 —<br/>배지 숫자(직접 배정분)보다 넓을 수 있고, 그것이 맞다"]
  BADGE -->|"아니오"| B2["'미사용' StatusBadge neutral — **링크로 만들지 않는다**<br/>열어 봐야 빈 목록이다"]
  ROW --> DISC{"togglable = 대분류 && childCount &gt; 0"}
  DISC -->|"예"| D1["펼침 토글 aria-expanded/aria-controls<br/>기본은 전부 펼침(숨겨진 정보 없이 시작한다) · collapsed Set 으로 접는다"]
  DISC -->|"아니오"| D2["disclosureSpacer — 토글이 없는 행도 라벨 시작점을 맞춘다"]

  SUB1 ~~~ SUB2

  subgraph SUB1["추가 · 수정 — ProgramCategoryFormModal"]
    ROW --> M1["[+] 하위 카테고리 추가 — **대분류 행에만** (2단계 제한)<br/>modal = {kind:'create', parentId: parent.id}"]
    ROW --> M2["[연필] 수정 — modal = {kind:'edit', category}"]
    OK1 --> M3["[카테고리 추가] — modal = {kind:'create', parentId:null}"]
    M1 --> FORM
    M2 --> FORM
    M3 --> FORM["useForm(zodResolver(programCategorySchema))<br/>상위 선택지는 **1Depth 뿐** — listProgramCategoryRoots()<br/>수정 중이면 자기 자신을 후보에서 뺀다(자기 밑으로 들어갈 수 없다)"]
    FORM --> LOCK{"parentLocked = isEdit && editing.hasChildren"}
    LOCK -->|"true"| LK["상위 셀렉트 자체를 disabled<br/>하위를 이미 가진 대분류는 다른 대분류 밑으로 옮길 수 없다<br/>(저장소도 같은 규칙: '하위 카테고리가 있는 카테고리는<br/>다른 카테고리 밑으로 옮길 수 없습니다.')"]
    LOCK -->|"false"| FREE["'없음 (대분류)' + 1Depth 목록"]
    LK --> FV
    FREE --> FV{"programCategorySchema"}
    FV -->|"name 공백/길이"| FV1["requiredText('카테고리 이름', PROGRAM_CATEGORY_NAME_MAX 40)<br/>필드 인라인 + aria-describedby=errorIdOf (A11Y-11)"]
    FV -->|"통과"| FS["parentId === '' 이면 **null** 로 바꿔 저장소에 넘긴다(최상위)<br/>create.mutate / update.mutate"]
    FS --> STORE{"저장소 가드 — assertAssignableParent"}
    STORE -->|"parentId === selfId"| SG1["'자기 자신을 상위 카테고리로 지정할 수 없습니다.'"]
    STORE -->|"부모 없음"| SG2["'상위 카테고리를 찾을 수 없습니다.'"]
    STORE -->|"부모가 이미 2Depth"| SG3["'카테고리는 2단계까지만 만들 수 있습니다.'<br/>3단계를 만들지 않는다"]
    STORE -->|"통과"| SOK["저장 · 수정이면 그 카테고리를 쓰는 프로그램의<br/>categoryLabel 비정규화 값도 함께 갱신한다"]
    SG1 --> FE["serverError '저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>모달은 닫히지 않는다"]
    SG2 --> FE
    SG3 --> FE
    FE --> FORM
    SOK --> TOK["모달 닫힘 + toast<br/>수정: ''…' 카테고리를 저장했습니다.'<br/>추가: ''…' 카테고리를 추가했습니다.'"]
    FORM --> MG["useModalDirtyGuard(isDirty && !saving, onClose)<br/>requestClose 를 Modal.onClose 와 취소 버튼에 **둘 다** 넘겨<br/>4경로(Esc·딤·×·취소)를 한 번에 덮는다 (FEEDBACK-06)"]
  end

  subgraph SUB2["삭제 — 두 가지 차단 사유"]
    ROW --> DEL{"blockReason (휴지통 버튼)"}
    DEL -->|"inUse"| DB1["disabled + title 'N개 프로그램 — 삭제할 수 없습니다'<br/>aria-label '… — N개 프로그램이라 삭제할 수 없습니다'<br/>저장소도 막는다: '사용 중인 카테고리는 삭제할 수 없습니다.'"]
    DEL -->|"hasChildren"| DB2["disabled + '하위 카테고리 있음 — 삭제할 수 없습니다'<br/>저장소: '하위 카테고리가 있는 카테고리는 삭제할 수 없습니다.'"]
    DEL -->|"null"| DOK["danger ghost 활성 → setPendingDelete(target)"]
    DOK --> DC{"ConfirmDialog intent='delete'<br/>''…' 카테고리를 삭제합니다. 이 작업은 되돌릴 수 없습니다.'"}
    DC -->|"취소"| DX["closeDelete — controller.abort() + deleteCategory.reset()"]
    DC -->|"[카테고리 삭제]"| DR["useCrudDelete.mutate({id, signal})"]
    DR --> DRES{"결과"}
    DRES -->|"성공"| DSOK["다이얼로그 닫힘 + toast ''…' 카테고리를 삭제했습니다.'"]
    DRES -->|"실패"| DERR["deleteError '삭제하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>다이얼로그 안 배너 — **닫히지 않는다** · 재클릭이 재시도"]
    DRES -->|"isAbort"| DAB["무시"]
    DERR --> DR
    DX --> OK1
  end

  TOK --> Q
  DSOK --> Q
  OK1 --> HINT["하단 안내 — 규칙을 화면이 스스로 밝힌다<br/>'사용 중인 카테고리는 삭제할 수 없습니다 — 건수 배지를 누르면 그 카테고리로<br/>걸러진 프로그램 목록이 열립니다(대분류는 아래 중분류까지 함께 보입니다).<br/>거기서 카테고리를 바꾸거나 삭제하세요.'"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,BADGE,DISC,LOCK,FV,STORE,DEL,DC,DRES gate
  class E1,EMP,B2,LK,FV1,SG1,SG2,SG3,FE,DB1,DB2,DERR err
  class OK1,B1,SOK,TOK,DSOK ok
