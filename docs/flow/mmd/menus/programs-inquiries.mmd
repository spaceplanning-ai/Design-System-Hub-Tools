%% 문의 (프로그램) · /programs/inquiries
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  MENU{"메뉴는 조건부다 — nav-config 의 visibleWhen: 'pg-off'<br/>inquiryMenuState(settings, backlog)"} -->|"!pgSellable → 'open'"| M1["평소의 메뉴 — 문의가 지금도 들어온다"]
  MENU -->|"pgSellable && (backlog === null || total &gt; 0)"| M2["'archive' — 배선을 모르면 남긴다(fail-open)<br/>라벨에 INQUIRY_ARCHIVE_SUFFIX ' · 읽기 전용'"]
  MENU -->|"pgSellable && total === 0"| M3["'hidden' — 사이드바에서 사라진다<br/>**라우트는 살아 있다**"]
  M1 --> S
  M2 --> S
  M3 --> S

  S(["진입 /programs/inquiries"]) --> URL["useListState({filterDefaults:{status:'all', topic:'all'}})<br/>status·topic·keyword 를 URL 이 소유 (IA-13)<br/>parseFilter × 2 (STATUS_FILTER_VALUES / TOPIC_FILTER_VALUES)"]
  URL --> Q["useCrudListQuery('program-inquiries', programInquiryAdapter)<br/>**CrudReadListShell** — 등록 폼 없음(후원자가 만든다)<br/>삭제·일괄작업·선택 체크박스가 어떤 역할에게도 없다"]
  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도(refetch)"]
  ST -->|"성공 · 0건"| EMP["Empty createVerb='접수'<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  ST -->|"성공"| OK1["표 · 문의번호·프로그램명·문의자·제목·**유형**·채널·상태·접수일·경과<br/>sortProgramInquiries(접수 DESC · 동시각은 문의번호)"]
  E1 --> Q
  L --> OK1

  Q --> AX["**두 축이다 — 상품 문의에 없는 topic 이 하나 더 있다**<br/>ProgramInquiryStatus 5종: received 접수 · answering 답변 중<br/>· quote_issued 견적 발행 · answered 답변 완료 · closed 종결<br/>ProgramInquiryTopic 5종: reward 리워드(info) · delivery 배송(info)<br/>· refund 환불(warning) · payment 결제(warning) · etc 기타(neutral)<br/>유형 축이 필요한 이유: 처리하는 사람이 다르다 —<br/>리워드·배송은 창작자 확인이 필요하고 환불·결제는 운영이 바로 답한다"]
  AX --> RAIL["FilterRail — '답변을 기다리는 문의가 N건 있습니다.'(unansweredCount)<br/>'결제대행을 끈 프로그램은 후원하기 대신 문의하기 버튼이 노출되고,<br/>그 문의가 이 목록으로 들어옵니다. **마감이 있는 펀딩이라 답변이 늦으면 후원이 사라집니다.**'<br/>FilterPanel 둘 — '처리 상태' · '문의 유형'<br/>건수는 각각 countProgramInquiriesByStatus / ByTopic (필터 이전 전체)"]
  RAIL --> ELAP["경과 배지 — OVERDUE_DAYS = **2** (상품 문의는 3)<br/>펀딩은 마감이 있는 판매라 답이 늦으면 후원 자체가 사라진다<br/>'오늘 접수' / 'N일째 미답변' / '당일 답변' / 'N일 만에 답변' / '견적 발행' / '—'<br/>TODAY='2026-07-21' 상수 — 화면이 new Date() 를 읽지 않는다"]
  ELAP --> APPLY["searchProgramInquiries(filterProgramInquiries(items, status, topic), keyword)<br/>filterProgramInquiries 는 **두 축을 한 번에** 건다<br/>(화면이 filter().filter() 로 순서를 만들지 않게)<br/>검색 대상: 문의번호·프로그램명·문의자·제목"]
  APPLY --> OK1
  OK1 --> DET(["행 클릭(rowTarget kind='detail') · DetailCellLink(제목)<br/>→ /programs/inquiries/:id"])

  GATE{"quoteIssueBlock(candidates) — **버튼과 저장이 같은 술어**<br/>candidate = toProgramQuoteIssueCandidate:<br/>{id, quoteId, issuable: canIssueProgramQuote(status)}<br/>목록의 바구니와 상세의 [견적 발행] 이 이 하나를 함께 읽는다"}
  GATE -->|"candidates.length === 0"| G1["QUOTE_ISSUE_EMPTY '견적을 발행할 문의를 한 건 이상 선택하세요.'"]
  GATE -->|"some(hasIssuedQuote) — quoteId !== ''"| G2["QUOTE_ISSUE_ALREADY '이미 견적이 발행된 문의가 있습니다. 발행된 견적을 여세요.'<br/>**quoteId 가 멱등키다**"]
  GATE -->|"some(!issuable) — status === 'closed'"| G3["QUOTE_ISSUE_NOT_ISSUABLE '종결된 문의는 견적을 발행할 수 없습니다.'"]
  GATE -->|"!isQuoteIssuerWired()"| G4["QUOTE_ISSUE_UNWIRED '견적 발행을 사용할 수 없습니다. 관리자에게 문의하세요.'<br/>미배선은 거절 사유로 드러난다 — 조용히 아무 일도 하지 않으면 다시 누르게 된다"]
  GATE -->|"null"| ISSUE["issueQuote(sources) — toProgramQuoteIssueSource<br/>channel:'program' · accountLabel = 문의자 이름 · itemName = 프로그램명<br/>여러 건이면 **한 견적으로 합쳐진다**(견적 바구니)<br/>배선은 src/wiring.ts 가 꽂는다 (pages/programs → pages/sales import 금지)"]
  G1 --> GX["막대·버튼 자리에 사유를 그대로 · disabled"]
  G2 --> GX
  G3 --> GX
  G4 --> GX

  SUB1 ~~~ SUB2

  subgraph SUB1["견적 바구니 — 목록 (canUpdate 에만 있는 열)"]
    OK1 --> BSK{"item.quoteId !== '' ?"}
    BSK -->|"예"| BQ["'견적 보기' → issuedQuoteHref(quoteId) = /sales/quotes/:id"]
    BSK -->|"아니오"| BT["[담기] / [담김] 토글 (aria-pressed)<br/>CrudReadListShell 의 선택은 일괄 삭제용이라 쓰지 않는다"]
    BT --> BCLR["useEffect: status·topic·keyword 가 바뀌면 setBasket(new Set()) (STATE-04-b)"]
    BCLR --> BAR["담은 것이 있을 때만 나타나는 Alert info 막대<br/>basketBlock === null 이면 '문의 N건을 한 견적으로 합칩니다.'<br/>아니면 그 사유를 그대로 · [비우기] · [견적 발행]"]
    BAR --> GATE
  end

  subgraph SUB2["상세 · /programs/inquiries/:id"]
    DET --> DQ["useQuery ['program-inquiries','detail',id] → adapter.fetchOne"]
    DQ --> DERR{"detailQuery.error (EXC-12)"}
    DERR -->|"isNotFound"| DNF["'문의를 찾을 수 없습니다. 이미 삭제되었을 수 있습니다.' [목록으로]만"]
    DERR -->|"그 외"| DER["'문의를 불러오지 못했습니다.' [다시 시도] · [목록으로]"]
    DERR -->|"undefined"| DL["'불러오는 중…' 카드"]
    DERR -->|"정상"| VIEW["제목 + 상태 배지 + 유형 배지 + 채널 배지 + 경과 배지<br/>dl: 문의번호·프로그램·접수일시·답변일시·문의 내용(pre-wrap)·**발행 견적**<br/>문의자 정보 카드에 **문의 유형** 줄이 따로 있다<br/>'답변은 위 연락처로 회신됩니다. 결제대행을 끈 프로그램은 후원하기 대신 문의하기 버튼이 노출됩니다.'<br/>처리 이력 Timeline — 저장된 사실에서 파생(별도 로그를 쌓지 않는다)"]
    DL --> VIEW

    VIEW --> CA{"canAnswerProgramInquiry(status) = status !== 'closed'"}
    CA -->|"아니오"| CLOSED["'발송한 답변' 읽기 표시<br/>'종결된 문의라 답변을 수정할 수 없습니다.'"]
    CA -->|"예"| FORM["TextareaField — answer==='' 면 '답변 작성' 아니면 '답변 수정'<br/>hint '저장하면 상태가 답변 완료 로 넘어갑니다.'<br/>PROGRAM_INQUIRY_ANSWER_MAX 1000"]
    FORM --> AV{"answerError(answer) — zod 정본"}
    AV -->|"공백만"| AV1["'답변 내용을 입력하세요.' (PROGRAM_EMPTY_ANSWER_ERROR)"]
    AV -->|"1000자 초과"| AV2["'답변은 1000자를 넘을 수 없습니다.'"]
    AV -->|"통과"| AOK["applyProgramAnswer — 본문·answeredAt·status 를 **함께** 옮긴다<br/>answeredAt 은 최초 답변 시각이라 재수정에서 바뀌지 않는다<br/>PROGRAM_ANSWER_ON_CLOSED_ERROR '종결된 문의는 답변을 수정할 수 없습니다.'"]

    VIEW --> ACT["액션 — 누를 수 없는 것을 보여 주지 않는다 (EXC-03)"]
    ACT --> A1{"canBeginAnsweringProgramInquiry = status === 'received'"}
    A1 -->|"예"| B1["[답변 착수] → applyProgramBeginAnswering<br/>PROGRAM_BEGIN_ANSWERING_ERROR '접수 상태의 문의만 답변 착수로 바꿀 수 있습니다.'"]
    ACT --> A2{"canCloseProgramInquiry = status === 'answered'"}
    A2 -->|"예"| B2["[문의 종결] → applyProgramClose<br/>PROGRAM_CLOSE_UNANSWERED_ERROR '답변하지 않은 문의는 종결할 수 없습니다.'"]
    ACT --> A3["[견적 발행] — issueBlock === null 일 때만 존재"]
    A3 --> GATE
    VIEW --> PERM{"canUpdate"}
    PERM -->|"아니오"| NOPERM["Alert info '이 문의에 답변할 권한이 없습니다. 조회만 가능합니다.'"]
  end

  ISSUE --> CROSS["견적 저장소가 **findQuoteBySource 로 한 번 더 교차 확인**(이중 방어)"]
  CROSS --> MARK["applyProgramQuoteIssued(inquiry, issued.id)<br/>quoteId 와 status 가 함께 옮겨 간다 · 이미 발행된 문의는 그대로 돌려준다(멱등)<br/>PROGRAM_QUOTE_ISSUE_ON_CLOSED_ERROR '종결된 문의는 견적을 발행할 수 없습니다.'"]
  MARK --> COMMIT
  AOK --> COMMIT["commit(next, message) — 저장의 단일 경로<br/>useCrudUpdate.mutate(toProgramInquiryInput(next))"]
  B1 --> COMMIT
  B2 --> COMMIT

  COMMIT --> RES{"결과"}
  RES -->|"성공 (상세)"| MOK["toast '답변을 저장하고 답변 완료로 변경했습니다.' / '답변을 수정했습니다.' /<br/>'답변 중으로 변경했습니다.' / '문의를 종결했습니다.' /<br/>'견적 Q-…을(를) 발행했습니다.'(objectParticle)<br/>detailQuery.refetch()"]
  RES -->|"성공 (목록 바구니)"| BOK["invalidateQueries(list) · setBasket(new Set())<br/>toast + navigate(issuedQuoteHref(issued.id))"]
  RES -->|"실패"| ME["serverError '저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>목록 쪽은 toast.error '견적을 발행하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
  RES -->|"isAbort"| AB["무시"]
  ME --> COMMIT
  MOK --> DQ
  BOK --> Q

  VIEW --> UNS["useUnsavedChangesDialog(dirty && !saving)<br/>'작성 중인 답변이 저장되지 않았습니다. 이 화면을 벗어나면 입력한 내용이 사라집니다.'"]
  UNS --> S

