%% 프로그램 · /programs
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /programs"]) --> URL["useListState({filterDefaults:{status:'all', category:'all'}})<br/>status·category·keyword 를 URL 이 소유 (IA-13)<br/>status 는 parseFilter(PROGRAM_STATUS_FILTER_VALUES,'all')<br/>category 는 **parseFilter 를 쓰지 않는다** — 운영자가 만드는 값이라<br/>닫힌 유니온이 없고 목록이 늦게 온다(도착 전 정상 id 까지 '전체'로 되돌아간다)"]
  URL --> Q["useCrudList('programs', programAdapter) — **CrudListShell**<br/>+ useQuery ['programs','category-options'] → fetchProgramCategoryOptions"]
  Q --> ST{"조회 상태"}
  ST -->|"firstLoading"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도"]
  ST -->|"성공 · 0건"| EMP["Empty — 검색 지우기 / 필터 초기화 / 등록 (STATE-05)<br/>createAction 은 canCreate 일 때만"]
  ST -->|"성공"| OK1["표 · 프로그램명(+한 줄 소개)·창작자·카테고리·목표금액<br/>·**모금액 · 달성률**·후원자수·기간·**남은 일수**·상태<br/>중심 열은 이름이 아니라 진행 상황이다"]
  E1 --> Q
  L --> OK1

  Q --> STS["상태 5종 ProgramStatus<br/>draft 작성 중(neutral) · scheduled 오픈 예정(info) · live 진행 중(success)<br/>· succeeded 성공(success) · failed 실패(danger)<br/>안내: '성공·실패는 기간이 끝난 뒤 목표 달성 여부로 갈립니다. 진행 중에는 아직 정해지지 않습니다.'"]
  STS --> DERIVE["파생값은 저장하지 않는다 — store 의 순수 함수를 목록·상세가 함께 쓴다<br/>fundingRate(goal, pledged): goal &lt;= 0 이면 0 · **100 을 넘을 수 있다**<br/>isGoalReached: goal &gt; 0 && pledged &gt;= goal<br/>daysLeft(endDate, TODAY='2026-07-21' 상수 — new Date() 를 읽으면 회귀 비교가 매일 깨진다)<br/>daysLeftText: succeeded|failed → '종료' · draft → '—' · 0 → '오늘 마감'"]
  DERIVE --> ROLL{"카테고리 필터 — **2Depth 롤업**"}
  ROLL -->|"대분류 선택"| R1["categoryFamily = 자기 자신 + 그 아래 중분류 전부<br/>filterProgramsByCategory 와 countProgramsByCategory 가<br/>**같은 롤업 위에 선다** — 갈라지면 '테크·가전 2' 배지 옆에서 표가 0건이 된다<br/>안내: '대분류를 고르면 그 아래 중분류의 프로그램까지 함께 보입니다.'"]
  ROLL -->|"모르는 id (손편집 URL·삭제된 카테고리)"| R2["아무것도 걸리지 않아 빈 목록 — 조회가 깨지는 것보다 낫다<br/>Empty 의 '필터 초기화' 가 되돌릴 길을 준다 (STATE-05)"]
  ROLL -->|"categoriesQuery.error"| R3["FilterPanel failed + onRetry → categoriesQuery.refetch()<br/>(카테고리 레일만 실패 표시 · 표는 그대로)"]
  R1 --> APPLY
  R2 --> APPLY
  APPLY["searchPrograms(filterProgramsByCategory(filterProgramsByStatus(...)))<br/>검색 대상: 프로그램명·창작자<br/>useEffect: status·category·keyword 가 바뀌면 clear() (STATE-04-b)"] --> OK1
  OK1 --> NAV(["행 클릭 rowTarget kind='detail' → /programs/:id<br/>연필 액션 onEdit → /programs/:id/edit<br/>DetailCellLink(제목)이 키보드 짝 (A11Y-08)"])

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 · /programs/:id — 읽는 화면(입력 필드 없음)"]
    NAV --> DQ["useQuery ['programs','detail',id] → programAdapter.fetchOne"]
    DQ --> DERR{"detailQuery.error (EXC-12)"}
    DERR -->|"isNotFound"| DNF["'프로그램을 찾을 수 없습니다. 이미 삭제되었을 수 있습니다.'<br/>[다시 시도] 없음 · '현황 목록으로' 만"]
    DERR -->|"그 외"| DER["'프로그램을 불러오지 못했습니다.' + [다시 시도]"]
    DERR -->|"data === undefined"| DL["LoadingSkeleton — 조건은 '아직 데이터가 없다' 뿐<br/>재조회(isFetching)로는 덮지 않는다 (STATE-01)"]
    DERR -->|"정상"| VIEW["펀딩 현황 카드 — 진행바 role='progressbar'<br/>aria-valuenow = clamp(rate, 0, 100) · aria-valuetext '목표 대비 N% 달성'<br/>**채움 폭만 100 에서 자른다 — 숫자는 자르지 않는다**<br/>CardTitle action: '목표 달성' / '모금 중'<br/>leftText: 종료됨 / 오늘 마감 / N일 남음"]
    DL --> VIEW
    VIEW --> CTA{"!ended 일 때만 후원 CTA 를 그린다<br/>checkoutCta(readPaymentSettings(), 'program')<br/>(결론이 난 펀딩에 '후원하기' 를 그리면 거짓이다)"}
    CTA -->|"kind === 'purchase'"| C1["primary 버튼 모양 + reason"]
    CTA -->|"kind === 'inquiry'"| C2["secondary '문의하기' — 그 문의는 프로그램 문의로 들어간다<br/>+ '결제 설정에서 바꾸기' 링크 (PAYMENT_SETTINGS_PATH)"]
    VIEW --> RW["리워드 표 — limitCount === 0 은 '무제한'(0개가 아니다)<br/>soldOut = limitCount &gt; 0 && claimedCount &gt;= limitCount → '마감' 배지<br/>0건이면 '등록된 리워드가 없습니다. 리워드는 등록/수정 화면에서 추가합니다.'"]
    VIEW --> EDIT{"canUpdate (EXC-03)"}
    EDIT -->|"예"| EL["제목 옆 [수정] → /programs/:id/edit"]
    EDIT -->|"아니오"| EN["버튼 자체를 그리지 않는다"]
  end

  subgraph SUB2["등록/수정 폼 · /programs/new · /programs/:id/edit"]
    NAV --> FP["useCrudForm(programSchema, EMPTY, toInput, toValues)<br/>다중 구획 + 미리보기라 FormPageShell 을 쓰지 않는다<br/>useActiveSection(SECTION_IDS) 로 좌측 레일이 현재 구획과 오류 구획을 표시"]
    FP --> PERM{"canSubmit — useCrudForm 이 라우트에서 파생<br/>(등록이면 create, 수정이면 update)"}
    PERM -->|"false"| FORB["ForbiddenScreen — **저장할 수 없는 폼은 열지 않는다** (EXC-03)"]
    PERM -->|"true"| LF{"loadFailure (EXC-12)"}
    LF -->|"'not-found'"| LF1["'프로그램을 찾을 수 없습니다. 이미 삭제되었을 수 있습니다.'<br/>[목록으로]만 — 없는 건에 재시도를 권하지 않는다"]
    LF -->|"'error'"| LF2["'프로그램을 불러오지 못했습니다.' [다시 시도](retryLoad) · [목록으로]"]
    LF -->|"null"| FRM["폼 본문 + 실시간 미리보기<br/>previewNumber: 검증 통과 **전** 값도 그린다('10,000,000' 에서 숫자만)<br/>카테고리는 셀렉트 2개지만 저장값은 categoryId **하나**<br/>대분류를 바꾸면 중분류 선택은 버린다"]
    LF2 --> FP

    FRM --> V{"programSchema 검증 (zod/mini 정본)"}
    V -->|"필수"| V1["프로그램명·창작자·한 줄 소개 requiredText<br/>categoryId minLength(1) '카테고리를 선택하세요.'<br/>startDate '시작일을 입력하세요.' · endDate '종료일을 입력하세요.'"]
    V -->|"금액"| V2["'목표 금액은 숫자만 입력하세요.'<br/>'목표 금액은 1원 이상이어야 합니다.'"]
    V -->|"기간 교차검증"| V3["startDate &lt;= endDate 아니면 path=['endDate']<br/>'종료일은 시작일과 같거나 그 뒤여야 합니다.'"]
    V -->|"상세 설명"| V4["**richTextLength 로 잰다** — value.length 로 재면 '굵게' 한 번에<br/>&lt;strong&gt;&lt;/strong&gt; 17자가 붙어 쓰지도 않은 글자수로 제출이 막힌다<br/>'상세 설명은 2000자를 넘을 수 없습니다.' (스토리에는 상한이 없다)"]
    V -->|"옵션 그룹"| V5["MAX_PROGRAM_OPTION_GROUPS 3 — '옵션은 최대 3개까지 만들 수 있습니다.'<br/>'옵션값을 입력한 옵션에는 옵션명을 함께 입력하세요.'<br/>(값이 빈 그룹은 막지 않는다 — 자리를 먼저 잡는 것은 정상이고<br/>normalizeProgramOptionGroups 가 저장 때 조용히 버린다)<br/>'옵션명이 중복되었습니다. 서로 다른 이름을 입력하세요.'"]
    V -->|"리워드 참조"| V6["path=['rewards'] '삭제된 옵션을 가리키는 리워드가 있습니다.<br/>리워드의 옵션 선택을 다시 확인하세요.'<br/>리워드 표의 선택지는 **값이 채워진 그룹만** — 버려질 그룹을 고르게 하지 않는다"]
    V1 --> VE["필드 인라인 + 좌측 구획 레일에 invalid 표시<br/>판정은 errors 하나만 본다(구획마다 조건을 다시 적지 않는다)"]
    V2 --> VE
    V3 --> VE
    V4 --> VE
    V5 --> VE
    V6 --> VE
    VE --> FRM
    V -->|"통과"| SUBMIT["submit → toInput → adapter.add / adapter.update<br/>applyOptionGroupsToRewards 가 사라진 그룹 참조를 리워드에서 떼어낸다"]
    SUBMIT --> MR{"결과"}
    MR -->|"409"| CF["FormConflictDialog(conflict)"]
    MR -->|"오류"| SE["FormServerError(serverError, errorReference)"]
    MR -->|"성공"| MOK["성공 토스트 · navigate('/programs')"]
    SE --> FRM
    CF --> S
    MOK --> S

    FRM --> UNS["useUnsavedChangesDialog(isDirty && !saving)"]
    UNS --> S
  end

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,ROLL,DERR,CTA,EDIT,PERM,LF,V,MR gate
  class E1,EMP,R2,R3,DNF,DER,EN,FORB,LF1,LF2,V1,V2,V3,V4,V5,V6,VE,SE,CF err
  class OK1,MOK,C1 ok
