  subgraph SUB1["상세 · /sales/billing/:id — 청구 요약 · 방식"]
    DET --> DQ["useQuery ['sales-billing','detail',id] → billingAdapter.fetchOne"]
    DQ --> DERR{"detailQuery.error (EXC-12)"}
    DERR -->|"isNotFound"| DNF["'청구를 찾을 수 없습니다. 이미 삭제되었을 수 있습니다.'<br/>[목록으로]만"]
    DERR -->|"그 외"| DER["'청구를 불러오지 못했습니다.' [다시 시도] · [목록으로]"]
    DERR -->|"data === undefined"| DL["'불러오는 중…' 카드"]
    DERR -->|"정상"| VIEW["제목 '청구 BL-…' + StatusBadge(입금 상태) + StatusBadge(청구 방식)<br/>요약 dl: 거래처·원 견적·청구일·청구액·입금액(누적)·잔액·입금 완료일<br/>quoteId === '' 면 '견적 없이 만든 청구입니다.'<br/>paidOnDate = 잔액을 0 으로 만든 그 입금의 날짜"]
    DL --> VIEW
    VIEW --> PERM{"canUpdate (EXC-03)"}
    PERM -->|"아니오"| NOPERM["Alert info '입금확인 권한이 없습니다. 이 화면은 조회만 가능합니다.'<br/>모든 입력 disabled · 기록 버튼 미노출"]
    PERM -->|"예"| METHOD["청구 방식 select — 값이 바뀌면 **즉시 commit**<br/>'결제대행을 쓰지 않으므로 앱은 결제를 처리하지 않습니다.<br/>개인결제창은 링크를 보관만 하고, 입금 사실은 아래에서 사람이 확인해 기록합니다.'<br/>bank_transfer 로 되돌리면 paymentLinkUrl 을 ''로 비운다<br/>payment_link 면 링크 input(hint '링크만 보관합니다 — 결제 상태를 조회하지 않습니다.')<br/>비고 TextareaField (BILLING_NOTE_MAX 300)"]
  end

  subgraph SUB2["입금확인 · 청구 안내 — 덧붙이기만 하는 기록"]
    METHOD --> PAY["입금확인 카드<br/>'통장에 찍힌 입금을 기록합니다. 여러 번 나눠 들어오면 그때마다 기록하고,<br/>누적 합이 청구액에 닿으면 입금완료가 됩니다.<br/>**기록한 입금은 되돌릴 수 없습니다.**'<br/>입금일(기본 TODAY 상수 — 화면이 new Date() 를 읽으면 회귀 비교가 매일 깨진다)<br/>입금액(digitsToNumber: '1,200,000원' 을 붙여 넣어도 살아남는다)<br/>입금자명·메모 (BILLING_MEMO_MAX 60)<br/>state === 'paid' 면 세 칸 모두 disabled"]
    PAY --> PB{"paymentBlock = recordPaymentBlock(billing, amount, paidOn)<br/>버튼 disabled 와 저장 거절이 **같은 술어**"}
    PB -->|"이미 완납"| P1["PAYMENT_ALREADY_PAID '이미 입금이 완료된 청구입니다.'"]
    PB -->|"!Number.isInteger(amount) || amount &lt;= 0"| P2["PAYMENT_AMOUNT_POSITIVE '입금액은 0보다 커야 합니다.'<br/>**되돌리는 전이가 없다** — 음수 기록으로 취소하는 문을 열지 않는다"]
    PB -->|"amount &gt; outstandingAmount"| P3["PAYMENT_OVER_OUTSTANDING '입금액이 잔액보다 클 수 없습니다.'<br/>초과분은 입금이 아니라 과오납 처리라는 다른 업무다"]
    PB -->|"YYYY-MM-DD 아님"| P4["PAYMENT_DATE_REQUIRED '입금일을 YYYY-MM-DD 형식으로 입력하세요.'"]
    PB -->|"null"| PGO["[입금확인 기록] 활성<br/>applyPayment — 내부에서 recordPaymentBlock 재판정 후 막히면 throw<br/>상태를 함께 옮기지 않는다(상태는 파생이다): 기록 하나만 덧붙이면<br/>배지·잔액·완납일이 동시에 따라온다"]
    P1 --> PW["Alert warning — 단, amountInput !== '' 일 때만 띄운다<br/>(빈 칸에 대고 미리 꾸짖지 않는다)"]
    P2 --> PW
    P3 --> PW
    P4 --> PW

    METHOD --> NOT["청구 안내 카드<br/>'앱이 메시지를 보내지는 않습니다 — 보낸 사실을 기록할 뿐입니다.'<br/>안내 창구 email 이메일 / sms 문자 / kakao 카카오톡 / phone 전화 + 메모"]
    NOT --> NB{"noticeBlock = sendNoticeBlock(billing)"}
    NB -->|"method==='payment_link' && paymentLinkUrl.trim()===''"| N1["NOTICE_LINK_REQUIRED<br/>'개인결제창 링크를 먼저 등록해야 안내를 보낼 수 있습니다.'<br/>(계좌이체는 계좌 안내가 문면에 있어 막지 않는다)"]
    NB -->|"null"| NGO["[안내 발송 기록] → applyNotice (되돌리지 않는다)"]
    N1 --> NW["Alert warning · 버튼 disabled"]
  end

  PGO --> COMMIT["commit(next, message) — 저장의 단일 경로<br/>입금·안내·방식·링크·비고가 모두 '다음 청구 한 벌' 을 통째로 보낸다<br/>useCrudUpdate.mutate(toBillingInput(next))"]
  NGO --> COMMIT
  COMMIT --> RES{"결과"}
  RES -->|"성공"| MOK["detailQuery.refetch() + setStatusMessage(…)<br/>aria-live polite 로도 읽힌다 (A11Y-16)<br/>'입금을 확인 처리했습니다.' / '청구 안내 발송을 기록했습니다.' /<br/>'청구 방식을 변경했습니다.' / '개인결제창 링크를 저장했습니다.' / '비고를 저장했습니다.'<br/>입금 폼은 amountInput·memo 를 비운다"]
  RES -->|"409 (없는 id)"| C409["'다른 사용자가 먼저 삭제한 청구입니다.' (EXC-04)<br/>조용히 지나치고 성공을 반환하지 않는다"]
  RES -->|"그 외"| ME["serverError '저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
