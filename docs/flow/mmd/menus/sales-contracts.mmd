  PF --> Q["useCrudList('sales-contracts', contractAdapter)"]
  Q --> ST{"조회 상태"}

  ST -->|"최초 로드"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도"]
  ST -->|"성공 · 0건"| EMP["Empty<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  ST -->|"성공 · 데이터 있음"| OK1["CrudListShell 표<br/>계약명·거래처·유형·기간·금액·상태"]

  E1 --> Q
  L --> OK1
  EMP --> F
  OK1 --> F["필터·검색 조작"]
  F --> F1["상태 SelectField<br/>draft/review/active/expired/terminated"]
  F --> F2["검색 (IME 안전)<br/>searchContracts: 계약명·거래처"]
  F1 --> URL
  F2 --> URL
  F1 --> CLR["useEffect: clear() — 선택 해제 (STATE-04-b)"]
  F2 --> CLR
  CLR --> OK1

  OK1 --> BADGE["상태 셀 = 2축 표시<br/>contractStatusMeta(status) 배지<br/>+ isRenewalDue(item, today) 면 '갱신임박'"]
  BADGE --> RD{"isRenewalDue<br/>status==='active' && autoRenew<br/>&& 0 ≤ daysRemaining ≤ renewNoticeDays"}
  RD -->|"예"| RD1["warning '갱신임박' 배지 추가"]
  RD -->|"아니오"| OK1
  RD1 --> OK1

  OK1 --> ACT["액션 선택"]
  ACT --> A1["행 수정 → /sales/contracts/:id/edit"]
  ACT --> A2["삭제 · 일괄 삭제"]
  ACT --> A3["계약 등록 (canCreate · EXC-03)"]

  A2 --> D1["ConfirmDialog intent='delete'"]
  D1 --> DC{"확인 / 취소"}
  DC -->|"취소·Esc"| DCX["abort · reset"]
  DCX --> OK1
  DC -->|"확인"| D2["adapter.remove"]
  D2 --> DR{"성공?"}
  DR -->|"실패"| DERR["다이얼로그 유지 + danger 배너 · 재클릭=재시도"]
  DERR --> D2
  DR -->|"성공"| DOK["닫힘 · 선택 해제 · 무효화 · 성공 토스트"]
  DOK --> Q

  SUB1 ~~~ SUB2

  subgraph SUB1["폼 서브플로우 — ContractFormPage"]
    A1 --> FP["useCrudForm(contractSchema, EMPTY)"]
    A3 --> FP
    FP --> LF{"loadFailure"}
    LF -->|"'not-found'"| LF1["'이미 삭제되었을 수 있습니다' · 목록으로"]
    LF -->|"'error'"| LF2["다시 시도 + 목록으로 (EXC-12)"]
    LF -->|"null"| FRM["입력 카드 + ContractSummaryPreview"]
    LF2 --> FP
    FRM --> AX["상태축과 서명축은 **별개 필드**다"]
    AX --> AX1["계약 상태 select<br/>draft/review/active/expired/terminated"]
    AX --> AX2["전자서명 상태 select<br/>unsigned/sent/partial/signed"]
    AX --> AX3["자동갱신 ToggleSwitch<br/>켤 때만 renewNoticeDays 필드 노출"]
    AX --> AX4["ImageGalleryField 첨부<br/>maxFiles=CONTRACT_MAX_ATTACHMENTS(5)"]
  end

  subgraph SUB2["검증 → 저장"]
    AX1 --> V{"contractSchema 통과?"}
    AX2 --> V
    AX3 --> V
    AX4 --> V
    V -->|"amount 비숫자/0 이하"| V1["'숫자만' · '0보다 커야 합니다'"]
    V -->|"기간 오류"| V2["isCalendarDate 실패 → 'YYYY-MM-DD'<br/>endAt &lt; startAt → '종료일은 시작일보다 빠를 수 없습니다'"]
    V -->|"autoRenew && 통지기한 비숫자"| V3["'갱신 통지기한(일)은 숫자만'"]
    V -->|"통과"| M["toInput: autoRenew 꺼지면 renewNoticeDays=0<br/>adapter.add · update"]
    V1 --> FRM
    V2 --> FRM
    V3 --> FRM
    M --> MR{"결과"}
    MR -->|"409"| CF["FormConflictDialog"]
    MR -->|"오류"| SE["FormServerError + errorReference"]
    MR -->|"성공"| MOK["성공 토스트 · navigate('/sales/contracts')"]
    SE --> FRM
    CF --> S
    MOK --> S
  end

  FRM --> UNS["useUnsavedChangesDialog(isDirty && !saving)"]
  UNS --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
