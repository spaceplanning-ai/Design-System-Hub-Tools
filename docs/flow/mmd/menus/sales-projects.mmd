%% 프로젝트 · /sales/projects
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /sales/projects"]) --> URL["useListState({filterDefaults:{stage:'all'}})<br/>stage·keyword 를 URL 이 소유 (IA-13)"]
  URL --> PF["parseFilter(stage, STAGE_FILTER_VALUES, 'all')"]
  PF --> Q["useCrudList('sales-projects', projectAdapter)"]
  Q --> ST{"조회 상태"}

  ST -->|"최초 로드"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도"]
  ST -->|"성공 · 0건"| EMP["Empty<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  ST -->|"성공 · 데이터 있음"| OK1["CrudListShell 표<br/>단계·프로젝트명·거래처·예상매출·기간·진척바"]

  E1 --> Q
  L --> OK1
  EMP --> F
  OK1 --> F["필터·검색 조작"]
  F --> F1["단계 SelectField (STAGES)<br/>lead/qualified/proposal/negotiation/won/lost"]
  F --> F2["검색: searchProjects 프로젝트명·거래처<br/>정렬 sortProjects: endAt 오름차순(임박이 위)"]
  F1 --> URL
  F2 --> URL
  F1 --> CLR["useEffect: clear() — 선택 해제 (STATE-04-b)"]
  F2 --> CLR
  CLR --> OK1

  OK1 --> ACT["액션 선택"]
  ACT --> A1["행 수정 → /sales/projects/:id/edit"]
  ACT --> A2["삭제 · 일괄 삭제"]
  ACT --> A3["프로젝트 등록 (canCreate · EXC-03)"]

  A2 --> D1["ConfirmDialog intent='delete'"]
  D1 --> DC{"확인 / 취소"}
  DC -->|"취소"| DCX["abort · reset"]
  DCX --> OK1
  DC -->|"확인"| D2["adapter.remove"]
  D2 --> DR{"성공?"}
  DR -->|"실패"| DERR["다이얼로그 유지 + danger 배너 · 재클릭=재시도"]
  DERR --> D2
  DR -->|"성공"| DOK["닫힘 · 무효화 · 성공 토스트"]
  DOK --> Q

  SUB1 ~~~ SUB2

  subgraph SUB1["폼 서브플로우 — ProjectFormPage"]
    A1 --> FP["useCrudForm(projectSchema, EMPTY stage='lead' probability='10')"]
    A3 --> FP
    FP --> LF{"loadFailure"}
    LF -->|"'not-found'"| LF1["'이미 삭제되었을 수 있습니다' · 목록으로"]
    LF -->|"'error'"| LF2["다시 시도 + 목록으로 (EXC-12)"]
    LF -->|"null"| FRM["입력 카드 + ProjectMilestonesField + 파이프라인 카드"]
    LF2 --> FP
    FRM --> SG["onStageChange(next)"]
    SG --> SG1["setValue('stage', next)<br/>setValue('probability', defaultProbability(next))<br/>lead10·qualified30·proposal50·negotiation70·won100·lost0"]
    SG1 --> FL{"stage === 'lost' ?<br/>STAGES.lost.inFlow === false"}
    FL -->|"예"| FL1["실주 사유 필드 노출(required)<br/>파이프라인 카드 = Stepper 대신 '실주 — 종료' 배지"]
    FL -->|"아니오"| FL2["Stepper current=stage<br/>PIPELINE_FLOW(실주 제외) 로 그린다"]
    FRM --> WR["가중예상매출 = weightedRevenue<br/>= round(expectedRevenue × probability / 100)"]
  end

  subgraph SUB2["검증 → 저장"]
    FL1 --> V{"projectSchema 통과?"}
    FL2 --> V
    WR --> V
    V -->|"probability·progress"| V1["'숫자만' / '0~100 사이여야 합니다'<br/>topicParticle 로 조사 계산"]
    V -->|"기간"| V2["'YYYY-MM-DD' / '종료일은 시작일보다 빠를 수 없습니다'"]
    V -->|"stage==='lost' && lostReason 공백"| V3["'실주 사유를 입력하세요.'"]
    V -->|"milestones"| V4["이름 공백 / 목표일 비-달력 → 배열 단일 문구"]
    V -->|"통과"| M["toInput: clampPercent · digitsToNumber<br/>lostReason 은 lost 아니면 '' 로 비운다<br/>adapter.add · update"]
    V1 --> FRM
    V2 --> FRM
    V3 --> FRM
    V4 --> FRM
    M --> MR{"결과"}
    MR -->|"409"| CF["FormConflictDialog"]
    MR -->|"오류"| SE["FormServerError + errorReference"]
    MR -->|"성공"| MOK["성공 토스트 · navigate('/sales/projects')"]
    SE --> FRM
    CF --> S
    MOK --> S
  end

  FRM --> UNS["useUnsavedChangesDialog(isDirty && !saving)"]
  UNS --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,DC,DR,LF,FL,V,MR gate
  class E1,DERR,LF1,LF2,V1,V2,V3,V4,SE,CF,FL1 err
  class OK1,DOK,MOK,FL2 ok
