%% 견적 · /sales/quotes
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /sales/quotes"]) --> URL["useListState({filterDefaults:{status:'all'}})<br/>status·keyword 를 URL 이 소유 (IA-13)"]
  URL --> PF["parseFilter(status, QUOTE_STATUS_FILTER_VALUES, 'all')"]
  PF --> Q["useCrudList('sales-quotes', quoteAdapter)"]
  Q --> ST{"조회 상태"}

  ST -->|"최초 로드"| L["스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도"]
  ST -->|"성공 · 0건"| EMP["Empty<br/>검색 지우기 / 필터 초기화 (STATE-05)"]
  ST -->|"성공 · 데이터 있음"| OK1["CrudListShell 표<br/>견적번호·거래처·원본문의·합계금액·유효기간·상태"]

  E1 --> Q
  L --> OK1
  EMP --> F
  OK1 --> F["필터·검색 조작"]
  F --> F1["상태 SelectField<br/>draft/sent/accepted/rejected/expired/ordered"]
  F --> F2["검색: searchQuotes 견적번호·거래처"]
  F1 --> URL
  F2 --> URL
  F1 --> CLR["useEffect: clear() — 선택 해제 (STATE-04-b)"]
  F2 --> CLR
  CLR --> OK1

  OK1 --> CALC["합계 = computeTotals(items, taxMode)<br/>세액은 라인별 반올림 후 합산 · 영세/면세는 0"]
  CALC --> LINK{"isInherited(item)<br/>inquiryId !== ''"}
  LINK -->|"예"| LK1["원본 문의 역링크<br/>/sales/inquiries/:inquiryId"]
  LINK -->|"아니오"| LK2["'—' (수동 등록 견적)"]

  OK1 --> ACT["액션 선택"]
  ACT --> A1["수주 전환 (행 인라인)"]
  ACT --> A2["행 수정 → /sales/quotes/:id/edit"]
  ACT --> A3["삭제 · 일괄 삭제"]
  ACT --> A4["견적 등록 (canCreate · EXC-03)"]

  A1 --> G1{"canConvertToOrder(status)<br/>status === 'accepted' 만"}
  G1 -->|"아니오"| G1X["버튼 없음 · '—' 표시<br/>draft/sent/rejected/expired/ordered"]
  G1 -->|"예"| C1["useCrudRowUpdate.run(id, {...toQuoteInput(item), status:'ordered'})"]
  C1 --> CR{"성공?"}
  CR -->|"성공"| COK["성공 토스트<br/>objectParticle(quoteNo) 로 조사 계산 (ERP-13)"]
  CR -->|"실패"| CERR["실패 토스트 · 상태 원복"]
  CERR --> C1
  COK --> Q
  G1X --> OK1

  A3 --> D1["ConfirmDialog intent='delete'"]
  D1 --> DC{"확인 / 취소"}
  DC -->|"취소"| DCX["abort · reset"]
  DCX --> OK1
  DC -->|"확인"| D2["removeQuote — 없으면 409 '이미 삭제된 견적'"]
  D2 --> DR{"성공?"}
  DR -->|"실패"| DERR["다이얼로그 유지 + danger 배너"]
  DERR --> D2
  DR -->|"성공"| DOK["닫힘 · 무효화 · 성공 토스트"]
  DOK --> Q

  SUB1 ~~~ SUB2

  subgraph SUB1["폼 서브플로우 — QuoteFormPage"]
    A2 --> FP["useCrudForm(quoteSchema, EMPTY_QUOTE_FORM)"]
    A4 --> FP
    FP --> LF{"loadFailure"}
    LF -->|"'not-found'"| LF1["'견적을 찾을 수 없습니다' · 목록으로"]
    LF -->|"'error'"| LF2["다시 시도 + 목록으로 (EXC-12)"]
    LF -->|"null"| FRM["입력 카드 + QuoteLineItemsTable + QuotePreview"]
    LF2 --> FP
    FRM --> INH{"isInherited({inquiryId})<br/>자동생성 견적인가"}
    INH -->|"예"| IN1["accountName·contactName readOnly (승계 잠금)<br/>'원본 문의' 카드 + 원본 문의 보기"]
    INH -->|"아니오"| IN2["승계 필드 자유 편집"]
    FRM --> NO["견적번호는 항상 readOnly<br/>빈 값이면 저장 시 makeQuoteNo(issueDate, seq) 자동 채번"]
    FRM --> PR["인쇄 · PDF 저장 → window.print()<br/>대상 지정은 quotes.css @media print (ERP-10)"]
  end

  subgraph SUB2["검증 → 저장"]
    IN1 --> V{"quoteSchema 통과?"}
    IN2 --> V
    NO --> V
    V -->|"items 위반"| V1["0개 → '품목을 한 개 이상'<br/>품목명 공백 / 수량 &lt; 1 정수 아님 / 단가 &lt; 0"]
    V -->|"날짜 위반"| V2["isCalendarDate 실패 → 'YYYY-MM-DD'<br/>validUntil &lt; issueDate → '유효기간은 견적일보다 빠를 수 없습니다'"]
    V -->|"accountName 공백"| V3["'거래처' 필수"]
    V -->|"통과"| M["adapter.add(nextQuote 채번) · update"]
    V1 --> FRM
    V2 --> FRM
    V3 --> FRM
    M --> MR{"결과"}
    MR -->|"409 '다른 사용자가 먼저 삭제한 견적'"| CF["FormConflictDialog"]
    MR -->|"오류"| SE["FormServerError + errorReference"]
    MR -->|"성공"| MOK["성공 토스트 · navigate('/sales/quotes')"]
    SE --> FRM
    CF --> S
    MOK --> S
  end

  FRM --> UNS["useUnsavedChangesDialog(isDirty && !saving)"]
  UNS --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,LINK,G1,CR,DC,DR,LF,INH,V,MR gate
  class E1,G1X,CERR,DERR,LF1,LF2,V1,V2,V3,SE,CF err
  class OK1,COK,DOK,MOK,LK1 ok
