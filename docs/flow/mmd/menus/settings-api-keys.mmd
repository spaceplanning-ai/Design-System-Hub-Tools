flowchart TD
  S(["진입 /settings/api-keys"]) --> Q["useSettingsQuery(aiConnections…)<br/>Revisioned&lt;AiConnectionsValues&gt;<br/>로컬 상태: tab(IntegrationTabId, 기본 'model')<br/>※ URL 파라미터를 쓰지 않는다"]
  Q --> LS{"목록 상태"}
  LS -->|"error !== null"| E1["인라인 danger 배너 + '다시 시도'(refetch)"]
  LS -->|"isFetching"| L1["카드 스켈레톤"]
  LS -->|"성공"| OK1["IntegrationsCard — 연동 카탈로그 13종<br/>탭: 모델 · 클라우드 · 게이트웨이 (탭 라벨에 건수 표기)"]
  E1 --> Q
  L1 --> OK1

  OK1 ~~~ SUB1

  subgraph SUB1["카탈로그 13종 (INTEGRATIONS)"]
    C1["모델 — openai · claude · gemini · grok<br/>mistral · perplexity · cohere · deepseek · groq"]
    C2["클라우드 — azure-openai(리소스 엔드포인트·배포명·API 버전)<br/>amazon-bedrock(리전 등)"]
    C3["게이트웨이 — openrouter · together"]
    C4["타일마다 ServiceGlyph + 연동 여부 표시<br/>저장된 키는 채워지지 않는다 — 저장 여부만 알고 •••• 로"]
  end

  OK1 --> ROW["타일 클릭 → aiConnectionPath(id)<br/>= /settings/api-keys/:providerId (라우트 전환)<br/>주소는 paths.ts 한 군데서만 만든다"]
  ROW --> D0["AiConnectionPage — 프로바이더 1종 상세"]

  D0 --> DK{"useParams providerId 가<br/>카탈로그에 있는가?"}
  DK -->|"없음"| DKE["'없는 프로바이더' 안내<br/>빈 껍데기를 내놓지 않는다 · 폼을 그리지 않는다"]
  DK -->|"있음"| DF["useForm(zodResolver(aiConnectionSchema(entry.credentials)))<br/>record(저장 기록) 도착 시 reset(recordToForm(record))<br/>없으면 '아직 저장한 적 없음'"]

  DF --> DS{"SettingsFormShell 상태"}
  DS -->|"loadFailed"| DE1["폼 대신 실패 화면 + 다시 시도"]
  DS -->|"loading"| DL["스켈레톤 · disabled"]
  DS -->|"!canUpdate"| DRO["읽기 전용 안내 · 저장 컨트롤 부재 (EXC-03)"]
  DS -->|"성공 · canUpdate"| DOK["AiCredentialFields + 사용 여부 토글 + AuditNote"]
  DL --> DOK
  DRO --> DOK

  DOK --> SEC["시크릿 취급<br/>저장된 API 키는 화면에 채워지지 않는다(•••• )<br/>'새 값 입력 중'인 비밀 칸은 화면 상태이지 저장값이 아니다<br/>비밀 칸은 값 비교 불가 — '저장 여부'가 갈라졌는지만 본다"]

  DOK --> SUB2["저장 제출"]
  SUB2 --> V{"aiConnectionSchema 검증"}
  V -->|"실패"| VE["필드 인라인 오류 · 입력 보존"]
  VE --> DOK
  V -->|"통과"| CD["ConfirmDialog — 켜기/끄기/일반 저장으로 문구 분기<br/>'이 연동만 저장됩니다. 다른 프로바이더는 바뀌지 않습니다'<br/>끄기: '연동이 하나도 남지 않으면 AI 화면의 응답 모드가 다시 잠깁니다'"]

  CD --> CC{"확인 / 취소"}
  CC -->|"취소"| CX["abort + save.reset()"]
  CX --> DOK
  CC -->|"확인"| M["save.mutate({value, expectedRevision, signal})<br/>페이로드는 서버 최신 문서에서 만들고<br/>이 프로바이더 자리만 폼 값으로 바꾼다"]

  M --> MR{"결과"}
  MR -->|"409 충돌"| CF["ConflictDialog — setConflict(cause.latest)"]
  MR -->|"실패"| ME["saveError 배너<br/>'AI 연동을 저장하지 못했습니다' · 입력 보존"]
  MR -->|"성공"| MOK["reset(recordToForm(stored)) — 평문은 화면에서 사라진다<br/>새 기준선은 저장소가 돌려준 문서('저장됐다'는 사실뿐)<br/>성공 토스트 '(이름) 연동을 저장했습니다'"]
  ME --> M

  CF --> CFC{"선택"}
  CFC -->|"최신 내용 불러오기"| CF1["reloadLatest: 최신 문서에서 이 프로바이더를 꺼내 reset<br/>+ refetch · 토스트 '최신 AI 연동 설정을 불러왔습니다'"]
  CFC -->|"내 변경으로 덮어쓰기"| CF2["force 재저장 · 실패 시 다이얼로그 안 배너"]
  CF1 --> DOK
  CF2 --> M

  DOK --> GUARD["미저장 이탈 가드(SettingsFormShell)<br/>브라우저 이탈·앱 내 링크·뒤로가기 3경로<br/>목록 복귀는 &lt;Link&gt; 로 — navigate() 는 가드를 지나친다"]
  MOK --> BACK["목록(/settings/api-keys)으로 복귀"]
  DKE --> BACK
  BACK --> Q

