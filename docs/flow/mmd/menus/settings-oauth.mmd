%% OAuth 설정 · /settings/oauth
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /settings/oauth"]) --> Q["useSettingsQuery(oauthSettings…)<br/>Revisioned&lt;OAuthSettingsValues&gt;<br/>useForm(zodResolver) — 표시 정책·순서는 목록 화면이 소유<br/>로컬 상태: pending · saveError · conflict · reordering"]
  Q --> LS{"목록 상태"}
  LS -->|"error !== null"| E1["loadFailed — 폼 대신 실패 화면 + '다시 시도'(refetch)"]
  LS -->|"isFetching"| L1["타일·카드 스켈레톤"]
  LS -->|"!canUpdate"| RO["읽기 전용 안내 · 저장 컨트롤 부재 (EXC-03)"]
  LS -->|"성공"| OK1["ProviderTileList(hrefOf=oauthProviderPath) + 표시 정책 카드"]
  E1 --> Q
  L1 --> OK1
  RO --> OK1

  OK1 ~~~ SUB1

  subgraph SUB1["제공자 6종 · 목록 화면이 하는 일"]
    P1["client-secret 갈래 5종 — google · kakao · naver · facebook · line"]
    P2["apple 갈래 1종 — servicesId · key 기반(다른 필드 모양)"]
    P3["로그인 화면 표시 정책 카드<br/>예: kakaoTalkInAppLoginOnly — 검증 오류는 정책 카드 안 인라인"]
    P4["표시 순서 재배열(reordering) — 목록에서 저장"]
  end

  OK1 --> ROW["타일 클릭 → oauthProviderPath(provider)<br/>= /settings/oauth/:provider (라우트 전환)<br/>주소는 paths.ts 한 군데서만 만든다"]
  ROW --> D0["OAuthProviderPage — 제공자 1종 상세"]

  D0 --> DK{"useParams provider 가 6종 중 하나인가?"}
  DK -->|"아님"| DKE["'없는 제공자' 안내 — 폼을 그리지 않는다"]
  DK -->|"맞음"| DF["useForm(zodResolver(oauthProviderScopedSchema(target)))<br/>이 제공자 자리만 검증한다 — 다른 제공자의 오류가<br/>보이지도 고칠 수도 없는 채로 저장을 막지 않게 (validation.ts)"]

  DF --> DS{"SettingsFormShell 상태"}
  DS -->|"loadFailed"| DE1["폼 대신 실패 화면 + 다시 시도"]
  DS -->|"loading"| DL["스켈레톤 · disabled"]
  DS -->|"!canUpdate"| DRO["읽기 전용 안내 · 저장 컨트롤 부재"]
  DS -->|"성공 · canUpdate"| DOK["OAuthProviderCard — 사용 토글 · clientId<br/>secret · redirectUri(콜백 URL) 등 + AuditNote"]
  DL --> DOK
  DRO --> DOK

  DOK --> SEC["시크릿 취급<br/>저장된 client secret 은 화면에 채워지지 않는다(•••• )<br/>'시크릿 변경 중'은 화면 상태이지 저장값이 아니다"]
  DOK --> VAL["갈래별 검증 — apple 은 servicesId·key,<br/>google 은 clientId 접미사(GOOGLE_CLIENT_ID_SUFFIX) 확인"]

  DOK --> SUB2["저장 제출"]
  SUB2 --> V{"oauthProviderScopedSchema 검증"}
  V -->|"실패"| VE["필드 인라인 오류 · 입력 보존"]
  VE --> DOK
  V -->|"통과"| CD["ConfirmDialog — 켜기/끄기/일반 저장 문구 분기<br/>끄기: '이 방식으로 가입한 사용자는 로그인할 수 없게 됩니다'<br/>'이 제공자의 설정만 저장됩니다. 다른 제공자와 표시 정책은 바뀌지 않습니다'"]

  CD --> CC{"확인 / 취소"}
  CC -->|"취소"| CX["abort + save.reset()"]
  CX --> DOK
  CC -->|"확인"| M["save.mutate({value, expectedRevision, signal})<br/>페이로드는 서버 최신 문서에서 만들고<br/>이 제공자 자리만 폼 값으로 바꾼다"]

  M --> MR{"결과"}
  MR -->|"409 충돌"| CF["ConflictDialog 'OAuth 설정이 이미 변경되었습니다'<br/>+ 갈린 항목(clientId·redirectUri 등) 나열"]
  MR -->|"실패"| ME["saveError 배너<br/>'OAuth 설정을 저장하지 못했습니다' · 입력 보존"]
  MR -->|"성공"| MOK["reset — 평문 시크릿은 화면에서 사라진다<br/>새 기준선은 '저장됨 + 빈 입력'<br/>성공 토스트 '(제공자) 설정을 저장했습니다'"]
  ME --> M

  CF --> CFC{"선택"}
  CFC -->|"최신 내용 불러오기"| CF1["reset(latest) + refetch<br/>토스트 '최신 OAuth 설정을 불러왔습니다'"]
  CFC -->|"내 변경으로 덮어쓰기"| CF2["force 재저장 · 실패 시 다이얼로그 안 배너"]
  CF1 --> DOK
  CF2 --> M

  DOK --> GUARD["미저장 이탈 가드(SettingsFormShell)<br/>브라우저 이탈·앱 내 링크·뒤로가기 3경로<br/>목록 복귀는 &lt;Link&gt; 로 — navigate() 는 가드를 지나친다"]
  MOK --> BACK["목록(/settings/oauth)으로 복귀"]
  DKE --> BACK
  BACK --> Q

