%% 결제 설정 · /settings/payment
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /settings/payment"]) --> Q["useSettingsQuery(paymentSettingsKey, paymentSettingsStore)<br/>Revisioned&lt;PaymentSettings&gt; — 값 + revision + audit<br/>useForm(zodResolver(paymentSettingsSchema))<br/>data 도착 시 reset(toPaymentFormValues(data.value)) 로 기준선 설정"]
  Q --> LS{"SettingsFormShell 상태"}
  LS -->|"loadFailed (error !== null)"| E1["폼 대신 실패 화면 + '다시 시도'(refetch)<br/>재현: ?fail=load"]
  LS -->|"isFetching && data===undefined"| L1["카드 골격 + 스켈레톤 (STATE-01)<br/>재조회 중에는 이전 값을 유지한다"]
  LS -->|"!canUpdate"| RO["info 배너 '조회 권한만 있습니다. 결제 설정을 바꾸려면<br/>시스템 설정 수정 권한이 필요합니다.'<br/>저장 컨트롤 자체를 렌더하지 않는다 (EXC-03)"]
  LS -->|"성공 · canUpdate"| OK1["폼 본문 + AuditNote(최종 수정자·시각)"]
  E1 --> Q
  L1 --> OK1
  RO --> OK1

  OK1 --> SW{"**구획 1 · 결제 연동** — ToggleSwitch 'PG 결제 사용'<br/>이 스위치 하나가 판매 방식을 정한다"}
  SW -->|"usePg === true"| SEC2["**구획 2 · PG 설정** (켰을 때만 존재)<br/>PG사 toss 토스페이먼츠 / inicis KG이니시스 / nice 나이스페이먼츠 / kakaopay 카카오페이<br/>연동 모드 test 테스트 / live 운영<br/>상점 ID (MERCHANT_ID_MAX 60)<br/>결제수단 다중선택 card·transfer·vbank·phone·easypay<br/>toggleMethod 는 카탈로그 순서로 되맞춘다(켰다 껐다 한 순서가 저장값에 남지 않게)<br/>※ 꺼져 있을 때는 **자리를 없앤다** — 잠가 두면 지금 무엇을 정할지 흐려진다"]
  SW -->|"usePg === false"| SEC3["**구획 3 · 문의 전환 안내** (껐을 때만 존재)<br/>안내 문구 TextareaField (INQUIRY_GUIDE_MAX 200)<br/>hint '상품 카드와 프로그램 상세의 문의하기 버튼 아래에 그대로 보입니다.'<br/>+ 상주 Alert info '지금은 PG 결제를 쓰지 않는 상태입니다…<br/>상품 문의 · 프로그램 문의로 들어옵니다.' (INQUIRY_PATH 링크 둘)"]

  SEC2 --> AXIS
  SEC3 --> AXIS

  AXIS{"**pgSellable = usePg && merchantId.trim() !== ''** (fail-closed)<br/>usePg 만 보지 않는다 — 켜 두고 상점 ID 가 비면 결제창을 못 연다<br/>그 상태로 '구매하기' 를 그리면 눌러도 아무 일 없는 버튼이 된다"}
  AXIS -->|"false"| CTA1["checkoutCta → kind 'inquiry' · label '문의하기'<br/>reason: usePg 면 'PG 상점 ID 가 비어 있어 결제창을 열 수 없습니다. 지금은 문의로 받습니다.'<br/>아니면 'PG 결제를 쓰지 않도록 설정되어 있어 결제 대신 문의로 받습니다.'<br/>inquiryPath = INQUIRY_PATH[domain]"]
  AXIS -->|"true"| CTA2["checkoutCta → kind 'purchase'<br/>label: product '구매하기' / program '후원하기'<br/>reason: mode==='test' 면 '… 테스트 모드로 결제창이 열립니다.<br/>실제 결제는 일어나지 않습니다.' 아니면 '… 결제창이 열립니다.'<br/>inquiryPath = null"]
  CTA1 --> PREV
  CTA2 --> PREV["CheckoutCtaPreview — 스위치 **바로 아래**에 두 도메인 모두 그린다<br/>여기서 정한 값은 이 화면 밖에서만 눈에 띄기 때문이다<br/>라벨을 이 화면이 고르지 않는다 — checkoutCta 가 정한다<br/>(미리보기가 자기 문구를 쓰면 고객 화면과 다른 미리보기가 된다)"]

  AXIS -.->|"같은 술어를 읽는 다른 축들"| FANOUT["pgLock(settings, section) — 잠금은 **값을 지우지 않는다**<br/>product-points · product-coupons · product-stock<br/>· product-shipping · coupon-admin · points-policy<br/>(옵션 구성과 상품 등록 자체는 잠기지 않는다)<br/><br/>resolvePriceDisplay — 축 B(상품 단위)와 합쳐 금액 칸 하나를 낸다<br/>**전역이 이긴다**: pgSellable 이 false 면 상품이 '금액 노출' 이라도<br/>'가격문의' 문구로 대체하고 amountFieldsLocked = true<br/><br/>ordersCanArrive · inquiryMenuState 도 같은 술어 위에 선다"]

  OK1 ~~~ SUB1

  subgraph SUB1["검증 — 전부 **교차 필드**다 (필수 여부가 usePg 에 달려 있다)"]
    PREV --> V{"paymentSettingsSchema .check(ctx)"}
    V -->|"merchantId 길이"| V0["'상점 ID 는 60자를 넘을 수 없습니다.'<br/>**켜짐과 무관하게** 본다 — 꺼진 채로도 저장되는 값이라"]
    V -->|"usePg && merchantId 공백"| V1["'PG 결제를 켰다면 상점 ID 를 입력하세요. PG 사에서 발급한 값입니다.'<br/>※ 형식(길이·문자셋·접두어)은 검사하지 않는다 —<br/>PG 사마다 다르고, 박아 두면 채번 규칙이 바뀌는 날 멀쩡한 값이 거절된다"]
    V -->|"usePg && methods.length === 0"| V2["'결제수단을 하나 이상 선택하세요.'<br/>묶음에 role='group' aria-label='결제수단 (필수)'<br/>+ aria-describedby=methodsErrorId (A11Y-11)"]
    V -->|"!usePg && inquiryGuide 공백"| V3["'PG 결제를 끄면 고객에게 보일 안내 문구가 필요합니다.'"]
    V -->|"inquiryGuide 길이"| V4["'안내 문구는 200자를 넘을 수 없습니다.'"]
    V0 --> VE["필드 인라인 오류 · 입력 보존<br/>저장 버튼은 !dirty || saving || loading 이면 비활성"]
    V1 --> VE
    V2 --> VE
    V3 --> VE
    V4 --> VE
    VE --> OK1
    V -->|"통과"| ONV["onValid — **여기서 저장하지 않는다**<br/>merchantId·inquiryGuide 를 trim 한 값을 쥐고 setPending"]
  end

  ONV --> CD{"ConfirmDialog intent='update' '결제 설정 저장'<br/>saveConfirmMessage(next, savedUsingPg) — 판매 방식이 바뀌는 저장이면 그 사실을 앞세운다"}
  CD -->|"켜짐 → 꺼짐"| CD1["'PG 결제를 끕니다. 저장하는 즉시 상품의 구매하기와 프로그램의 후원하기가<br/>문의하기로 바뀌고, 접수된 문의는 상품 문의·프로그램 문의로 들어옵니다. 저장할까요?'"]
  CD -->|"꺼짐 → 켜짐 (test)"| CD2["'PG 결제를 켭니다. 지금은 테스트 모드라 결제창은 열리지만<br/>실제 결제는 일어나지 않습니다. 저장할까요?'"]
  CD -->|"꺼짐 → 켜짐 (live)"| CD3["'PG 결제를 켭니다. 저장하는 즉시 고객이 상품·프로그램을<br/>실제로 결제할 수 있습니다. 저장할까요?'"]
  CD -->|"그 외"| CD4["'결제 설정을 저장하면 상품·프로그램 화면에 즉시 반영됩니다. 저장할까요?'"]
  CD -->|"취소·Esc·딤"| CX["cancelSave — controller.abort() + save.reset() + lock.release()<br/>진행 중이던 저장도 함께 취소한다"]
  CX --> OK1

  CD1 --> M
  CD2 --> M
  CD3 --> M
  CD4 --> M["confirmSave → runSave(pending, force=false)<br/>[EXC-08] useSubmitLock 동기 잠금 — disabled 렌더를 기다리지 않는다<br/>save.mutate({value, expectedRevision: data.revision, force, signal})<br/>내가 읽은 revision 을 함께 보낸다"]

  M --> MR{"결과"}
  MR -->|"성공"| MOK["**저장이 성립한 뒤에만** writePaymentSettings(saved.value)<br/>(data-source 의 store.save 안 — 이 한 줄이 없으면 설정은 저장됐는데<br/>상품 카드의 버튼은 그대로인 어긋남이 생긴다)<br/>reset(toPaymentFormValues(next)) — 새 기준선 · dirty 해제 → 이탈 가드도 내려감<br/>toast: usePg 면 '결제 설정을 저장했습니다. 상품·프로그램에서 결제로 판매합니다.'<br/>아니면 '결제 설정을 저장했습니다. 상품·프로그램의 버튼이 문의하기로 바뀌었습니다.'"]
  MR -->|"409 isSettingsConflict"| CF["setConflict(cause.latest) — **덮어쓰지 않는다** (EXC-04)<br/>**실패·409 에서는 writePaymentSettings 를 부르지 않는다**<br/>거절된 저장이 판매 방식을 바꾸면 화면과 앱이 갈라진다"]
  MR -->|"실패"| ME["saveError '결제 설정을 저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'<br/>확인 다이얼로그 안 danger 배너 — 재클릭이 재시도 (재현: ?fail=save)"]
  MR -->|"isAbort"| AB["[EXC-09] 취소는 실패가 아니다 — 무시"]
  ME --> M

  CF --> CFD{"ConflictDialog subject='결제 설정'<br/>latestBy/latestAt + divergedLabels(getValues(), latest.value, PAYMENT_FIELD_LABELS)<br/>PG 결제 사용 · PG사 · 상점 ID · 연동 모드 · 결제수단 · 문의 전환 안내 문구"}
  CFD -->|"최신 내용 불러오기"| CF1["reset(toPaymentFormValues(latest.value)) + refetch<br/>내 입력을 버린다 · toast '최신 결제 설정을 불러왔습니다.'"]
  CFD -->|"내 변경으로 덮어쓰기"| CF2["runSave(getValues(), force=true) → 다시 M"]
  CFD -->|"닫기"| CF3["closeConflict — abort + save.reset() + lock.release()"]
  CF1 --> OK1
  CF2 --> M
  CF3 --> OK1
  MOK --> Q

  OK1 --> GUARD["미저장 이탈 가드 — SettingsFormShell 이 dirty && !saving 으로 세운다<br/>'결제 설정에 저장하지 않은 변경 사항이 있습니다.<br/>이 화면을 벗어나면 입력한 내용이 사라집니다.'"]
  GUARD --> S

