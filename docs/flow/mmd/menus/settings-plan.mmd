%% 플랜·이용 현황 · /settings/plan
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  ANY(["어느 라우트든 · AppShell 의 &lt;Outlet&gt; 을 감싼다"]) --> ORDER["**중첩 순서가 곧 판정 순서다 — 뒤집지 마라**<br/>① 인증 → 없으면 /login<br/>② RequireEntitlement — 샀는가<br/>③ RequirePermission — 권한이 있는가 (403)<br/>④ 도메인 설정(PG 스위치 등)은 화면 안의 일<br/>플랜이 바깥인 이유: 사지 않은 기능에 '권한이 없습니다' 라고 말하면<br/>운영자는 관리자에게 권한을 요청하고, 관리자도 켤 수 없어 지원 티켓이 된다"]
  ORDER --> RE{"useRouteEntitlement() = entitlementStateForPath(plan, pathname)<br/>→ entitlementStateOf(plan, key) 3상태"}

  RE -->|"granted"| G["children 렌더 — 통과"]
  RE -->|"absent"| A["&lt;Navigate to='/dashboard' replace /&gt;<br/>판매하지 않는 모듈이라 살 수도, 권한을 받을 수도 없다<br/>이 계정에 **존재하지 않는 주소**라 설명 대신 되돌린다<br/>replace 인 이유: 뒤로 가기가 없는 주소로 되돌아가는 고리를 만들지 않는다"]
  RE -->|"locked"| U["&lt;UpgradeScreen reason upgradeTo /&gt;<br/>title '{티어} 플랜에서 사용할 수 있습니다'<br/>description = lockReason + ' 플랜을 올리면 이 화면이 그대로 열리고,<br/>지금까지 쌓인 데이터도 그대로 남아 있습니다.'<br/>[플랜 보기](외부 &lt;a&gt; PLAN_PORTAL_URL, target=_blank rel=noopener noreferrer)<br/>[현재 플랜 확인] → PLAN_PAGE_PATH<br/>**참조 코드가 없다** — 신고할 고장이 아니라 계약 상태다<br/>403(ForbiddenScreen)과 섞지 않는다: 다른 사람이 다른 행동을 해야 한다"]

  DECIDE{"entitlementStateOf — **실패 방향이 권한과 정반대다(fail-open)**"} --> D0["value = resolveEntitlement = overrides[key] ?? entitlements[key]<br/>**overrides 가 tier 를 이긴다**"]
  D0 --> D1{"판정"}
  D1 -->|"value === undefined"| DG1["**granted** — 응답에 없는 키는 '못 산 기능' 이 아니라<br/>'서버 카탈로그가 앱보다 오래됐다' 일 가능성이 훨씬 높다<br/>차단으로 읽으면 새 모듈이 출시일에 전 고객에게서 사라진다"]
  D1 -->|"entitlementEnabled(value)"| DG2["**granted**<br/>switch: enabled · quota: limit==='unlimited' || limit &gt; 0<br/>level: level !== 'none'<br/>※ 한도 0 은 '쓸 수 없다', 쿼터 소진(200/200)은 생성만 막고 화면은 연다"]
  D1 -->|"꺼짐 && 카탈로그에 키 없음"| DG3["**granted** — 무엇을 사야 하는지 말할 수 없으므로 열어 둔다"]
  D1 -->|"꺼짐 && spec.minTier === null"| DA["**absent** — 어떤 플랜에도 번들되지 않는다(예: marketing.sms)<br/>발송사 계약이 따로 있어야 켜지므로 플랜을 올려도 저절로 안 열린다<br/>살 수 없는 것에 자물쇠를 달면 결제 페이지를 뒤지다 아무것도 못 찾는다"]
  D1 -->|"꺼짐 && spec.minTier 있음"| DL["**locked** { reason: '{모듈} 기능은 {티어} 플랜부터 사용할 수 있습니다.',<br/>upgradeTo: spec.minTier }"]
  DG1 --> RE
  DG2 --> RE
  DG3 --> RE
  DA --> RE
  DL --> RE

  STORE["entitlement-store (zustand + localStorage 'tds-admin.plan')<br/>loadState: 저장값 없음·JSON 파손·프라이빗 모드 → **DEFAULT_PLAN_STATE**<br/>(tier 'enterprise' · 전 기능 가용) — permission-store 는 fail-closed 인데<br/>여기서 같은 자세를 취하면 '저장값 파손 = 전 기능 정지' 가 된다<br/>normalizePlanState: 티어를 못 읽으면 기본값 · 개별 키가 깨지면 **그 키만 없애** granted 로<br/>응답에 없던 키를 티어 정의로 채우지 않는다(채우면 새 모듈이 전 고객에게서 잠긴다)<br/>subscribeToOtherTabs — 다른 탭의 플랜 변경을 storage 이벤트로 따라간다"] --> DECIDE
  STORE --> S

  S(["진입 /settings/plan — **조회 전용 화면**"]) --> P0["usePlan() — 스토어 조각 구독<br/>이 화면에는 폼도 저장도 없다: 구독·결제·계약은 사내 홈페이지 소관이고<br/>여기에 변경 수단을 두면 실제 계약과 어긋나는 **두 번째 정본**이 생긴다<br/>(청구서·인보이스·카드 등록도 같은 이유로 없다)<br/>TODO(backend): GET /api/tenant/entitlements — 쓰기 엔드포인트가 없다"]

  P0 --> NOTE{"상단 배너 둘 (있을 때만)"}
  NOTE -->|"billingNotice(plan)"| N1{"billingState"}
  N1 -->|"'past_due' 결제 지연"| N1a["Alert warning '결제가 확인되지 않아 지금은 조회만 가능합니다.<br/>사내 홈페이지에서 결제 상태를 확인해 주세요.'"]
  N1 -->|"'suspended' 이용 정지"| N1b["Alert warning '구독이 정지되어 지금은 조회만 가능합니다.<br/>사내 홈페이지에서 구독을 다시 활성화해 주세요.'"]
  N1 -->|"'active' 정상"| N1c["배너 없음 (null)"]
  NOTE -->|"planChangeNotice(plan)"| N2["effectiveAt 이 **미래일 때만** Alert info<br/>'{YYYY-MM-DD}에 플랜 변경이 적용됩니다.<br/>변경 내용은 사내 홈페이지에서 확인해 주세요.'<br/>**무엇이 사라지는지는 말하지 않는다** — 이 어드민은 받는 쪽이라<br/>다음 플랜의 엔타이틀먼트를 모르고, 지어내면 예고와 실제가 갈라진다"]

  N1a --> RW["planReadOnly = billingState !== 'active'<br/>미납·정지는 기능을 **지우지 않는다** — 전부 읽기 전용으로 내려앉을 뿐<br/>usePlanWriteBlock() 이 화면들의 등록·수정·삭제 컨트롤을 잠근다<br/>**조회·내보내기는 잠그지 않는다** — 감추면 무엇을 결제할지도 확인 못 한다"]
  N1b --> RW

  P0 --> CARD1["카드 '현재 플랜' + StatusBadge(plan.planLabel)<br/>'지금 계약된 플랜과 그 플랜에 포함된 기능입니다.<br/>플랜 변경·결제는 사내 홈페이지에서 진행합니다.'<br/>dl: 플랜 등급(free 무료 / basic 베이직 / pro 프로 / enterprise 엔터프라이즈)<br/>· 청구 상태 배지(active success / past_due warning / suspended danger)<br/>· 변경 적용 예정(없으면 '없음')<br/>'플랜을 바꾸려면 사내 홈페이지의 요금제 안내에서 진행해 주세요.<br/>이 화면에서는 바꿀 수 없습니다.' → PLAN_PORTAL_URL"]

  P0 --> CARD2["카드 '포함 기능' — 표 기능 · 상태 · 사용량·수준<br/>'잠긴 기능은 메뉴에 남아 있고, 들어가면 어떤 플랜에서 열리는지 안내합니다.<br/>잠금은 이미 쌓인 데이터를 지우지 않습니다.'"]
  CARD2 --> ROWS{"toRows(plan) — MODULE_SPECS 를 훑는다"}
  ROWS -->|"state.kind === 'absent'"| RX["**행 자체를 그리지 않는다**(continue)<br/>살 수 없는 것을 표에 올리면 그것이 곧 티저다"]
  ROWS -->|"'granted'"| RG["tone success · status '포함'<br/>detail = moduleDetail: quota 면 planQuotaStatus(...).text<br/>('상품 200/200' 또는 '상품 12건 · 무제한')<br/>level 이면 LEVEL_LABEL — none 미포함 / basic 기본 / advanced 고급 + ' 수준'<br/>switch 면 빈 문자열 → 표에는 '—'"]
  ROWS -->|"'locked'"| RL["tone neutral · status '{티어} 플랜부터'<br/>detail 은 빈 문자열"]

  RG --> QT["쿼터 — planQuotaStatus 는 **배선된 실제 건수가 저장값 usage 를 이긴다**<br/>registerEntitlementUsageLookup 의 자리를 src/wiring.ts 가 채운다<br/>미배선이면 null → 저장값 usage 로 되돌아간다<br/>(여기서 0 을 주면 한도가 찬 계정도 등록이 열린다 — '모른다' 와 '없다' 는 다르다)<br/>exhausted 면 quotaCreateBlock '{텍스트} · 상위 플랜에서 늘릴 수 있습니다.'<br/>**create 만 막는다** — 초과분을 삭제하지도, 어느 항목이 초과인지 앱이 정하지도 않는다"]

  P0 --> DEV["import.meta.env.DEV 일 때만 &lt;PlanDevPanel /&gt;<br/>devSetTier / devSetBillingState — vite 가 운영 빌드에서<br/>이 분기를 상수 false 로 접어 패널 코드까지 통째로 제거한다<br/>(운영 화면에는 플랜 변경 수단이 없다)<br/>devSetTier 는 overrides·billingState·effectiveAt 을 남긴다 — 티어와 다른 축이라"]

  U --> S
  A --> DASH(["/dashboard"])

