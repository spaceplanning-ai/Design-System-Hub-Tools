%% 사이트 설정 · /settings/site
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /settings/site"]) --> Q["useSettingsQuery(siteSettingsKey, siteSettingsStore)<br/>Revisioned&lt;SiteSettingsValues&gt; — 값 + revision<br/>useForm(zodResolver(siteSettingsSchema))<br/>data 도착 시 reset(data.value) 로 기준선 설정"]
  Q --> LS{"SettingsFormShell 상태"}
  LS -->|"loadFailed"| E1["폼 대신 실패 화면 + '다시 시도'(refetch)"]
  LS -->|"isFetching"| L1["카드 골격 + 스켈레톤"]
  LS -->|"!canUpdate"| RO["info 배너 — 읽기 전용 안내<br/>저장 컨트롤 자체를 렌더하지 않는다 (EXC-03)<br/>눌러 보고 403 받는 자리를 만들지 않는다"]
  LS -->|"성공 · canUpdate"| OK1["폼 본문 + AuditNote(최종 수정자·시각)"]
  E1 --> Q
  L1 --> OK1
  RO --> OK1

  OK1 ~~~ SUB1

  subgraph SUB1["폼 구성 — SettingLayout(좌: 라벨·설명 / 우: 입력)"]
    B["사이트 기본 정보 — siteName(CountedInput, 최대 길이 카운터)<br/>설명 · 토글 · 공개 범위 RadioCardGroup(전체 공개 / 비공개)"]
    I["사이트 표시 이미지 — favicon · ogImage · privateImage<br/>useAssetUpload: 슬롯별 busy/error<br/>업로드 실패는 그 슬롯 옆 인라인"]
    P["미리보기 — BrowserTabPreview · OgCardPreview<br/>입력이 실제로 어떻게 보이는지 즉시 확인"]
    W["visibility==='private' 이면 상주 경고<br/>'저장하면 관리자를 제외한 방문자는 접속할 수 없습니다'"]
  end

  OK1 --> SUB["저장 제출(onSubmit)"]
  SUB --> V{"siteSettingsSchema 검증"}
  V -->|"실패"| VE["필드 인라인 오류 · 입력 보존<br/>저장 버튼은 !dirty || saving || loading 이면 비활성"]
  VE --> OK1
  V -->|"통과"| CD["여기서 저장하지 않는다 — 값을 쥐고 ConfirmDialog<br/>비공개 전환이면 그 사실을 문구 앞에 세운다<br/>'저장하는 즉시 관리자를 제외한 방문자는 접속할 수 없습니다'"]

  CD --> CC{"확인 / 취소·Esc·딤"}
  CC -->|"취소"| CX["pending 해제 + 진행 중이던 저장도 abort · save.reset()"]
  CX --> OK1
  CC -->|"확인"| M["save.mutate({value, expectedRevision, force, signal})<br/>내가 읽은 revision 을 함께 보낸다"]

  M --> MR{"결과"}
  MR -->|"409 충돌"| CF["ConflictDialog '기본 설정이 이미 변경되었습니다'<br/>+ diff 로 갈린 항목 라벨 나열"]
  MR -->|"실패"| ME["serverError 배너<br/>'기본 설정을 저장하지 못했습니다' · 입력 보존"]
  MR -->|"성공"| MOK["reset(values) — 저장한 값이 새 기준선<br/>dirty 해제 → 이탈 가드도 함께 내려감<br/>성공 토스트 '기본 설정을 저장했습니다'"]
  ME --> M

  CF --> CFC{"선택"}
  CFC -->|"최신 내용 불러오기"| CF1["reset(latest.value) + refetch<br/>내 입력을 버린다 · 토스트 '최신 기본 설정을 불러왔습니다'"]
  CFC -->|"내 변경으로 덮어쓰기"| CF2["force:true 로 재저장<br/>실패하면 다이얼로그 안 danger 배너 · 재클릭=재시도"]
  CF1 --> OK1
  CF2 --> M

  OK1 --> GUARD["미저장 이탈 가드 — useUnsavedChangesDialog(dirty && !saving)<br/>브라우저 이탈 · 앱 내 링크 · 뒤로가기 세 경로<br/>navigate() 프로그램 이동은 가드를 지나친다 — 쓰지 않는다"]
  MOK --> Q

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class LS,V,CC,MR,CFC gate
  class E1,VE,ME,CF err
  class OK1,MOK ok
