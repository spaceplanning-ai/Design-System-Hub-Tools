flowchart TD
  S(["진입 /stats/keywords"]) --> PERM{"StatsPageShell<br/>can(navPageResourceId, 'read') ?"}
  PERM -->|"없음 (URL 직접 입력)"| DENY["'접근 권한이 없습니다' 화면 (EXC-03)"]
  PERM -->|"있음"| URL["useStatsParams — 조회 조건의 단일 원천은 URL (IA-13)<br/>preset·start·end·compare·segment·metric<br/>sort·dir·page·size·q · 기본 정렬 sort=searchCount desc<br/>view 는 'ranking' 하나뿐 — 축을 고를 것이 없다"]

  URL --> RANGE{"periodErrorOf(period)"}
  RANGE -->|"종료일 < 시작일"| RERR["DateRangeField 옆 인라인 오류<br/>본문을 그리지 않는다"]
  RANGE -->|"정상"| Q["useStatsQuery<br/>key=['stats','keywords',period,comparePeriod,compare]<br/>fetchKeywordStats({period, comparePeriod}, signal)"]

  Q --> ST{"조회 상태 (STATE-02)"}
  ST -->|"query.error !== ''"| E1["인라인 danger Alert + '다시 시도'"]
  ST -->|"isFirstLoad"| L1["KPI·차트·표 스켈레톤"]
  ST -->|"성공 · 0건"| EMP["StatsEmpty label='검색어'<br/>검색어(q)만 걸렸으면 검색어 지우기,<br/>필터가 걸렸으면 '필터 초기화' (STATE-05)"]
  ST -->|"성공"| OK1["본문 3단 — KPI → 추이 → 검색어 순위 표"]
  E1 --> Q
  L1 --> OK1
  EMP --> COND

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    K["StatsKpiRow 5종<br/>검색수 · 순 검색어 수 · 검색결과 없음<br/>클릭률 · 구매전환율"]
    C["StatsTrendCard 지표 3종 (metric)<br/>검색수 · 검색결과 없음 · 구매전환율"]
    V["세그먼트=검색어 유형 3종<br/>전체 · 결과 있음 · 결과 없음"]
    B["검색어 순위 표 7칸<br/>검색어(결과 0건이면 warning 배지) · 검색수<br/>검색결과 수 · 클릭수 · 클릭률 · 구매건수 · 구매전환율"]
    F["StatsFilterBar 에 검색 입력이 있다<br/>searchLabel='검색어' — 통계 6화면 중 유일"]
  end

  OK1 --> COND["조회 조건 변경 → URL 직렬화"]
  COND --> P1["setPreset / setPeriod"]
  COND --> P2["setCompare(직전·전년) · setSegment(검색어 유형)<br/>기본값이면 파라미터 삭제 · page 되돌림"]
  COND --> P3["setMetric — keepPage:true (차트는 표와 무관)"]
  COND --> P4["setKeyword(useDebouncedSearch, COMP-10)<br/>값이 실제로 바뀔 때만 커밋 — 아니면 ?page=N 이 사라진다"]
  P1 --> Q
  P2 --> Q
  P3 --> Q
  P4 --> Q

  OK1 --> INT["표 상호작용"]
  INT --> I1["toggleSort(key) — 검색수 내림차순이 기본 (ERP-04)"]
  INT --> I2["setPage · setPageSize (ERP-05)"]
  INT --> I3["내보내기 — export 권한 없으면 버튼 부재<br/>현재 조건 전체 CSV (ERP-12)"]
  I1 --> Q
  I2 --> Q
  I3 --> OK1

  OK1 --> RO["쓰기 경로 없음 — 조회 전용<br/>검색어 사전·추천어 편집 라우트가 없다"]
  RO --> BACK["뒤로가기 = 조건이 살아있는 URL 로 복귀"]

