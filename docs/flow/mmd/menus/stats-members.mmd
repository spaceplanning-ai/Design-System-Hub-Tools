flowchart TD
  S(["진입 /stats/members"]) --> PERM{"StatsPageShell<br/>can(navPageResourceId, 'read') ?"}
  PERM -->|"없음 (URL 직접 입력)"| DENY["'접근 권한이 없습니다' 화면 (EXC-03)"]
  PERM -->|"있음"| URL["useStatsParams — 조회 조건의 단일 원천은 URL (IA-13)<br/>preset·start·end·compare·segment·view·metric<br/>sort·dir·page·size·q<br/>기본값은 URL 에 쓰지 않는다 · 갱신은 replace"]

  URL --> RANGE{"periodErrorOf(period)"}
  RANGE -->|"종료일 < 시작일"| RERR["DateRangeField 옆 인라인 오류<br/>본문을 그리지 않는다"]
  RANGE -->|"정상"| Q["useStatsQuery<br/>key=['stats','members',period,comparePeriod,compare]<br/>fetchMemberStats({period, comparePeriod}, signal)"]

  Q --> ST{"조회 상태 (STATE-02)"}
  ST -->|"query.error !== ''"| E1["인라인 danger Alert + '다시 시도'"]
  ST -->|"isFirstLoad"| L1["KPI·차트·표(또는 막대) 스켈레톤"]
  ST -->|"성공 · 0건"| EMP["StatsEmpty — 일자별 '가입 기록' / 등급별 '회원 등급'<br/>hasActiveFilters 면 '필터 초기화' (STATE-05)"]
  ST -->|"성공"| OK1["본문 3단 — KPI → 추이 → 드릴다운"]
  E1 --> Q
  L1 --> OK1
  EMP --> COND

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    K["StatsKpiRow 4종<br/>신규 가입 · 탈퇴(isLowerBetter) · 순증 · 누적 회원 수<br/>신규만 세면 탈퇴가 같은 수로 빠져도 성장으로 읽힌다"]
    C["StatsTrendCard 지표 4종 (metric)<br/>신규 가입 · 탈퇴 · 순증 · 누적"]
    V["세그먼트=가입 경로 5종<br/>전체·이메일·네이버·카카오·구글<br/>KPI·추이·표를 모두 좁힌다"]
    B["드릴다운 축(view) 2종<br/>일자별 → StatsTable(순증은 +/- 부호 표기, ERP-08)<br/>등급별 → ShareBarList 구성비 막대(일반·실버·골드·VIP)"]
  end

  OK1 --> COND["조회 조건 변경 → URL 직렬화"]
  COND --> P1["setPreset / setPeriod (custom 이면 start·end 유지)"]
  COND --> P2["setCompare(직전·전년) · setSegment(가입 경로)<br/>기본값이면 파라미터 삭제 · page 되돌림"]
  COND --> P3["setView — sort·dir 초기화 (표↔막대 전환)<br/>setMetric — keepPage:true"]
  COND --> P4["setKeyword — 값이 실제로 바뀔 때만 커밋"]
  P1 --> Q
  P2 --> Q
  P3 --> Q
  P4 --> Q

  OK1 --> INT["상호작용"]
  INT --> I1["toggleSort(key) — 일자별 표에서만 (ERP-04)<br/>등급별은 4행 스냅샷이라 정렬·페이지가 없다"]
  INT --> I2["setPage · setPageSize (ERP-05)"]
  INT --> I3["내보내기 — export 권한 없으면 버튼 부재<br/>view 에 따라 stats-members-daily / -tier<br/>등급별 CSV 는 구성비까지 담는다 (ERP-12)"]
  I1 --> Q
  I2 --> Q
  I3 --> OK1

  OK1 --> RO["쓰기 경로 없음 — 조회 전용<br/>개별 회원은 여기서 열 수 없다<br/>(사람 하나를 고치는 화면은 /users/members)"]
  RO --> BACK["뒤로가기 = 조건이 살아있는 URL 로 복귀"]

