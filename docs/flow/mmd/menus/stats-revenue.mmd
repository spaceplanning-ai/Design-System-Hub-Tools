  ST -->|"성공"| OK1["본문 3단 — KPI → 추이 → 드릴다운 표"]
  E1 --> Q
  L1 --> OK1
  EMP --> COND

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    K["StatsKpiRow 5종<br/>결제합계 · 환불합계(isLowerBetter) · 순매출<br/>결제건수 · 객단가"]
    C["StatsTrendCard 지표 5종 (metric)<br/>순매출 · 결제합계 · 환불합계 · 결제건수 · 객단가"]
    V["세그먼트=결제수단 5종<br/>전체·신용카드·계좌이체·가상계좌·간편결제"]
    B["드릴다운 축(view) 2종<br/>일자별 → 금액 5칸 + 과세/면세/영세 3칸<br/>결제수단별 → 금액 5칸만(세 구분이 갈리지 않는다)<br/>수단을 좁히면 그 한 줄만 남긴다"]
    U["ERP-07 — 금액 칸에 '원'을 붙이지 않는다<br/>단위는 헤더가 갖고(withUnitSuffix) 칸은 숫자만"]
  end

  OK1 --> COND["조회 조건 변경 → URL 직렬화"]
  COND --> P1["setPreset / setPeriod"]
  COND --> P2["setCompare(직전·전년) · setSegment(결제수단)<br/>기본값이면 파라미터 삭제 · page 되돌림"]
  COND --> P3["setView — sort·dir 초기화(컬럼 구성이 바뀐다)<br/>setMetric — keepPage:true"]
  COND --> P4["setKeyword — 값이 실제로 바뀔 때만 커밋"]
  P1 --> Q
  P2 --> Q
  P3 --> Q
  P4 --> Q

  OK1 --> INT["표 상호작용"]
  INT --> I1["toggleSort(key) (ERP-04)<br/>결제수단별의 라벨 컬럼은 정렬 값이 없다(4줄)"]
  INT --> I2["setPage · setPageSize (ERP-05)"]
  INT --> I3["내보내기 — export 권한 없으면 버튼 부재<br/>stats-revenue-(view) · 현재 조건 전체 (ERP-12)"]
  I1 --> Q
  I2 --> Q
  I3 --> OK1

  OK1 --> RO["쓰기 경로 없음 — 조회 전용<br/>주문·환불을 여기서 처리하지 않는다"]
