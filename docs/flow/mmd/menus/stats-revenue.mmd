  RANGE -->|"종료일 < 시작일"| RERR["DateRangeField 옆 인라인 오류<br/>본문을 그리지 않는다"]
  RANGE -->|"정상"| Q["useStatsQuery<br/>key=['stats','revenue',period,comparePeriod,compare]<br/>fetchRevenueStats({period, comparePeriod}, signal)"]

  Q --> ST{"조회 상태 (STATE-02)"}
