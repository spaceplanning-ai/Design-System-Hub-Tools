flowchart TD
  S(["진입 /stats/traffic"]) --> PERM{"StatsPageShell<br/>can(navPageResourceId, 'read') ?"}
  PERM -->|"없음 (URL 직접 입력)"| DENY["'접근 권한이 없습니다' 화면 (EXC-03)"]
  PERM -->|"있음"| URL["useStatsParams — 조회 조건의 단일 원천은 URL (IA-13)<br/>preset·start·end·compare·segment·view·metric<br/>sort·dir·page·size·q · 기본 정렬 sort=visits desc"]

  URL --> RANGE{"periodErrorOf(period)"}
  RANGE -->|"종료일 < 시작일"| RERR["DateRangeField 옆 인라인 오류<br/>본문을 그리지 않는다"]
  RANGE -->|"정상"| Q["useStatsQuery<br/>key=['stats','traffic',period,comparePeriod,compare]<br/>fetchTrafficStats({period, comparePeriod}, signal)"]

  Q --> NOTICE{"view === 'engine' ?"}
  NOTICE -->|"예"| N1["info Alert 고지<br/>'구글 유입은 개인정보 보호정책에 따라 검색어가<br/>전달되지 않아 참조검색어 없음으로 집계됩니다'<br/>유입수·매출은 정상, 검색어만 빈다"]
  NOTICE -->|"아니오"| ST
  N1 --> ST{"조회 상태 (STATE-02)"}

  ST -->|"query.error !== ''"| E1["인라인 danger Alert + '다시 시도'"]
  ST -->|"isFirstLoad"| L1["KPI·차트·표(또는 막대) 스켈레톤"]
  ST -->|"성공 · 0건"| EMP["StatsEmpty — 채널별 '유입' / 그 외 '유입 기록'<br/>hasActiveFilters 면 '필터 초기화' (STATE-05)"]
  ST -->|"성공"| OK1["본문 3단 — KPI → 추이 → 드릴다운"]
  E1 --> Q
  L1 --> OK1
  EMP --> COND

  OK1 ~~~ SUB1

  subgraph SUB1["이 화면 고유 구성"]
    K["StatsKpiRow 4종<br/>유입수 · 구매건수 · 매출액 · 구매전환율"]
    C["StatsTrendCard 지표 4종 (metric)<br/>유입 · 구매 · 매출 · 전환율"]
    V["세그먼트=유입 채널 6종<br/>전체·검색엔진·북마크·외부사이트·SNS·광고"]
    B["드릴다운 축(view) 3종<br/>채널별 → ShareBarList(채널·유입수·구성비)<br/>검색엔진별 → 표(고지 동반)<br/>랜딩페이지별 → 표<br/>공통 칸: 유입수·구매건수·매출액·구매전환율"]
  end

  OK1 --> COND["조회 조건 변경 → URL 직렬화"]
  COND --> P1["setPreset / setPeriod"]
  COND --> P2["setCompare(직전·전년) · setSegment(유입 채널)<br/>기본값이면 파라미터 삭제 · page 되돌림"]
  COND --> P3["setView — sort·dir 초기화 (축마다 컬럼이 다르다)<br/>setMetric — keepPage:true"]
  COND --> P4["setKeyword — 값이 실제로 바뀔 때만 커밋"]
  P1 --> Q
  P2 --> Q
  P3 --> Q
  P4 --> Q

  OK1 --> INT["상호작용"]
  INT --> I1["toggleSort(key) — 유입수 내림차순이 기본 (ERP-04)"]
  INT --> I2["setPage · setPageSize (ERP-05)"]
  INT --> I3["내보내기 — export 권한 없으면 버튼 부재<br/>stats-traffic-(view) · 현재 조건 전체 (ERP-12)"]
  I1 --> Q
  I2 --> Q
  I3 --> OK1

  OK1 --> RO["쓰기 경로 없음 — 조회 전용<br/>유입 소스·광고 설정을 여기서 고치지 않는다"]
  RO --> BACK["뒤로가기 = 조건이 살아있는 URL 로 복귀"]

