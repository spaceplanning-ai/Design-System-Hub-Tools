%% 문의 유형 · /support/categories
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /support/categories"]) --> Q["useCrudListQuery('support-categories', supportCategoryAdapter)<br/>항목 = 유형 + 사용 건수(listCategoryUsage)<br/>필터·검색 없음 — URL 조회 상태 없음"]
  Q --> ST{"조회 상태"}

  ST -->|"isFetching && data===undefined"| L["'불러오는 중…' (STATE-01)"]
  ST -->|"error"| E1["danger 배너 '문의 유형을 불러오지 못했습니다'<br/>+ 다시 시도(refetch)"]
  ST -->|"성공 · 0개"| EMP["'등록된 문의 유형이 없습니다.'"]
  ST -->|"성공 · 데이터 있음"| OK1["Card 안 목록 · '전체 N개'<br/>refreshing 이면 '새로고침 중…' (STATE-03)"]

  E1 --> Q
  L --> OK1
  EMP --> OK1
  OK1 --> ROW["CategoryRow 배지 2개<br/>사용/미사용(active) + categoryUsageLabel<br/>'사용 안 함' 또는 '티켓 3 · 템플릿 1'"]

  ROW --> ACT["액션 선택"]
  ACT --> A1["유형 추가 (모달)"]
  ACT --> A2["수정 (연필 · 모달)"]
  ACT --> A3["삭제 (휴지통)"]

  SUB1 ~~~ SUB2

  subgraph SUB1["삭제 게이트 — 사용 중 차단"]
    A3 --> G1{"categoryInUse(usage)<br/>ticketCount + templateCount &gt; 0"}
    G1 -->|"예"| G1X["삭제 버튼 disabled<br/>title/aria '티켓 3 · 템플릿 1 — 삭제할 수 없습니다'<br/>안내: 유형을 바꾸거나 사용여부를 꺼서 숨기세요"]
    G1 -->|"아니오"| D1["ConfirmDialog intent='delete'<br/>'이 작업은 되돌릴 수 없습니다'"]
    G1X --> OK1
    D1 --> DC{"확인 / 취소"}
    DC -->|"취소·Esc"| DCX["abort · deleteCategory.reset() · 오류 비움"]
    DCX --> OK1
    DC -->|"확인"| D2["useCrudDelete → removeCategory<br/>저장소도 사용 중이면 던진다(이중 방어 · 서버는 409)"]
    D2 --> DR{"성공?"}
    DR -->|"실패"| DERR["다이얼로그 유지 + 내부 danger 배너<br/>'삭제하지 못했습니다' · 재클릭=재시도"]
    DERR --> D2
    DR -->|"성공"| DOK["닫힘 · 성공 토스트 &#39;유형을 삭제했습니다&#39;"]
    DOK --> Q
  end

  subgraph SUB2["등록·수정 모달 — CategoryFormModal"]
    A1 --> M1["Modal (등록/수정 겸용 · editing 유무로 갈림)"]
    A2 --> M1
    M1 --> FLD["유형 이름 input (max CATEGORY_LABEL_MAX=30)<br/>사용여부 ToggleSwitch — 끄면 신규 선택에서만 숨는다"]
    FLD --> V{"supportCategorySchema 통과?"}
    V -->|"이름 공백·초과"| VE["필드 인라인 오류 + 첫 필드 포커스 복귀"]
    VE --> FLD
    V -->|"통과"| MU["isEdit ? useCrudUpdate : useCrudCreate<br/>updateCategory 는 티켓·템플릿의 비정규화 라벨도 갱신"]
    MU --> MR{"결과"}
    MR -->|"abort"| ABT["무시 (isAbort)"]
    MR -->|"오류"| SE["모달 안 danger 배너<br/>'저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
    MR -->|"성공"| MOK["모달 닫힘 + 성공 토스트<br/>추가/저장 문구 분기"]
    SE --> FLD
    MOK --> Q
    M1 --> DG["useModalDirtyGuard(isDirty && !saving)<br/>Esc·딤·×·취소 4경로 확인 (FEEDBACK-06)"]
    DG --> OK1
  end

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,G1,DC,DR,V,MR gate
  class E1,G1X,DERR,VE,SE err
  class OK1,DOK,MOK ok
