%% 자주 묻는 질문 · /support/faq
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /support/faq"]) --> SCOPE["**큐레이션 전용 화면**<br/>작성·수정·삭제·카테고리는 콘텐츠 관리 소관<br/>info 배너 + '콘텐츠 관리 FAQ 로 이동' → /content/faq"]
  SCOPE --> Q["useQuery(['support-faq','list'] → fetchCustomerFaqs)<br/>placeholderData=이전 목록 유지 · 필터·검색 없음"]
  Q --> ST{"조회 상태"}

  ST -->|"isFetching && data===undefined"| L["표 스켈레톤 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 '고객노출 FAQ 를 불러오지 못했습니다'<br/>+ 다시 시도(refetch)"]
  ST -->|"성공 · 데이터 있음"| OK1["CustomerFaqTable<br/>'전체 N건 · 노출 M건' (countVisible)<br/>refreshing 이면 '새로고침 중…' (STATE-03)"]

  E1 --> Q
  L --> OK1
  OK1 --> SORT["sortCustomerFaqs: order 오름차순 · 동순위는 id 안정 정렬"]

  SORT --> ACT["액션 선택 — 큐레이션 3축"]
  ACT --> A1["표시 순서 변경 (DnD · 이동 버튼)"]
  ACT --> A2["노출 토글 (visible)"]
  ACT --> A3["BEST 고정 토글 (pinned)"]
  ACT --> NA["등록·수정·삭제 없음<br/>ConfirmDialog·일괄 액션 경로 자체가 없다"]

  SUB1 ~~~ SUB2

  subgraph SUB1["순서 변경 — 낙관적 반영 + 롤백"]
    A1 --> R1["useReorderableRows(ids, onReorder, reordering)<br/>grip DnD + moveBy 이동 버튼(키보드 경로)"]
    R1 --> R2["이전 요청 abort · snapshot 보관<br/>setQueryData(applyFaqOrder(faqs, orderedIds)) — 낙관적"]
    R2 --> RG{"applyFaqOrder 무결성<br/>orderedIds 길이·구성이 목록과 일치?"}
    RG -->|"불일치"| RGX["원본을 sortCustomerFaqs 로 되돌린다(부분집합 방지)"]
    RG -->|"일치"| R3["order 를 1..n 으로 재부여 → reorderCustomerFaqs"]
    RGX --> OK1
    R3 --> RR{"결과"}
    RR -->|"abort"| RAB["무시 (isAbort)"]
    RR -->|"실패"| RERR["snapshot 롤백 + 실패 토스트<br/>retry = onReorder(orderedIds)"]
    RR -->|"성공"| ROK["'고객센터 표시 순서를 변경했습니다.'"]
    RERR --> R2
    ROK --> INV["onSettled: invalidateQueries(QUERY_KEY)"]
    INV --> Q
  end

  subgraph SUB2["노출 · BEST 토글"]
    A2 --> T1{"togglingIds.has(faq.id) ?<br/>같은 행 중복 클릭 차단"}
    A3 --> T1
    T1 -->|"예"| T1X["무시 (이미 처리 중)"]
    T1 -->|"아니오"| T2["markToggling(id,true) · snapshot 보관<br/>setQueryData 낙관적 반영"]
    T1X --> OK1
    T2 --> T3["setCustomerFaqVisible / setCustomerFaqPinned"]
    T3 --> TR{"결과"}
    TR -->|"abort"| TAB["무시 (isAbort)"]
    TR -->|"실패"| TERR["snapshot 롤백 + 실패 토스트<br/>'노출/BEST 고정을 변경하지 못했습니다' + retry"]
    TR -->|"성공"| TOK["성공 토스트<br/>'…를 노출합니다' / '…를 숨겼습니다'<br/>'…를 BEST 로 고정했습니다' / '해제했습니다'"]
    TERR --> T2
    TOK --> TFIN["onSettled: markToggling(id,false) + invalidateQueries"]
    TFIN --> Q
  end

  OK1 --> BACKTO["작성이 필요하면 /content/faq 로 이동<br/>(페이지 간 직접 import 없이 라우트 링크로 연결)"]
  BACKTO --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,RG,RR,T1,TR gate
  class E1,RGX,RERR,TERR,NA,T1X err
  class OK1,ROK,TOK ok
