%% 1:1 문의 · /support/tickets
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /support/tickets"]) --> URL["useListState({filterDefaults:{status,priority,channel,category='all'}})<br/>4축 + keyword 를 URL 이 소유 (IA-13)<br/>트리아지 큐가 Back·F5 를 견디고 공유된다"]
  URL --> PF["parseFilter × 3 (status·priority·channel)<br/>category 는 운영자 생성 id — 모르는 값은 빈 목록으로 흘린다"]
  PF --> Q["useCrudListQuery('support-tickets', ticketAdapter)<br/>읽기 전용 — 문의는 고객 채널이 접수한다"]
  Q --> ST{"조회 상태"}

  ST -->|"isFetching && data===undefined"| L["스켈레톤 5행 (STATE-01)"]
  ST -->|"error"| E1["danger 배너 + 다시 시도(refetch)"]
  ST -->|"성공 · 0건"| EMP["'문의가 없습니다.'"]
  ST -->|"성공 · 데이터 있음"| OK1["표 · refreshing 이면 '새로고침 중…' (STATE-03)<br/>상태·우선순위·유형·채널·제목·고객·담당·SLA·접수일시"]

  E1 --> Q
  L --> OK1
  EMP --> F
  OK1 --> F["필터·검색 조작"]
  F --> F1["상태 · 우선순위 SelectField"]
  F --> F2["채널 · 유형(listActiveCategories) SelectField"]
  F --> F3["검색: searchTickets 제목·문의번호·고객 (IME 안전 COMP-10)"]
  F1 --> URL
  F2 --> URL
  F3 --> URL

  OK1 --> SLA{"ticketSlaState(ticket, now)<br/>목표 = SLA_TARGET_HOURS[priority]<br/>urgent1·high4·normal24·low72h"}
  SLA -->|"answered · closed"| SL1["'응답완료' (met · success)"]
  SLA -->|"remaining ≤ 0"| SL2["'SLA 초과' (breached · danger)"]
  SLA -->|"remaining ≤ 목표창 × 0.25"| SL3["'SLA 임박' (due_soon · warning)"]
  SLA -->|"그 외"| SL4["'정상' (on_track)"]

  OK1 --> DET(["행 클릭 · '상세' 버튼<br/>→ /support/tickets/:id"])

  SUB1 ~~~ SUB2

  subgraph SUB1["상세 처리 — TicketDetailPage + TicketWorkspace"]
    DET --> DQ["useQuery detail → ticketAdapter.fetchOne<br/>없는 id → HttpError 404 (EXC-12)"]
    DQ --> DS{"상세 상태"}
    DS -->|"error"| DE["danger 배너 + 목록으로"]
    DS -->|"undefined"| DL["'불러오는 중…' 카드"]
    DS -->|"성공"| DV["SLA 배지 + slaRemainingLabel<br/>정보 + TicketTimeline(append-only)"]
    DL --> DV
    DV --> W1["담당 배정 input"]
    DV --> W2["상태 select = allowedNextStatuses(ticket.status)<br/>STATUS_FLOW: received→assigned·closed<br/>assigned→in_progress·closed<br/>in_progress→answered·closed<br/>answered→closed·in_progress<br/>closed→[] (종착)"]
    DV --> W3["답변/메모 composer (max 1000)<br/>템플릿 select = templatesForCategory(공용 '' + 동일 유형)<br/>선택 시 applyTemplate 로 {{고객명}}·{{문의번호}}·{{담당자}} 치환"]
  end

  subgraph SUB2["게이트 → 저장 → 복귀"]
    W1 --> AG{"assigneeError(status, assignee)<br/>statusRequiresAssignee: in_progress · answered"}
    W2 --> AG
    W3 --> AG
    AG -->|"담당 공백"| AG1["인라인 오류 '&#39;처리중&#39; 상태는 담당 배정이 필요합니다.'<br/>저장 버튼 disabled"]
    AG -->|"통과"| DIRTY{"isProcessDirty(ticket, draft)<br/>담당·상태·composer 중 하나라도 변경"}
    DIRTY -->|"아니오"| DIS["'처리 저장' disabled"]
    DIRTY -->|"예"| CLS{"willClose?<br/>status==='closed' && ticket.status!=='closed'"}
    CLS -->|"예"| CD["ConfirmDialog '문의 종결'<br/>'다시 열 수 없습니다' (EXC-11)<br/>취소 시 abort · 실패해도 닫히지 않고 재클릭=재시도"]
    CLS -->|"아니오"| SV
    CD --> SV["onSave"]
    SV --> CS{"canSetStatus(from, to, assignee)<br/>canTransition && 담당 요건"}
    CS -->|"거부"| CSX["serverError '허용되지 않는 상태 전이입니다.'"]
    CS -->|"허용"| MU["buildTimeline: assign·status·composer 이벤트 append<br/>useCrudUpdate.mutate(toTicketInput + …)"]
    CSX --> DV
    MU --> MR{"결과"}
    MR -->|"409 '다른 사용자가 먼저 변경한 문의입니다'"| CFL["serverError 배너 (EXC-04)"]
    MR -->|"오류"| SE["'저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
    MR -->|"성공"| MOK["composer·템플릿 초기화 · 성공 토스트<br/>detailQuery.refetch()"]
    CFL --> DV
    SE --> DV
    MOK --> DV
  end

  DV --> UNS["useUnsavedChangesDialog(dirty && !saving)"]
  DV --> BK["'목록으로' → /support/tickets"]
  UNS --> S
  BK --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,SLA,DS,AG,DIRTY,CLS,CS,MR gate
  class E1,DE,AG1,DIS,CSX,CFL,SE,SL2,SL3 err
  class OK1,MOK,SL1 ok
