%% 관리자 관리 · /users/admins
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /users/admins"]) --> LS["로컬 상태(useState)<br/>tab · groupId · keyword(250ms 디바운스)<br/>page · selectedIds<br/>※ URL 동기화 없음 — 회원 목록과 다른 점"]
  LS --> Q["useAdminsQuery({groupId, keyword, page})<br/>placeholderData 유지"]
  Q --> ST{"조회 상태"}

  ST -->|"isFetching && data===undefined"| L["표 스켈레톤 · 건수 '—' (STATE-01)"]
  ST -->|"error !== null"| E1["인라인 danger 배너<br/>'운영자 목록을 불러오지 못했습니다'<br/>+ 다시 시도(refetch)"]
  ST -->|"성공 · admins.length===0"| EMP["빈 표"]
  ST -->|"성공"| OK1["전체 운영자 N명 + 표<br/>선택 시 'M명 선택됨'"]

  E1 --> Q
  L --> OK1
  EMP --> FIL
  OK1 --> FIL["필터·검색·페이지"]
  FIL --> F1["AdminGroupPanel 그룹 선택<br/>GROUP_ALL 또는 그룹 id"]
  FIL --> F2["AdminsSearchCard 검색어"]
  FIL --> F3["Pagination · 조건 변경 시 page=1<br/>+ selectedIds 초기화"]
  F1 --> Q
  F2 --> Q
  F3 --> Q

  OK1 --> ACT["액션"]
  ACT --> A1["+ 운영자 등록 (canCreate 일 때만 노출)"]
  ACT --> A2["운영진 그룹 만들기"]
  ACT --> A3["운영진 그룹 삭제"]
  ACT --> A4["행 → 운영자 상세"]

  %% 그룹 생성
  A2 --> G1["CreateAdminGroupModal"]
  G1 --> GV{"검증 통과?"}
  GV -->|"아니오"| GVE["모달 안 인라인 오류"]
  GVE --> G1
  GV -->|"예"| GOK["모달 닫힘 · 성공 토스트<br/>그룹 목록/건수 자동 무효화"]
  GOK --> OK1

  %% 그룹 삭제 — 2단계
  A3 --> R1["1단계: useAdminGroupUsageQuery(groupId)<br/>참조 현황부터 조회 (다이얼로그는 아직 열지 않는다)"]
  R1 --> RG{"현황 판정"}
  RG -->|"usage.error"| RE1["danger 배너<br/>'사용 현황을 확인하지 못해 삭제할 수 없습니다'<br/>다이얼로그 열지 않음"]
  RG -->|"adminGroupDeletionBlock !== null<br/>(소속 운영자·발신 프로필 참조)"| RE2["danger 배너로 사유 표시<br/>ConfirmDialog 는 확인 버튼을 잠글 수 없어<br/>애초에 띄우지 않는다"]
  RG -->|"block === null"| R2["2단계: ConfirmDialog intent='delete'<br/>usableAsSender 여부로 문구 분기"]
  RE1 --> OK1
  RE2 --> OK1

  R2 --> RC{"확인 / 취소"}
  RC -->|"취소"| RX["abort + remove.reset()"]
  RX --> OK1
  RC -->|"확인"| R3["useDeleteAdminGroup.mutate"]
  R3 --> RR{"결과"}
  RR -->|"실패(경합 시 어댑터 문장)"| RERR["다이얼로그 유지 + 안의 배너<br/>재클릭 = 재시도"]
  RERR --> R3
  RR -->|"성공"| ROK["groupId=GROUP_ALL 로 복귀<br/>(지운 그룹이 필터에 남아 0건 되는 것 방지)<br/>성공 토스트"]
  ROK --> Q

  %% 등록/수정 폼
  A1 --> FP["AdminFormPage (/new · /:id/edit)<br/>useCrudForm + FormPageShell"]
  FP --> FV["adminSchema 검증<br/>닉네임·계정(이메일)·그룹·역할 필수"]
  FV --> FG{"editingSelf ?<br/>isCurrentOperator(loaded, currentAccount)<br/>※ 폼 값이 아닌 서버 원본 loaded 로 판정"}
  FG -->|"예"| FL["역할 셀렉트 잠금<br/>SELF_ROLE_CHANGE_REASON 을<br/>aria-describedby 로 연결"]
  FG -->|"아니오"| FE["역할 자유 선택 (권한 스토어 roles)"]
  FL --> FS
  FE --> FS["저장 제출"]
  FP --> FGE["그룹 목록 조회 실패 시<br/>'빈 셀렉트 = 그룹 없음' 오해 방지 배너 + 재시도"]
  FGE --> FS

  FS --> FR{"저장 결과"}
  FR -->|"검증 실패"| FRE["필드 인라인 오류 · 입력 보존"]
  FRE --> FS
  FR -->|"409 충돌"| FRC["충돌 다이얼로그 (useCrudForm)"]
  FRC --> FS
  FR -->|"서버 오류(중복 계정 등)"| FRS["serverError 배너 + errorReference<br/>입력 보존"]
  FRS --> FS
  FR -->|"성공"| FOK["목록으로 복귀 + 성공 토스트"]
  FOK --> Q

  %% 상세
  A4 --> D1["AdminDetailPage /users/admins/:id<br/>useAdminQuery — 회원 상세 재사용 아님"]
  D1 --> DS{"상세 상태"}
  DS -->|"isNotFound (404)"| DE1["'이미 삭제되었을 수 있습니다'<br/>다시 시도 없음 · 목록으로만"]
  DS -->|"기타 오류"| DE2["'운영자 정보를 불러오지 못했습니다'<br/>다시 시도 + 목록으로"]
  DS -->|"data===undefined"| DL["카드 스켈레톤"]
  DS -->|"성공"| DV["AdminProfileCards<br/>계정·부서·직급·그룹·역할·메모<br/>등급·적립금·쿠폰 없음"]
  DE2 --> D1
  DL --> DV

  DV --> DG{"삭제 가능?<br/>adminDeletionBlock(admin, guardContext)"}
  DG -->|"canRemove=false"| DGN["삭제 버튼 자체를 그리지 않음 (EXC-03)"]
  DG -->|"guardUnavailable / guardPending"| DGP["버튼 잠금<br/>'명부를 불러오지 못해 판단할 수 없습니다'"]
  DG -->|"본인 계정 또는 마지막 시스템 관리자"| DGB["버튼 잠금 + info 배너로 사유<br/>aria-describedby 연결"]
  DG -->|"block === null"| DD["ConfirmDialog intent='delete'"]
  DGN --> DV
  DGP --> DV
  DGB --> DV

  DD --> DC{"확인 / 취소"}
  DC -->|"취소"| DX["abort + reset"]
  DX --> DV
  DC -->|"확인"| DM["useDeleteAdmin.mutate"]
  DM --> DR{"결과"}
  DR -->|"실패(경합 시 서버가 같은 가드 문장 반환)"| DERR["다이얼로그 유지 + 안의 배너 · 재클릭=재시도"]
  DERR --> DM
  DR -->|"성공"| DOK["성공 토스트<br/>navigate('/users/admins', replace)"]
  DOK --> Q

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,GV,RG,RC,RR,FG,FR,DS,DG,DC,DR gate
  class E1,GVE,RE1,RE2,RERR,FRE,FRC,FRS,FGE,DE1,DE2,DGP,DGB,DERR err
  class OK1,GOK,ROK,FOK,DOK ok
