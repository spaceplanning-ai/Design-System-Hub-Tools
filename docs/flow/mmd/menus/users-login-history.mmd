%% 로그인 이력 · /users/login-history
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /users/login-history"]) --> INIT["로컬 상태(useState)<br/>outcome=all · accountKind=all<br/>period=last-30d · keyword(250ms) · page<br/>customDraft = presetRange('last-30d')"]
  INIT --> P{"period === 'custom' ?"}

  P -->|"아니오 (프리셋)"| PR["presetRange(period)<br/>코드가 만든다 — 틀릴 수 없다<br/>rangeIssues = []"]
  P -->|"예 (직접 지정)"| PC["validateCustomRange(draft)<br/>zod/mini · 기준 '오늘'은 KST"]

  PC --> PV{"검증 결과"}
  PV -->|"YYYY-MM-DD 아님 / 실재하지 않는 날짜"| PE1["해당 입력 칸 옆 인라인 오류"]
  PV -->|"to > today"| PE2["'미래 날짜는 조회할 수 없습니다.<br/>감사 기록에 미래는 없습니다.'"]
  PV -->|"from > to"| PE3["'시작일은 종료일보다 늦을 수 없습니다.'"]
  PV -->|"days > MAX_RANGE_DAYS"| PE4["'조회 기간은 최대 N일입니다.'"]
  PV -->|"통과"| PR

  PE1 --> BLK
  PE2 --> BLK
  PE3 --> BLK
  PE4 --> BLK["range = null → enabled:false<br/>조회 자체를 걸지 않는다<br/>요약줄 '조회 기간을 확인해 주세요.'"]
  BLK --> FIL

  PR --> Q["useLoginHistoryQuery(query, {enabled: range !== null})<br/>placeholderData 로 이전 행 유지"]
  Q --> ST{"조회 상태"}

  ST -->|"isFetching && data===undefined"| L["표 스켈레톤 (STATE-01)"]
  ST -->|"error !== null"| E1["인라인 danger 배너<br/>'로그인 이력을 불러오지 못했습니다'<br/>+ 다시 시도 — 토스트로 띄우지 않는다<br/>(사라지면 '기록 없음'과 구분 불가)"]
  ST -->|"성공 · entries.length===0"| EMP["빈 표 — 조건에 걸린 기록 없음"]
  ST -->|"성공"| OK1["전체 N건 + 표(8열, 가로 스크롤)<br/>실패 건수>0 이면 danger 톤으로 별도 표기"]

  E1 --> Q
  L --> OK1
  EMP --> FIL
  OK1 --> FIL["필터·검색 조작"]

  FIL --> F1["결과 필터 outcome (all/success/failure)"]
  FIL --> F2["계정 유형 accountKind"]
  FIL --> F3["기간 preset ↔ custom<br/>custom 진입 시 보던 구간을 물려준다<br/>(빈 입력으로 떨어뜨리지 않음)"]
  FIL --> F4["검색어 · Pagination<br/>조건 변경 시 page=1 · 총 페이지 축소 시 보정"]
  F1 --> P
  F2 --> P
  F3 --> P
  F4 --> P

  OK1 --> RO["행 클릭 → 그 계정의 상세<br/>회원 /users/members/:id · 운영자 /users/admins/:id<br/>미등록 계정은 가리킬 레코드가 없어 이동하지 않는다"]

  OK1 --> RD["쓰기 액션 없음<br/>삭제·수정·행 ⋯ 메뉴·체크박스 없음<br/>data-source 에 쓰기 함수가 하나도 없다 (불변 감사 로그)"]

  OK1 --> X1{"내보내기 클릭<br/>range === null 이면 무시"}
  X1 -->|"range null"| BLK
  X1 -->|"range 있음"| X2["useExportLoginHistory<br/>현재 페이지가 아닌 필터 전체"]
  X2 --> XR{"결과"}
  XR -->|"성공"| XOK["downloadCsv('login-history-YYYY-MM-DD', KST)<br/>성공 토스트에 실패 건수도 함께 적는다"]
  XR -->|"실패"| XERR["실패 토스트(자동 소멸 없음)<br/>retry = onExport"]
  XERR --> X2
  XOK --> OK1

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class P,PV,ST,X1,XR gate
  class PE1,PE2,PE3,PE4,BLK,E1,XERR err
  class OK1,XOK ok
