%% 회원 관리 · /users/members
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /users/members"]) --> URL["useListState<br/>page·tier·group·keyword·선택을<br/>URL 쿼리스트링이 소유 (IA-13)"]
  URL --> Q["useMembersQuery(query)<br/>placeholderData=이전 목록 유지"]
  Q --> ST{"조회 상태"}

  ST -->|"isFetching && data===undefined"| L["스켈레톤<br/>'불러오는 중…' (STATE-01)"]
  ST -->|"error !== null"| E1["인라인 danger 배너<br/>'회원 목록을 불러오지 못했습니다'<br/>+ 다시 시도(refetch)"]
  ST -->|"성공 · members.length===0"| EMP["빈 표<br/>필터/검색 결과 없음"]
  ST -->|"성공 · 데이터 있음"| OK1["표 + 전체 N명<br/>재조회 중엔 이전 행 유지<br/>(aria-busy)"]

  E1 --> Q
  L --> OK1
  EMP --> F
  OK1 --> F["필터·검색 조작"]

  F --> F1["등급 FilterPanel<br/>all/normal/vip/vvip"]
  F --> F2["그룹 FilterPanel<br/>GROUP_ALL + 그룹 id (AND 결합)"]
  F --> F3["검색어 (IME 안전 디바운스)"]
  F --> F4["Pagination · clampPage 보정<br/>총 페이지 축소 시 마지막 페이지로"]
  F1 --> URL
  F2 --> URL
  F3 --> URL
  F4 --> URL

  F2 --> GE{"그룹 목록 조회 실패?<br/>groupsError"}
  GE -->|"예"| GERR["패널 전용 재시도 경로<br/>refetchGroups"]
  GE -->|"아니오"| ACT
  GERR --> ACT["액션 선택"]

  OK1 --> ACT

  ACT --> A1["CSV 내보내기"]
  ACT --> A2["알림 발송 (행 ⋯ · 일괄)"]
  ACT --> A3["회원 삭제 (행 ⋯ · 일괄)"]
  ACT --> A4["+ 새 그룹 만들기 (모달)"]

  %% 내보내기
  A1 --> X1["useExportMembers<br/>현재 필터 전체 조회"]
  X1 --> XR{"성공?"}
  XR -->|"성공"| XOK["downloadCsv('members')<br/>성공 토스트 N명"]
  XR -->|"실패"| XERR["실패 토스트(자동 소멸 없음)<br/>retry=onExport"]
  XERR --> X1
  XOK --> OK1

  %% 알림
  A2 --> N1["확인 절차 없음 · 즉시 요청<br/>notifyingIds 로 행 잠금 '발송 중…'"]
  N1 --> NR{"결과 판정"}
  NR -->|"전원 성공"| NOK["성공 토스트"]
  NR -->|"부분/전체 실패"| NERR["실패 토스트<br/>'N명 중 M명 발송 실패' + 재시도"]
  NERR --> N1
  NOK --> OK1

  %% 삭제
  A3 --> D1["ConfirmDialog intent='delete'<br/>되돌릴 수 없음 안내"]
  D1 --> DC{"확인 / 취소"}
  DC -->|"취소·Esc·딤"| DCX["controller.abort()<br/>mutation.reset()"]
  DCX --> OK1
  DC -->|"확인"| D2["useDeleteMembers<br/>Promise.allSettled(targets)"]
  D2 --> DR{"failed > 0 ?<br/>(isAbort 제외)"}
  DR -->|"예"| DERR["다이얼로그 유지 + 안의 danger 배너<br/>목록 무효화 안 함 · 재클릭=재시도"]
  DERR --> D2
  DR -->|"아니오"| DOK["다이얼로그 닫힘 · clearSelection<br/>lists() 무효화 · 성공 토스트"]
  DOK --> Q

  %% 그룹 생성
  A4 --> G1["CreateGroupModal<br/>createGroupSchema (zod/mini)"]
  G1 --> GV{"검증 통과?<br/>이름 필수·GROUP_NAME_MAX_LENGTH"}
  GV -->|"아니오"| GVE["필드 인라인 오류"]
  GVE --> G1
  GV -->|"예"| G2["useCreateGroup → groups 무효화"]
  G2 --> GOK["모달 닫힘 + 성공 토스트"]
  GOK --> OK1

  %% 상세 서브플로우
  OK1 --> DET(["행 클릭 → /users/members/:id"])
  DET --> DQ["useMemberDetailQuery(id, listPath, fetchDetail)<br/>캐시 키에 listPath 포함"]
  DQ --> DS{"상세 상태"}
  DS -->|"error"| DE["'회원을 찾을 수 없습니다' 또는 조회 실패<br/>다시 시도 / 목록으로"]
  DS -->|"data===undefined"| DL["카드 스켈레톤"]
  DS -->|"성공"| DV["읽기 전용 카드<br/>정보·동의·활동·적립금·쿠폰·메모"]
  DL --> DV

  DV --> P1["비밀번호 변경 모달<br/>passwordChangeSchema: 8자+영문+숫자+일치"]
  DV --> P2["적립금 지급/차감<br/>금액 1 이상 정수·사유 필수·잔액 초과 차감 불가<br/>idempotencyKey 재사용(중복 지급 차단)"]
  DV --> P3["적립금 내역 삭제 (ConfirmDialog)"]
  DV --> P4["⋯ 메뉴: 회원 삭제 / 알림 발송"]
  P1 --> DOK2["성공 토스트 · lists() 무효화"]
  P2 --> DOK2
  P3 --> DOK2
  P4 --> P5["삭제 성공 시 navigate(listPath, replace)"]
  P5 --> S
  DOK2 --> DV

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,GE,XR,NR,DC,DR,GV,DS gate
  class E1,GERR,XERR,NERR,DERR,GVE,DE err
  class XOK,NOK,DOK,GOK,OK1,DOK2 ok
