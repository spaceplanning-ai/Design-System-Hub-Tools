%% 권한 관리 · /users/roles
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /users/roles"]) --> LD["usePermissionStore.loadState()<br/>localStorage 'tds-admin.roles'<br/>서버 조회 없음 — 로딩/오류 상태가 없다"]
  LD --> MIG{"저장값 형태"}
  MIG -->|"version===2"| M2["normalizeRoleState<br/>read 의존·그룹=합집합 불변식 통과"]
  MIG -->|"v1(역할+평면맵) / v0('tds-admin.permissions')"| M1["migrateLegacyRoleState<br/>migrateLegacyPermissions<br/>즉시 재저장 · 옛 키 제거"]
  MIG -->|"JSON 파손 · 저장소 접근 불가"| M0["createInitialRoleState() 폴백<br/>(메모리로 계속 동작)"]
  M2 --> V
  M1 --> V
  M0 --> V["화면 구성<br/>좌: RolePanel / 우: 헤더+매트릭스+위젯"]

  V --> SEL["selectedRole = selectedRoleOf(state, requestedRoleId)<br/>고르기 전이면 activeRole 과 동일"]
  SEL --> SYS{"selectedRole.system ?"}
  SYS -->|"예 (슈퍼어드민)"| SYSL["매트릭스·위젯 잠금<br/>'모든 권한을 갖습니다 · 바꿀 수 없습니다'<br/>이름 변경·삭제도 거부"]
  SYS -->|"아니오"| EDIT["편집 가능"]
  SYSL --> ACT
  EDIT --> ACT["액션 선택"]

  ACT --> A1["권한 체크 토글 (즉시 저장 · 저장 버튼 없음)"]
  ACT --> A2["역할 적용 / 데이터 범위 변경"]
  ACT --> A3["역할 추가 · 이름 변경"]
  ACT --> A4["역할 삭제"]

  %% 즉시 저장 토글
  A1 --> T1["setResourceAction · setActionForAll · setAllPermissions<br/>setWidget · setAllWidgets"]
  T1 --> TR["resources.ts 가 규칙을 강제<br/>조회 OFF → 나머지 액션 동반 OFF<br/>다른 액션 ON → 조회 동반 ON"]
  TR --> SAVE["mutate() → saveState(localStorage)<br/>실패해도 무시 (세션은 메모리로 유지)"]
  SAVE --> LIVE["적용 중 역할이면 사이드바·대시보드가<br/>리로드 없이 갱신 (PermissionProvider 구독)"]
  LIVE --> SEL

  %% 적용 / 범위
  A2 --> B1["activateRole(selectedRoleId)<br/>존재하는 역할일 때만 반영"]
  A2 --> B2["setScope(RoleScope)"]
  B1 --> BOK["성공 토스트 '역할을 적용했습니다'"]
  B2 --> SAVE
  BOK --> SEL

  %% 생성 / 이름 변경
  A3 --> C1["RoleFormModal (create · rename)"]
  C1 --> CV{"validateRoleName(name, roles, ignoreId)"}
  CV -->|"공백"| CV1["'역할명을 입력하세요.'"]
  CV -->|"ROLE_NAME_MAX_LENGTH 초과"| CV2["'역할명은 N자를 넘을 수 없습니다.'"]
  CV -->|"대소문자 무시 중복"| CV3["'이미 같은 이름의 역할이 있습니다.'"]
  CV -->|"통과"| CM{"수행 종류"}
  CV1 --> C1
  CV2 --> C1
  CV3 --> C1

  CM -->|"createRole"| CR["새 역할: 전 권한 OFF·위젯 OFF (최소 권한)<br/>생성 즉시 requestedRoleId 로 선택"]
  CM -->|"renameRole · 시스템 역할이면 거부"| RN["이름만 교체"]
  CR --> COK["모달 닫힘 + 성공 토스트"]
  RN --> COK
  COK --> SEL

  %% 삭제
  A4 --> D1{"isActive ?<br/>selectedRoleId === activeRoleId"}
  D1 -->|"예"| D1A["ConfirmDialog: '적용 중인 역할입니다.<br/>삭제하면 남아 있는 첫 역할이 대신 적용됩니다'"]
  D1 -->|"아니오"| D1B["ConfirmDialog: '되돌릴 수 없습니다'"]
  D1A --> D2
  D1B --> D2["확인 / 취소 (busy=false — localStorage 라 즉시 끝난다)"]

  D2 --> DC{"deleteRole 결과"}
  DC -->|"role===null"| DE1["실패 토스트 '역할을 찾을 수 없습니다.'"]
  DC -->|"role.system"| DE2["실패 토스트 '시스템 역할은 삭제할 수 없습니다.'"]
  DC -->|"roles.length <= 1"| DE3["실패 토스트 '마지막 역할은 삭제할 수 없습니다.'"]
  DC -->|"ok"| DOK["성공 토스트 · 남은 첫 역할로 activeRoleId 승계<br/>requestedRoleId 도 폴백"]
  DE1 --> SEL
  DE2 --> SEL
  DE3 --> SEL
  DOK --> SEL

  %% 크로스탭
  SEL --> XT["subscribeToOtherTabs()<br/>다른 탭의 storage 이벤트 → syncFromStorage()<br/>같은 탭 저장은 재진입하지 않아 루프 없음"]
  XT --> SEL

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class MIG,SYS,CV,CM,D1,D2,DC gate
  class M0,CV1,CV2,CV3,DE1,DE2,DE3,SYSL err
  class BOK,COK,DOK,LIVE ok
