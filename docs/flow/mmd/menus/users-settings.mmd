%% 고객 설정 · /users/settings
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /users/settings"]) --> Q["useTierPolicyQuery()<br/>등급 정책 단건 조회"]
  Q --> ST{"조회 상태"}

  ST -->|"error !== null"| E1["전체 화면 danger 배너<br/>'등급 정책을 불러오지 못했습니다'<br/>+ 다시 시도(refetch)"]
  ST -->|"firstLoading 또는 draft===null"| L["스켈레톤 3줄<br/>'등급 정책을 불러오는 중입니다…'"]
  ST -->|"성공"| INIT["draftFromPolicy(data)<br/>draft + baseline(serializeDraft) 동시 수립<br/>attempted=false"]

  E1 --> Q
  L --> INIT
  INIT --> EDIT["편집 화면<br/>좌: 등급 정책 + 산정 기준 / 우: 분포 미리보기"]

  EDIT --> C1["TierPolicyCard<br/>승급 조건(원) · 할인율(%)<br/>입력 중 sanitizeDigits · blur 에 천단위 포맷"]
  EDIT --> C2["TierCriteriaCard<br/>period(all·last-12m·last-6m)<br/>allowDemotion · recalcTrigger"]
  EDIT --> C3["TierDistributionCard<br/>computeDistribution(MEMBERS)<br/>정책이 유효할 때만 계산 · 읽기 전용"]

  C1 --> V["validateDraft(draft) 실시간 재계산"]
  C2 --> V
  V --> VE{"이슈 종류"}
  VE -->|"error<br/>정수 아님 · 할인율 0~DISCOUNT_MAX 밖<br/>승급 조건 단조 증가 위반"| VER["표 안 인라인 오류<br/>showErrors=attempted 일 때만 노출<br/>policy = null"]
  VE -->|"warning<br/>상위 등급 할인율이 더 낮음"| VW["경고 문구 — 저장은 막지 않는다<br/>(zod 밖 policyWarnings)"]
  VE -->|"이슈 없음"| VOK["policy 생성됨"]
  VER --> C3
  VW --> C3
  VOK --> C3

  C3 --> DIRTY{"isDirty ?<br/>serializeDraft(draft) !== baseline"}
  DIRTY -->|"아니오"| NB["'변경 사항이 없습니다'<br/>저장 버튼 비활성"]
  DIRTY -->|"예"| DB["'저장하지 않은 변경 사항이 있습니다'<br/>저장 버튼 활성"]
  NB --> EDIT

  DB --> NAV{"화면 이탈 시도?"}
  NAV -->|"예"| UNS["useUnsavedChangesDialog<br/>intent='discard' 확인 다이얼로그"]
  UNS --> EDIT
  NAV -->|"아니오 · 저장 클릭"| RS["requestSave()<br/>attempted=true · validateDraft 재실행"]

  RS --> RG{"policy === null ?"}
  RG -->|"예"| RE["실패 토스트<br/>'입력값이 규칙에 맞지 않아 저장하지 않았습니다'<br/>→ 표의 인라인 오류 확인"]
  RE --> EDIT
  RG -->|"아니오"| CD["ConfirmDialog intent='update'<br/>'이후 등급 산정부터 새 기준이 적용됩니다'"]

  CD --> CC{"확인 / 취소"}
  CC -->|"취소·Esc·딤"| CX["controller.abort()<br/>savePolicy.reset() · 알림 없음"]
  CX --> EDIT
  CC -->|"확인"| MU["useSaveTierPolicy.mutate(policy, signal)"]

  MU --> MR{"결과"}
  MR -->|"성공"| MOK["baseline=저장 스냅샷 · attempted=false<br/>다이얼로그 닫힘 · 성공 토스트<br/>tier-policy 무효화 → 저장 버튼 비활성"]
  MR -->|"isAbort"| CX
  MR -->|"실패"| MERR["다이얼로그 유지 + 안의 danger 배너<br/>확인 재클릭 = 재시도"]
  MERR --> MU
  MOK --> EDIT

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,VE,DIRTY,NAV,RG,CC,MR gate
  class E1,VER,RE,MERR err
  class VOK,MOK ok
