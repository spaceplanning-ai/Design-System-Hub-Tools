{
  "name": "@tds/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "E2E / 통합 테스트 — FS-NNN 의 요소 번호와 예외 7축을 실행 가능한 Playwright 시나리오로 옮긴다. 백엔드는 없다: 화면은 data-source 어댑터의 픽스처로 돈다.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3"
  }
}
