{
  "name": "css-frameworks-storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm build:tokens && pnpm build:tw && storybook build",
    "build:tokens": "node scripts/build-tokens.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build:manifest": "node scripts/build-story-manifest.mjs",
    "build:tw": "tailwindcss -i src/frameworks/tailwind/tailwind.source.css -o src/frameworks/tailwind/tailwind.generated.css --minify",
    "snapshots": "node scripts/capture-snapshots.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@heroicons/react": "^2.1.0",
    "@material-symbols/svg-400": "^0.45.5",
    "@tabler/icons-react": "^3.44.0",
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.11.0",
    "bulma": "^1.0.0",
    "chart.js": "^4.5.1",
    "foundation-sites": "^6.9.0",
    "lucide-react": "^1.23.0",
    "materialize-css": "^1.0.0",
    "normalize.css": "^8.0.0",
    "pretendard": "^1.3.9",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.0",
    "semantic-ui-css": "^2.5.0",
    "skeleton-css": "^2.0.4",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-designs": "^8.2.1",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/blocks": "^8.6.18",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/theming": "^8.6.18",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.0",
    "sass": "^1.70.0",
    "storybook": "^8.6.0",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.23.1",
      "onFail": "download"
    }
  }
}
