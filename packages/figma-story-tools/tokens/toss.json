{
  "$preset": "toss",
  "color": {
    "primary": "#3182F6",
    "secondary": "#4E5968",
    "error": "#F04452",
    "success": "#00C471",
    "bg": "#FFFFFF",
    "text": "#191F28"
  },
  "typography": {
    "fontFamily": "'Pretendard', -apple-system, sans-serif",
    "baseSize": 16,
    "scale": 1.2,
    "sizes": { "xs": 11, "sm": 13, "md": 16, "lg": 19, "xl": 23, "xxl": 28 },
    "weights": { "regular": 400, "medium": 500, "bold": 700 }
  },
  "radius": { "sm": 4, "md": 8, "lg": 12 },
  "spacing": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24 }
}
