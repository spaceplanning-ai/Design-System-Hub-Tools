{
  "$preset": "bootstrap",
  "color": {
    "primary": "#7952B3",
    "secondary": "#6C757D",
    "error": "#DC3545",
    "success": "#198754",
    "warning": "#FFC107",
    "bg": "#FFFFFF",
    "bgSubtle": "#F8F9FA",
    "text": "#212529",
    "border": "#DEE2E6"
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "baseSize": 16,
    "scale": 1.25,
    "sizes": { "xs": 10, "sm": 13, "md": 16, "lg": 20, "xl": 25, "xxl": 31 },
    "weights": { "regular": 400, "medium": 500, "bold": 700 }
  },
  "radius": { "sm": 4, "md": 8, "lg": 12 },
  "spacing": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24 }
}
