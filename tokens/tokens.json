    "overlay": {
      "$description": "Modal·Toast 가 함께 소비하는 enter/exit 모션 recipe (MOTION-08). 오버레이는 '들어올 때 감속(decelerate)·나갈 때 가속(accelerate)' 한다 — 등장은 눈이 따라갈 시간을 주고, 퇴장은 길을 막지 않고 빠르게 비운다. prefers-reduced-motion:reduce 에서는 각 컴포넌트 CSS 가 애니메이션을 끄고, 소비자는 Web Animations API 로 '애니메이션 없음'을 관측해 즉시 unmount 한다 (MOTION-03).",
      "enter-duration": {
        "$type": "duration",
        "$value": "{motion.duration.normal}",
        "$description": "250ms — 오버레이 등장. fast 는 딤+다이얼로그가 함께 움직이기엔 짧다"
      },
      "enter-easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.decelerate}",
        "$description": "들어오며 감속 — 도착점에서 부드럽게 멎는다"
      },
      "exit-duration": {
        "$type": "duration",
        "$value": "{motion.duration.fast}",
        "$description": "150ms — 퇴장은 짧다. 닫기는 이미 결정된 동작이라 기다리게 하면 안 된다"
      },
      "exit-easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.accelerate}",
        "$description": "나가며 가속 — 화면에서 빠르게 이탈한다"
      }
    }
  }
}
