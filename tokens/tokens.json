    "typography": {
      "font-family": {
        "$type": "fontFamily",
        "sans": {
          "$value": ["Pretendard", "-apple-system", "Segoe UI", "sans-serif"]
        },
        "mono": {
          "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "Consolas", "monospace"],
          "$description": "고정폭 — 시크릿 키·송장번호·JSON 페이로드·토큰 경로처럼 글자를 하나씩 대조해 읽는 값. 비례폭에서는 0/O · 1/l 이 구분되지 않아 오독을 부른다"
        }
      },
      "font-size": {
        "$type": "dimension",
        "12": {
          "$value": "0.75rem"
        },
        "14": {
          "$value": "0.875rem"
        },
        "16": {
          "$value": "1rem"
        },
        "18": {
          "$value": "1.125rem"
        },
        "20": {
          "$value": "1.25rem"
        },
        "24": {
          "$value": "1.5rem"
        }
      },
      "font-weight": {
        "$type": "fontWeight",
        "regular": {
          "$value": 400
        },
        "medium": {
          "$value": 500
        },
        "semibold": {
          "$value": 600
        },
        "bold": {
          "$value": 700
        }
      },
      "line-height": {
        "$type": "number",
        "tight": {
          "$value": 1.2
        },
        "normal": {
          "$value": 1.5
        }
      }
    },
    "border-width": {
      "$type": "dimension",
      "$description": "테두리 두께. CSS 키워드(thin/medium/thick)는 브라우저마다 계산값이 달라 디자인 스펙과 어긋나므로, 명시 두께가 필요한 곳은 이 토큰을 쓴다.",
      "1": {
        "$value": "1px"
      },
      "2": {
        "$value": "2px"
      },
      "4": {
        "$value": "4px"
      }
    },
    "breakpoint": {
      "$type": "dimension",
      "$description": "반응형 분기점. CSS 미디어 쿼리는 스펙상 var()를 받지 못하므로(커스텀 프로퍼티는 media feature 값에 사용 불가), 이 값들은 CSS 변수로도 노출되지만 미디어 쿼리 안에서는 동일 값을 리터럴로 미러링해야 한다. 미러링 지점에는 참조 토큰 경로를 주석으로 남길 것.",
      "640": {
        "$value": "640px"
      },
      "768": {
        "$value": "768px"
      },
      "1024": {
        "$value": "1024px"
      }
    },
    "motion": {
      "duration": {
        "$type": "duration",
        "fast": {
          "$value": "150ms"
        },
        "normal": {
          "$value": "250ms"
        },
        "slow": {
          "$value": "400ms"
        }
      },
      "easing": {
        "$type": "cubicBezier",
        "standard": {
          "$value": [0.4, 0, 0.2, 1]
        },
        "decelerate": {
          "$value": [0, 0, 0.2, 1]
        },
        "accelerate": {
          "$value": [0.4, 0, 1, 1]
        }
      }
    }
  },
  "color": {
    "$description": "2계층 semantic — 색. 모든 토큰은 primitive 참조 + tds.modes 라이트/다크 페어링 필수. 계약(tokens 블록)과 컴포넌트 토큰은 이 계층만 참조한다.",
    "$type": "color",
    "$extensions": {
      "tds.tier": "semantic"
    },
    "action": {
      "primary": {
        "default": {
          "$value": "{primitive.color.blue.600}",
          "$description": "기본 액션 배경. on-primary 텍스트와 대비비 light 5.17:1 / dark 6.99:1 (>= 4.5:1)",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.blue.600}",
              "dark": "{primitive.color.blue.400}"
            }
          }
        },
        "hover": {
          "$value": "{primitive.color.blue.700}",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.blue.700}",
              "dark": "{primitive.color.blue.300}"
            }
          }
        },
        "active": {
          "$value": "{primitive.color.blue.800}",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.blue.800}",
              "dark": "{primitive.color.blue.200}"
            }
          }
        },
        "disabled": {
          "$value": "{primitive.color.gray.300}",
          "$description": "비활성 배경 — WCAG 대비비 예외 대상 (disabled 컨트롤)",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.gray.300}",
              "dark": "{primitive.color.gray.700}"
            }
          }
        }
      }
    },
    "text": {
      "on-primary": {
        "$value": "{primitive.color.gray.0}",
        "$description": "primary 액션 배경 위 텍스트. dark 모드는 밝은 배경(blue.400)이므로 어두운 텍스트로 페어링",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.0}",
            "dark": "{primitive.color.gray.900}"
          }
        }
      },
      "default": {
        "$value": "{primitive.color.gray.900}",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.900}",
            "dark": "{primitive.color.gray.100}"
          }
        }
      },
      "muted": {
        "$value": "{primitive.color.gray.600}",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.600}",
            "dark": "{primitive.color.gray.400}"
          }
        }
      },
      "disabled": {
        "$value": "{primitive.color.gray.500}",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.500}",
            "dark": "{primitive.color.gray.500}"
          }
        }
      }
    },
    "surface": {
      "default": {
        "$value": "{primitive.color.gray.0}",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.0}",
            "dark": "{primitive.color.gray.900}"
          }
        }
      },
      "raised": {
        "$value": "{primitive.color.gray.100}",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.100}",
            "dark": "{primitive.color.gray.800}"
          }
        }
      },
      "skeleton": {
        "$value": "{primitive.color.gray.200}",
        "$description": "로딩 스켈레톤 배경 — 콘텐츠 자리표시",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.200}",
            "dark": "{primitive.color.gray.700}"
          }
        }
      },
      "disabled": {
        "$value": "{primitive.color.gray.100}",
        "$description": "비활성 컨트롤 배경 — WCAG 대비비 예외 대상",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.100}",
            "dark": "{primitive.color.gray.800}"
          }
        }
      }
    },
    "border": {
      "default": {
        "$value": "{primitive.color.gray.300}",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.300}",
            "dark": "{primitive.color.gray.700}"
          }
        }
      },
      "subtle": {
        "$value": "{primitive.color.gray.200}",
        "$description": "장식용 구분선 전용 — 표 행 divider 처럼 '이미 내용으로 구분된 것을 거들기만' 하는 선. Toss 는 강한 테두리 대신 옅은 divider + 여백으로 행을 나눈다 (ERP-02).\n\n[border.default 를 옅게 만들지 않고 토큰을 따로 둔 이유] border.default 는 input/Card 처럼 UI 컴포넌트의 경계를 그리므로 WCAG 1.4.11(비텍스트 3:1)의 대상이다 — 이미 white 위 1.47:1 로 미달인데 더 옅게 하면 악화된다. 반면 이 토큰은 장식(decorative) 구분선에만 쓰이므로 1.4.11 대상이 아니다. 컨트롤 경계에 이 토큰을 쓰지 말 것.",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.gray.200}",
            "dark": "{primitive.color.gray.800}"
          }
        }
      },
      "focus": {
        "$value": "{primitive.color.blue.600}",
        "$description": "focus-visible 링. 인접 배경과 3:1 이상 (비텍스트 UI 기준)",
        "$extensions": {
          "tds.modes": {
            "light": "{primitive.color.blue.600}",
            "dark": "{primitive.color.blue.400}"
          }
        }
      }
    },
    "overlay": {
      "$value": "{primitive.color.overlay.light}",
      "$description": "모달/드로어/시트/토스트 백드롭 딤 — alpha 내장. text 색 + 매직 opacity 대신 이 토큰을 참조한다.",
      "$extensions": {
        "tds.modes": {
          "light": "{primitive.color.overlay.light}",
          "dark": "{primitive.color.overlay.dark}"
        }
      }
    },
    "feedback": {
      "$description": "상태 피드백(Alert · 인라인 에러 · 상태 뱃지). 각 의미별로 surface(배경) · border(테두리) · text(전경) 3종을 제공한다. text 는 같은 의미의 surface 위에서 4.5:1 이상, border 는 3:1 이상(비텍스트 UI 기준).",
      "danger": {
        "surface": {
          "$value": "{primitive.color.red.100}",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.red.100}",
              "dark": "{primitive.color.red.800}"
            }
          }
        },
        "border": {
          "$value": "{primitive.color.red.600}",
          "$description": "danger surface 위 3.95:1 / 페이지 배경(white) 위 4.83:1 (>= 3:1 비텍스트 UI)",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.red.600}",
              "dark": "{primitive.color.red.400}"
            }
          }
        },
        "text": {
          "$value": "{primitive.color.red.700}",
          "$description": "red.100 위에서 6.48:1 / dark: red.200 on red.800 에서 7.31:1",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.red.700}",
              "dark": "{primitive.color.red.200}"
            }
          }
        }
      },
      "success": {
        "surface": {
          "$value": "{primitive.color.green.100}",
          "$extensions": {
            "tds.modes": {
              "light": "{primitive.color.green.100}",
              "dark": "{primitive.color.green.800}"
            }
          }
        },
