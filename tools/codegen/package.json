{
  "name": "@tds/codegen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TDS 코드 생성 파이프라인 — contracts/*.contract.json + tokens/tokens.json(DTCG)을 단일 원천으로 React 타입, Storybook argTypes, Figma Properties, Docs, CSS 변수를 자동 생성한다.",
  "scripts": {
    "generate": "tsx src/index.ts",
    "check": "tsx src/index.ts --check",
    "validate": "tsx src/validate-contract.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
