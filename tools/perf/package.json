{
  "name": "@tds/perf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "성능 감사 — packages/ui public entry의 gzip 번들 예산(size-limit, 컴포넌트당 +2KB 규칙)을 검사하고, 초과 시 G6 차단 입력(exit 1)을 생성한다",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "audit": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@size-limit/file": "^11.1.6",
    "@types/node": "^20.17.0",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
