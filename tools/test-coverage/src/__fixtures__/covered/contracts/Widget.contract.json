{
  "name": "Widget",
  "version": "1.0.0",
  "level": "atom",
  "description": "골든 픽스처 전용 가상 계약. 실제 컴포넌트가 아니다 — 테스트 커버리지 자기 검증(selftest)의 입력이다.",
  "props": {
    "disabled": { "type": "boolean", "default": false },
    "loading": { "type": "boolean", "default": false }
  },
  "events": {
    "onClick": {
      "payload": "MouseEvent",
      "blockedWhen": ["disabled", "loading"],
      "description": "disabled/loading 상태에서는 발화 금지"
    }
  },
  "states": ["default", "disabled", "loading"]
}
