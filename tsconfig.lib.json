{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "packages/design-kit/dist/types",
    "rootDir": "src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/lib.ts"]
}
